<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= __('challengesPage.leaderboardTitle') %> — <%= __('title') %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/design-system.css" />
  <link rel="stylesheet" href="/css/main_page.css" />
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #fff; color: #2d2d2d; }
    .lb-container { max-width: 700px; margin: 0 auto; padding: 2rem 1.5rem; }
    .back-link { font-size: 13px; color: #1a5276; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; margin-bottom: 1.5rem; }
    .back-link:hover { color: #0d3b54; }
    .page-title { font-size: 28px; font-weight: 600; font-family: Inter, sans-serif; margin-bottom: 0.25rem; }
    .page-subtitle { font-size: 15px; color: #6c757d; margin-bottom: 2rem; }

    .lb-table { width: 100%; border-collapse: collapse; }
    .lb-table th { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #6c757d; padding: 0.5rem 0.75rem; border-bottom: 2px solid #dee2e6; text-align: left; }
    .lb-table td { padding: 0.6rem 0.75rem; border-bottom: 1px solid #f0f0f0; font-size: 14px; }
    .lb-table tr:hover { background: #f8f9fa; }
    .rank-cell { width: 40px; text-align: center; font-weight: 600; }
    .rank-gold { color: #d4a017; }
    .rank-silver { color: #8a8a8a; }
    .rank-bronze { color: #a0522d; }
    .user-cell { display: flex; align-items: center; gap: 0.5rem; }
    .user-cell img { width: 28px; height: 28px; border-radius: 50%; object-fit: cover; }
    .user-cell a { color: #1a5276; text-decoration: none; font-weight: 500; }
    .user-cell a:hover { color: #0d3b54; }
    .score-cell { font-weight: 600; }
    .streak-cell { color: #6c757d; }
    .empty-state { text-align: center; padding: 3rem 1rem; color: #6c757d; }
  </style>
</head>
<body>
  <%- include('../default/main_site_header') %>

  <div class="lb-container">
    <a href="/compete" class="back-link">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <%= __('challengesPage.challenges') %>
    </a>

    <h1 class="page-title"><%= __('challengesPage.leaderboardTitle') %></h1>
    <p class="page-subtitle"><%= __('challengesPage.leaderboardSubtitle') %></p>

    <% if (leaderboard.length > 0) { %>
    <table class="lb-table">
      <thead>
        <tr>
          <th class="rank-cell">#</th>
          <th><%= __('challengesPage.user') %></th>
          <th><%= __('challengesPage.solved') %></th>
          <th><%= __('challengesPage.score') %></th>
          <th><%= __('challengesPage.streak') %></th>
          <th><%= __('challengesPage.bestStreak') %></th>
        </tr>
      </thead>
      <tbody>
        <% leaderboard.forEach(function(entry, idx) { %>
        <tr>
          <td class="rank-cell <%= idx === 0 ? 'rank-gold' : idx === 1 ? 'rank-silver' : idx === 2 ? 'rank-bronze' : '' %>">
            <%= idx + 1 %>
          </td>
          <td>
            <div class="user-cell">
              <img src="<%= entry.profile_picture || '/img/profile_images/Default_placeholder.svg' %>" alt="" />
              <a href="/user/<%= entry.username %>"><%= entry.username %></a>
            </div>
          </td>
          <td><%= entry.total_solved %></td>
          <td class="score-cell"><%= entry.total_score %></td>
          <td class="streak-cell"><%= entry.current_streak %>w</td>
          <td class="streak-cell"><%= entry.longest_streak %>w</td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } else { %>
    <div class="empty-state">
      <p style="font-size: 16px; font-weight: 500;"><%= __('challengesPage.noScoresLeaderboard') %></p>
      <p><%= __('challengesPage.completeChallengesToAppear') %></p>
      <a href="/compete" style="color: #1a5276;"><%= __('challengesPage.viewCurrentChallenge') %></a>
    </div>
    <% } %>
  </div>

  <%- include('../default/modern_footer') %>
  <%- include('../default/main_site_search_script') %>
  <script src="/js/analytics.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= (challenge.title ? (challenge.title.includes('|') ? (lang === 'ru' ? challenge.title.split('|')[1] : challenge.title.split('|')[0]) : challenge.title) : (lang === 'ru' ? 'Задача #' : 'Challenge #') + challenge.id) %> — <%= __('title') %></title>

  <script type="application/ld+json">
  {
      "@context": "https://schema.org",
      "@type": "Article",
      "name": "<%= (challenge.title ? (challenge.title.includes('|') ? (lang === 'ru' ? challenge.title.split('|')[1] : challenge.title.split('|')[0]) : challenge.title) : (lang === 'ru' ? 'Задача #' : 'Challenge #') + challenge.id).replace(/"/g, '\\"') %>",
      "educationalLevel": "University",
      "learningResourceType": "Challenge Problem",
      "url": "https://savchenkosolutions.com/compete/<%= challenge.id %>",
      "isPartOf": {
          "@type": "WebSite",
          "name": "Savchenko Solutions",
          "url": "https://savchenkosolutions.com"
      }
  }
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/design-system.css" />
  <link rel="stylesheet" href="/css/main_page.css" />
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
  MathJax = {
    tex: {
      inlineMath: [['$', '$'], ['\\(', '\\)']],
      displayMath: [['$$', '$$'], ['\\[', '\\]']],
      processEscapes: true
    },
    options: {
      skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code']
    }
  };
  </script>
  <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"></script>
  <!-- CodeMirror for submission editor -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.10/codemirror.min.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.10/codemirror.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.10/mode/stex/stex.min.js"></script>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #fff; color: #2d2d2d; }
    .challenge-container { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem; }
    .back-link { font-size: 13px; color: #1a5276; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; margin-bottom: 1.5rem; }
    .back-link:hover { color: #0d3b54; }
    .challenge-title { font-size: 24px; font-weight: 600; font-family: Inter, sans-serif; margin-bottom: 0.5rem; }
    .challenge-meta { display: flex; gap: 1rem; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; font-size: 14px; color: #6c757d; }
    .difficulty-badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; background: #1a1a2e; color: #fff; }
    .challenge-statement { font-size: 15px; line-height: 1.8; padding: 1.25rem; background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 8px; margin-bottom: 2rem; }
    .expired-banner { background: #fff3cd; border: 1px solid #ffc107; border-radius: 6px; padding: 0.75rem 1rem; font-size: 14px; color: #856404; margin-bottom: 1.5rem; }

    .solution-section { margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid #dee2e6; }
    .solution-section h3 { font-size: 18px; font-weight: 600; margin-bottom: 1rem; }
    .official-solution { padding: 1.25rem; background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 8px; line-height: 1.8; }
    .correct-sub { padding: 1rem; border: 1px solid #c3e6cb; border-radius: 6px; margin-bottom: 1rem; background: #f8fff8; }
    .correct-sub-header { font-size: 13px; color: #6c757d; margin-bottom: 0.5rem; }
    .correct-sub-content { font-size: 14px; line-height: 1.7; }

    .submission-section { margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid #dee2e6; }
    .submission-section h3 { font-size: 18px; font-weight: 600; margin-bottom: 1rem; }
    .CodeMirror { border: 1px solid #dee2e6; border-radius: 6px; height: 250px; font-size: 14px; }
    .submit-btn { display: inline-block; padding: 0.5rem 1.5rem; background: #1a1a2e; color: #fff; border: none; border-radius: 6px; font-size: 14px; font-weight: 500; cursor: pointer; margin-top: 1rem; }
    .submit-btn:hover { background: #0d0d1a; }
    .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }
    .submit-msg { font-size: 13px; margin-top: 0.5rem; }
    .submit-msg.success { color: #27ae60; }
    .submit-msg.error { color: #c0392b; }
    .preview-box { margin-top: 1rem; padding: 1rem; border: 1px solid #dee2e6; border-radius: 6px; background: #fafafa; display: none; }
    .preview-toggle { font-size: 13px; color: #1a5276; cursor: pointer; margin-top: 0.5rem; display: inline-block; }
    .existing-sub { background: #eaf7ef; border: 1px solid #c3e6cb; border-radius: 6px; padding: 0.75rem 1rem; font-size: 14px; color: #155724; margin-bottom: 1rem; }

    .image-upload-area { margin-top: 1rem; margin-bottom: 1rem; }
    .image-upload-label { font-size: 14px; font-weight: 500; margin-bottom: 0.5rem; display: block; }
    .image-drop-zone { border: 2px dashed #dee2e6; border-radius: 8px; padding: 1.5rem; text-align: center; cursor: pointer; transition: border-color 0.2s, background 0.2s; }
    .image-drop-zone:hover, .image-drop-zone.drag-over { border-color: #1a5276; background: #f0f7fb; }
    .image-drop-zone p { margin: 0; font-size: 14px; color: #6c757d; }
    .image-drop-zone .drop-icon { font-size: 24px; color: #6c757d; margin-bottom: 0.5rem; }
    .image-preview-container { position: relative; display: inline-block; margin-top: 0.75rem; }
    .image-preview-container img { max-width: 100%; max-height: 400px; border-radius: 6px; border: 1px solid #dee2e6; }
    .image-remove-btn { position: absolute; top: 6px; right: 6px; background: rgba(0,0,0,0.6); color: #fff; border: none; border-radius: 50%; width: 24px; height: 24px; font-size: 14px; line-height: 24px; text-align: center; cursor: pointer; padding: 0; }
    .image-remove-btn:hover { background: #c0392b; }
    .image-uploading { font-size: 13px; color: #6c757d; margin-top: 0.5rem; }
    .submission-image { max-width: 100%; max-height: 500px; border-radius: 6px; border: 1px solid #dee2e6; margin-top: 0.5rem; }
    .or-divider { text-align: center; font-size: 13px; color: #6c757d; margin: 1rem 0; position: relative; }
    .or-divider::before, .or-divider::after { content: ''; position: absolute; top: 50%; width: 40%; height: 1px; background: #dee2e6; }
    .or-divider::before { left: 0; }
    .or-divider::after { right: 0; }
  </style>
</head>
<body>
  <%- include('../default/main_site_header') %>

  <%
    const dateLocale = lang === 'ru' ? 'ru-RU' : 'en-US';
    function localTitle(t, id) {
      if (!t) return (lang === 'ru' ? 'Задача #' : 'Challenge #') + id;
      const parts = t.split('|');
      return lang === 'ru' && parts.length > 1 ? parts[1] : parts[0];
    }
  %>

  <div class="challenge-container">
    <a href="/compete" class="back-link">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <%= __('challengesPage.allChallenges') %>
    </a>

    <h1 class="challenge-title"><%= localTitle(challenge.title, challenge.id) %></h1>

    <div class="challenge-meta">
      <% if (challenge.difficulty) { %>
        <span class="difficulty-badge"><%= __('challengesPage.difficulty') %>: <%= challenge.difficulty %>/10</span>
      <% } %>
      <span>
        <%= new Date(challenge.week_start).toLocaleDateString(dateLocale, { month: 'short', day: 'numeric' }) %> &ndash;
        <%= new Date(challenge.week_end).toLocaleDateString(dateLocale, { month: 'short', day: 'numeric', year: 'numeric' }) %>
      </span>
      <span><%= submissionCount %> <%= __('challengesPage.submissions') %></span>
      <% if (challenge.author_name) { %>
        <span><%= lang === 'ru' ? 'от' : 'by' %> <a href="/user/<%= challenge.author_name %>" style="color: #1a5276;"><%= challenge.author_name %></a></span>
      <% } %>
    </div>

    <% if (isExpired) { %>
    <div class="expired-banner"><%= __('challengesPage.challengeEnded') %></div>
    <% } %>

    <div class="challenge-statement"><%- challenge.problem_statement %></div>

    <% if (!isExpired) { %>
      <!-- Countdown -->
      <div style="font-size: 14px; color: #6c757d; margin-bottom: 1.5rem;">
        <%= __('challengesPage.timeRemaining') %>: <strong id="challengeCountdown" data-end="<%= new Date(challenge.week_end).toISOString().slice(0, 10) %>"></strong>
      </div>

      <!-- Submission Form -->
      <% if (typeof username !== 'undefined' && username) { %>
      <div class="submission-section">
        <h3><%= __('challengesPage.yourSubmission') %></h3>
        <% if (userSubmission) { %>
        <div class="existing-sub">
          <%= __('challengesPage.submittedOn') %> <%= new Date(userSubmission.submitted_at).toLocaleDateString(dateLocale, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>. <%= __('challengesPage.canUpdateBelow') %>
        </div>
        <% } %>
        <!-- Image upload -->
        <div class="image-upload-area">
          <label class="image-upload-label"><%= lang === 'ru' ? 'Фото рукописного решения' : 'Photo of handwritten solution' %></label>
          <div id="imageDropZone" class="image-drop-zone" <% if (userSubmission && userSubmission.image_path) { %>style="display: none;"<% } %> onclick="document.getElementById('imageFileInput').click()">
            <div class="drop-icon"><i class="fas fa-camera"></i></div>
            <p><%= lang === 'ru' ? 'Перетащите фото или нажмите для выбора' : 'Drag and drop a photo or click to browse' %></p>
            <p style="font-size: 12px; margin-top: 4px;"><%= lang === 'ru' ? 'JPG, PNG, WebP, HEIC — до 10 МБ' : 'JPG, PNG, WebP, HEIC — up to 10 MB' %></p>
          </div>
          <input type="file" id="imageFileInput" accept="image/jpeg,image/png,image/gif,image/webp,image/heic,.jpg,.jpeg,.png,.gif,.webp,.heic" style="display: none;" />
          <div id="imageUploading" class="image-uploading" style="display: none;"><%= lang === 'ru' ? 'Загрузка...' : 'Uploading...' %></div>
          <div id="imagePreviewContainer" class="image-preview-container" style="display: none;">
            <img id="imagePreview" src="" alt="Uploaded solution" />
            <button type="button" class="image-remove-btn" onclick="removeImage()" title="<%= lang === 'ru' ? 'Удалить' : 'Remove' %>">&times;</button>
          </div>
          <% if (userSubmission && userSubmission.image_path) { %>
          <div id="existingImageContainer" class="image-preview-container" style="margin-top: 0.75rem;">
            <img src="<%= userSubmission.image_path %>" alt="Uploaded solution" />
            <button type="button" class="image-remove-btn" onclick="removeExistingImage()" title="<%= lang === 'ru' ? 'Удалить' : 'Remove' %>">&times;</button>
          </div>
          <% } %>
        </div>

        <div class="or-divider"><%= lang === 'ru' ? 'и / или' : 'and / or' %></div>

        <p style="font-size: 13px; color: #6c757d; margin-bottom: 0.75rem;"><%= __('challengesPage.latexHint') %></p>
        <textarea id="submissionEditor"><%= userSubmission ? userSubmission.content : '' %></textarea>
        <div>
          <button class="submit-btn" id="submitBtn" onclick="submitSolution()">
            <%= userSubmission ? __('challengesPage.updateSubmission') : __('challengesPage.submitSolution') %>
          </button>
          <span class="preview-toggle" onclick="togglePreview()"><%= __('challengesPage.preview') %></span>
        </div>
        <div id="submitMsg" class="submit-msg"></div>
        <div id="previewBox" class="preview-box"></div>
      </div>
      <% } else { %>
      <div style="text-align: center; padding: 2rem 1rem; background: #f8f9fa; border-radius: 8px; border: 1px solid #dee2e6;">
        <p style="margin-bottom: 0.75rem;"><a href="/<%= lang %>/login" style="color: #1a5276; font-weight: 500;"><%= lang === 'ru' ? 'Войдите' : 'Log in' %></a> <%= __('challengesPage.loginToSubmitSolution') %></p>
      </div>
      <% } %>
    <% } %>

    <% if (isExpired) { %>
      <!-- Official Solution -->
      <% if (challenge.solution) { %>
      <div class="solution-section">
        <h3><%= __('challengesPage.officialSolution') %></h3>
        <div class="official-solution"><%- challenge.solution %></div>
      </div>
      <% } %>

      <!-- Correct Submissions -->
      <% if (correctSubmissions.length > 0) { %>
      <div class="solution-section">
        <h3><%= __('challengesPage.correctSubmissions') %> (<%= correctSubmissions.length %>)</h3>
        <% correctSubmissions.forEach(function(sub) { %>
        <div class="correct-sub">
          <div class="correct-sub-header">
            <span class="avatar-presence" style="vertical-align: middle;">
              <img src="<%= sub.profile_picture || '/img/profile_images/Default_placeholder.svg' %>" alt="" style="width: 18px; height: 18px; border-radius: 50%;" />
              <% if (sub.isOnline && sub.username !== (typeof username !== 'undefined' ? username : null)) { %><span class="online-dot" title="<%= lang === 'ru' ? 'В сети' : 'Online' %>"></span><% } %>
            </span>
            <a href="/user/<%= sub.username %>" style="color: #1a5276; font-weight: 500;"><%= sub.username %></a>
            &middot; <%= new Date(sub.submitted_at).toLocaleDateString(dateLocale, { month: 'short', day: 'numeric' }) %>
          </div>
          <% if (sub.image_path) { %>
          <img src="<%= sub.image_path %>" alt="Handwritten solution" class="submission-image" />
          <% } %>
          <% if (sub.content) { %>
          <div class="correct-sub-content"><%- sub.content %></div>
          <% } %>
        </div>
        <% }); %>
      </div>
      <% } %>
    <% } %>
  </div>

  <%- include('../default/modern_footer') %>

  <script>
  // Countdown timer
  (function() {
    const el = document.getElementById('challengeCountdown');
    if (!el) return;
    const rawEnd = (el.dataset.end || '').trim();
    let endDate = null;

    if (/^\d{4}-\d{2}-\d{2}$/.test(rawEnd)) {
      const parts = rawEnd.split('-').map(Number);
      endDate = new Date(parts[0], parts[1] - 1, parts[2], 23, 59, 59);
    } else if (rawEnd) {
      endDate = new Date(rawEnd);
    }

    if (!endDate || Number.isNaN(endDate.getTime())) {
      el.textContent = '—';
      return;
    }
    const expiredLabel = "<%= __('challengesPage.expired') %>";
    function update() {
      const now = new Date();
      const diff = endDate - now;
      if (diff <= 0) {
        el.textContent = expiredLabel;
        return;
      }
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const lang = '<%= lang %>';
      const dLabel = lang === 'ru' ? 'д' : 'd';
      const hLabel = lang === 'ru' ? 'ч' : 'h';
      const mLabel = lang === 'ru' ? 'м' : 'm';
      el.textContent = days + dLabel + ' ' + hours + hLabel + ' ' + mins + mLabel;
    }
    update();
    setInterval(update, 60000);
  })();

  // CodeMirror editor
  let editor;
  const textarea = document.getElementById('submissionEditor');
  if (textarea) {
    editor = CodeMirror.fromTextArea(textarea, {
      mode: 'stex',
      lineNumbers: true,
      lineWrapping: true,
      theme: 'default',
    });
  }

  // Image upload state
  let uploadedImagePath = null;
  const challengeId = <%= challenge.id %>;

  // Image upload handling
  const dropZone = document.getElementById('imageDropZone');
  const fileInput = document.getElementById('imageFileInput');
  const imagePreviewContainer = document.getElementById('imagePreviewContainer');
  const imagePreview = document.getElementById('imagePreview');
  const imageUploading = document.getElementById('imageUploading');

  if (dropZone) {
    dropZone.addEventListener('dragover', function(e) {
      e.preventDefault();
      dropZone.classList.add('drag-over');
    });
    dropZone.addEventListener('dragleave', function() {
      dropZone.classList.remove('drag-over');
    });
    dropZone.addEventListener('drop', function(e) {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      const files = e.dataTransfer.files;
      if (files.length > 0) handleImageFile(files[0]);
    });
  }

  if (fileInput) {
    fileInput.addEventListener('change', function() {
      if (fileInput.files.length > 0) handleImageFile(fileInput.files[0]);
    });
  }

  async function handleImageFile(file) {
    if (file.size > 10 * 1024 * 1024) {
      const msg = document.getElementById('submitMsg');
      msg.className = 'submit-msg error';
      msg.textContent = '<%= lang === "ru" ? "Файл слишком большой (макс. 10 МБ)" : "File too large (max 10 MB)" %>';
      return;
    }

    dropZone.style.display = 'none';
    imageUploading.style.display = 'block';

    const formData = new FormData();
    formData.append('image', file);

    try {
      const resp = await fetch('/compete/' + challengeId + '/upload-image', {
        method: 'POST',
        body: formData,
      });
      const data = await resp.json();
      if (data.success) {
        uploadedImagePath = data.imagePath;
        imagePreview.src = data.imagePath;
        imagePreviewContainer.style.display = 'inline-block';
        const existingContainer = document.getElementById('existingImageContainer');
        if (existingContainer) existingContainer.style.display = 'none';
      } else {
        dropZone.style.display = '';
        const msg = document.getElementById('submitMsg');
        msg.className = 'submit-msg error';
        msg.textContent = data.error || 'Upload failed';
      }
    } catch (err) {
      dropZone.style.display = '';
      const msg = document.getElementById('submitMsg');
      msg.className = 'submit-msg error';
      msg.textContent = '<%= lang === "ru" ? "Ошибка загрузки" : "Upload error" %>';
    }
    imageUploading.style.display = 'none';
    fileInput.value = '';
  }

  function removeImage() {
    uploadedImagePath = null;
    imagePreviewContainer.style.display = 'none';
    imagePreview.src = '';
    dropZone.style.display = '';
  }

  async function removeExistingImage() {
    try {
      const resp = await fetch('/compete/' + challengeId + '/remove-image', { method: 'POST' });
      const data = await resp.json();
      if (data.success) {
        const container = document.getElementById('existingImageContainer');
        if (container) container.remove();
        dropZone.style.display = '';
      }
    } catch (_e) { /* ignore */ }
  }

  // Submit solution
  const t = {
    submitting: "<%= __('challengesPage.submitting') %>",
    saved: "<%= __('challengesPage.submissionSaved') %>",
    updateSubmission: "<%= __('challengesPage.updateSubmission') %>",
    writeSolutionFirst: "<%= lang === 'ru' ? 'Напишите решение или загрузите фото.' : 'Please write your solution or upload a photo.' %>",
    networkError: "<%= __('challengesPage.networkError') %>",
  };

  async function submitSolution() {
    const btn = document.getElementById('submitBtn');
    const msg = document.getElementById('submitMsg');
    const content = editor ? editor.getValue() : (textarea ? textarea.value : '');
    const existingImage = document.getElementById('existingImageContainer');
    const hasExistingImage = existingImage && existingImage.style.display !== 'none';

    if (!content.trim() && !uploadedImagePath && !hasExistingImage) {
      msg.className = 'submit-msg error';
      msg.textContent = t.writeSolutionFirst;
      return;
    }
    btn.disabled = true;
    btn.textContent = t.submitting;
    msg.textContent = '';
    try {
      const body = { content: content.trim() };
      if (uploadedImagePath) body.imagePath = uploadedImagePath;
      const resp = await fetch('/compete/' + challengeId + '/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await resp.json();
      if (data.success) {
        msg.className = 'submit-msg success';
        msg.textContent = t.saved;
        btn.textContent = t.updateSubmission;
      } else {
        msg.className = 'submit-msg error';
        msg.textContent = data.error || 'Failed to submit.';
      }
    } catch (err) {
      msg.className = 'submit-msg error';
      msg.textContent = t.networkError;
    }
    btn.disabled = false;
  }

  // Preview toggle
  function togglePreview() {
    const box = document.getElementById('previewBox');
    if (box.style.display === 'none' || !box.style.display) {
      const content = editor ? editor.getValue() : textarea.value;
      box.innerHTML = content.replace(/</g, '&lt;').replace(/>/g, '&gt;');
      box.style.display = 'block';
      if (typeof MathJax !== 'undefined' && MathJax.typesetPromise) {
        MathJax.typesetPromise([box]);
      }
    } else {
      box.style.display = 'none';
    }
  }
  </script>
  <%- include('../default/main_site_search_script') %>
  <script src="/js/analytics.js"></script>
</body>
</html>

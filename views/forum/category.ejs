<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%
        const catName = __('forumPage.cat_' + category.slug + '_name') !== 'forumPage.cat_' + category.slug + '_name' ? __('forumPage.cat_' + category.slug + '_name') : category.name;
        const catDesc = __('forumPage.cat_' + category.slug + '_desc') !== 'forumPage.cat_' + category.slug + '_desc' ? __('forumPage.cat_' + category.slug + '_desc') : category.description;
    %>
    <title><%= catName %> — <%= __('forumPage.discussion') %> | <%= __('title') %></title>
    <meta name="description" content="<%= catDesc %>" />
    <link rel="canonical" href="https://savchenkosolutions.com/discuss/<%= category.slug %>" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/design-system.css" />
    <link rel="stylesheet" href="/css/main_page.css" />
    <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
    <link rel="icon" type="image/png" href="/img/logo.png" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        .forum-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }
        .forum-breadcrumb {
            font-size: 14px;
            margin-bottom: 1.5rem;
            color: #6c757d;
        }
        .forum-breadcrumb a {
            color: #1a5276;
            text-decoration: none;
        }
        .forum-breadcrumb a:hover {
            color: #0d3b54;
        }
        .forum-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }
        .forum-header h1 {
            font-family: 'Inter', sans-serif;
            font-size: 24px;
            font-weight: 600;
            color: #2d2d2d;
            margin: 0;
        }
        .btn-new-topic {
            background: #1a1a2e;
            color: #fff;
            border: none;
            border-radius: 6px;
            padding: 0.5rem 1.25rem;
            font-size: 14px;
            font-weight: 500;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            transition: background 0.15s;
        }
        .btn-new-topic,
        .btn-new-topic:visited,
        .btn-new-topic:hover,
        .btn-new-topic:focus,
        .btn-new-topic:active {
            color: #fff !important;
            text-decoration: none;
        }
        .btn-new-topic:hover {
            background: #0d0d1a;
        }
        .topic-list {
            border: 1px solid #dee2e6;
            border-radius: 8px;
            overflow: hidden;
        }
        .topic-row {
            display: flex;
            align-items: center;
            padding: 0.85rem 1.25rem;
            border-bottom: 1px solid #dee2e6;
            transition: background 0.1s;
        }
        .topic-row:last-child {
            border-bottom: none;
        }
        .topic-row:hover {
            background: #f8f9fa;
        }
        .topic-row.pinned {
            background: #fefce8;
        }
        .topic-info {
            flex: 1;
            min-width: 0;
        }
        .topic-title-row {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .topic-title {
            font-size: 15px;
            font-weight: 500;
            margin: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .topic-title a {
            color: #2d2d2d;
            text-decoration: none;
        }
        .topic-title a:hover {
            color: #1a5276;
        }
        .pin-icon {
            color: #b8860b;
            flex-shrink: 0;
        }
        .solution-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.2rem;
            font-size: 11px;
            font-weight: 600;
            color: #27ae60;
            flex-shrink: 0;
        }
        .topic-meta {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-top: 0.25rem;
            font-size: 13px;
            color: #6c757d;
        }
        .topic-author-avatar {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            object-fit: cover;
        }
        .topic-stats {
            display: flex;
            gap: 1.25rem;
            flex-shrink: 0;
            margin: 0 1rem;
            font-size: 13px;
            color: #6c757d;
        }
        .topic-stat {
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }
        .topic-last-reply {
            flex-shrink: 0;
            text-align: right;
            font-size: 13px;
            color: #6c757d;
            min-width: 100px;
        }
        .pagination-bar {
            display: flex;
            justify-content: center;
            gap: 0.5rem;
            margin-top: 1.5rem;
        }
        .pagination-bar a, .pagination-bar span {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 36px;
            height: 36px;
            border-radius: 6px;
            border: 1px solid #dee2e6;
            font-size: 14px;
            text-decoration: none;
            color: #2d2d2d;
        }
        .pagination-bar a:hover {
            background: #f8f9fa;
        }
        .pagination-bar .active {
            background: #1a1a2e;
            color: #fff;
            border-color: #1a1a2e;
        }
        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            color: #6c757d;
        }
        @media (max-width: 768px) {
            .forum-container { padding: 1rem 0.75rem; }
            .topic-stats { display: none; }
            .topic-last-reply { display: none; }
            .topic-row { padding: 0.75rem 1rem; }
        }
    </style>
</head>
<body>
    <%- include('../default/main_site_header', { showViewsButton: false }) %>

    <div class="forum-container">
        <div class="forum-breadcrumb">
            <a href="/discuss"><%= __('forumPage.discussion') %></a>
            <span> / </span>
            <span><%= catName %></span>
        </div>

        <div class="forum-header">
            <h1><%= catName %></h1>
            <% if (userId) { %>
                <a href="/discuss/new?category=<%= category.slug %>" class="btn-new-topic">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    <%= __('forumPage.newTopic') %>
                </a>
            <% } else { %>
                <a href="/<%= lang %>/login" class="btn-new-topic">
                    <%= __('forumPage.loginToPost') %>
                </a>
            <% } %>
        </div>

        <% if (topics.length === 0) { %>
        <div class="empty-state">
            <p><%= __('forumPage.noTopicsInCategory') %></p>
        </div>
        <% } else { %>
        <div class="topic-list">
            <% topics.forEach(topic => { %>
            <div class="topic-row<%= topic.is_pinned ? ' pinned' : '' %>">
                <div class="topic-info">
                    <div class="topic-title-row">
                        <% if (topic.is_pinned) { %>
                        <span class="pin-icon" title="Pinned">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"/></svg>
                        </span>
                        <% } %>
                        <p class="topic-title">
                            <a href="/discuss/<%= category.slug %>/<%= topic.id %>-<%= topic.slug %>"><%= translateTopicTitle(topic.title, lang) %></a>
                        </p>
                        <% if (topic.has_solution) { %>
                        <span class="solution-badge" title="<%= __('forumPage.solved') %>">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                            <%= __('forumPage.solved') %>
                        </span>
                        <% } %>
                    </div>
                    <div class="topic-meta">
                        <span class="avatar-presence">
                            <img src="<%= topic.author_avatar || '/img/profile_images/Default_placeholder.svg' %>" alt="" class="topic-author-avatar" />
                            <% if (topic.author_online) { %><span class="online-dot" title="<%= lang === 'ru' ? 'В сети' : 'Online' %>"></span><% } %>
                        </span>
                        <span><%= topic.author_username %></span>
                        <span>&middot;</span>
                        <span><%= timeAgo(topic.created_at) %></span>
                    </div>
                </div>
                <div class="topic-stats">
                    <span class="topic-stat">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                        <%= topic.reply_count %>
                    </span>
                    <span class="topic-stat">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        <%= topic.view_count %>
                    </span>
                </div>
                <div class="topic-last-reply">
                    <% if (topic.last_reply_username) { %>
                        <div><%= topic.last_reply_username %></div>
                        <div><%= timeAgo(topic.last_reply_at) %></div>
                    <% } else { %>
                        <div>-</div>
                    <% } %>
                </div>
            </div>
            <% }); %>
        </div>

        <% if (totalPages > 1) { %>
        <div class="pagination-bar">
            <% if (page > 1) { %>
                <a href="/discuss/<%= category.slug %>?page=<%= page - 1 %>">&laquo;</a>
            <% } %>
            <% for (let i = 1; i <= totalPages; i++) { %>
                <% if (i === page) { %>
                    <span class="active"><%= i %></span>
                <% } else { %>
                    <a href="/discuss/<%= category.slug %>?page=<%= i %>"><%= i %></a>
                <% } %>
            <% } %>
            <% if (page < totalPages) { %>
                <a href="/discuss/<%= category.slug %>?page=<%= page + 1 %>">&raquo;</a>
            <% } %>
        </div>
        <% } %>
        <% } %>
    </div>

    <%- include('../default/modern_footer') %>
    <%- include('../default/main_site_search_script') %>
</body>
</html>

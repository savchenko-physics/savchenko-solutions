<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <%
    const isRu = lang === 'ru';
    const pageTitle = isRu ? 'Июньский конкурс' : 'June Contest';
    const pageDesc = isRu
      ? 'Конкурс авторов решений задачника Савченко. Публикуй новые решения в LaTeX в июне 2026 и выигрывай эксклюзивный мерч. Живая таблица результатов.'
      : 'A contest for Savchenko solution authors. Publish new LaTeX solutions in June 2026 and win exclusive merch. Live leaderboard.';
    function fmtDate(d) {
      const dt = new Date(d);
      const months = isRu
        ? ['января','февраля','марта','апреля','мая','июня','июля','августа','сентября','октября','ноября','декабря']
        : ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      return dt.getUTCDate() + ' ' + months[dt.getUTCMonth()] + (isRu ? '' : ' ' + dt.getUTCFullYear());
    }
    const tierLabels = {
      grand:  isRu ? 'Гран-при' : 'Grand',
      silver: isRu ? 'Серебро' : 'Silver',
      bronze: isRu ? 'Бронза' : 'Bronze',
    };
  %>
  <meta name="description" content="<%= pageDesc %>" />
  <title><%= pageTitle %> — <%= __('title') %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/design-system.css" />
  <link rel="stylesheet" href="/css/main_page.css" />
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #fff; color: #2d2d2d; }
    .contest-container { max-width: 1080px; margin: 0 auto; padding: 1.25rem 1rem 3rem; }

    .contest-eyebrow { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.6px; color: #1a5276; }
    .contest-title { font-size: 30px; font-weight: 700; font-family: Inter, sans-serif; color: #1a1a2e; margin: 0.25rem 0 0.4rem; }
    .contest-sub { font-size: 15px; color: #6c757d; max-width: 680px; line-height: 1.6; }
    .contest-dates { font-size: 13px; color: #6c757d; margin-top: 0.6rem; }
    .contest-dates strong { color: #2d2d2d; }

    /* Live counter */
    .counter-card { background: #1a1a2e; color: #fff; border-radius: 8px; padding: 1.5rem 1.5rem 1.25rem; margin: 1.5rem 0; }
    .counter-top { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; }
    .counter-number { font-size: 44px; font-weight: 800; font-family: Inter, sans-serif; line-height: 1; }
    .counter-label { font-size: 14px; color: #c9c9d4; }
    .counter-goal { font-size: 13px; color: #c9c9d4; }
    .progress-track { height: 8px; background: rgba(255,255,255,0.16); border-radius: 6px; margin-top: 1rem; overflow: hidden; }
    .progress-fill { height: 100%; background: #27ae60; border-radius: 6px; width: 0; transition: width 0.6s ease; }
    .counter-foot { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.7rem; font-size: 13px; color: #c9c9d4; }
    .counter-foot .live-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #27ae60; margin-right: 6px; vertical-align: middle; }

    .section { margin-top: 2rem; }
    .section-title { font-size: 19px; font-weight: 600; font-family: Inter, sans-serif; color: #1a1a2e; margin-bottom: 0.85rem; }

    .contest-layout { display: grid; grid-template-columns: 1fr 320px; gap: 1.75rem; align-items: start; }
    @media (max-width: 860px) { .contest-layout { grid-template-columns: 1fr; } }

    /* Prizes */
    .prizes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.85rem; }
    .prizes-community { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.85rem; margin-top: 0.85rem; }
    @media (max-width: 620px) { .prizes { grid-template-columns: 1fr; } .prizes-community { grid-template-columns: 1fr; } }
    .prize { border: 1px solid #dee2e6; border-radius: 8px; padding: 1rem; background: #f8f9fa; }
    .prize-locked { opacity: 0.6; }
    .prize-badge { display: inline-block; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; padding: 2px 9px; border-radius: 12px; margin-bottom: 0.55rem; }
    .badge-grand { background: #1a1a2e; color: #fff; }
    .badge-silver { background: #6c757d; color: #fff; }
    .badge-bronze { background: #fff; color: #2d2d2d; border: 1px solid #dee2e6; }
    .badge-org { background: #f8f9fa; color: #6c757d; border: 1px solid #dee2e6; }
    .badge-raffle { background: #1a5276; color: #fff; }
    .badge-spotlight { background: #7d6608; color: #fff; }
    .prize-h { font-size: 15px; font-weight: 600; color: #2d2d2d; margin-bottom: 0.2rem; }
    .prize-p { font-size: 13px; color: #6c757d; line-height: 1.5; margin: 0; }
    .prize-lock-note { font-size: 12px; color: #c0392b; margin-top: 0.5rem; font-weight: 500; }
    .prizes-section-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #6c757d; margin: 1.25rem 0 0.5rem; }

    /* Merch */
    .merch-note { font-size: 13px; color: #6c757d; margin-bottom: 0.75rem; }
    .merch-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.6rem; }
    @media (max-width: 620px) { .merch-grid { grid-template-columns: 1fr 1fr; } }
    .merch-grid img { width: 100%; height: 260px; object-fit: contain; border: 1px solid #dee2e6; border-radius: 8px; background: #f8f9fa; padding: 4px; }
    .exclusive-tag { display: inline-block; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #c0392b; border: 1px solid #c0392b; border-radius: 12px; padding: 2px 9px; margin-left: 0.5rem; vertical-align: middle; }

    /* Rules + multipliers */
    .rules-list { font-size: 14px; line-height: 1.7; color: #2d2d2d; padding-left: 1.1rem; margin: 0; }
    .mult-table { width: 100%; border-collapse: collapse; margin-top: 0.85rem; font-size: 14px; }
    .mult-table th, .mult-table td { text-align: left; padding: 0.5rem 0.6rem; border-bottom: 1px solid #f0f0f0; }
    .mult-table th { font-weight: 600; color: #6c757d; font-size: 12px; text-transform: uppercase; letter-spacing: 0.4px; }
    .mult-table td:last-child, .mult-table th:last-child { text-align: right; font-variant-numeric: tabular-nums; }

    /* Leaderboard */
    .lb-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .lb-table th { font-size: 12px; text-transform: uppercase; letter-spacing: 0.4px; color: #6c757d; font-weight: 600; text-align: left; padding: 0.4rem 0.5rem; border-bottom: 1px solid #dee2e6; }
    .lb-table td { padding: 0.55rem 0.5rem; border-bottom: 1px solid #f0f0f0; vertical-align: middle; }
    .lb-rank { width: 30px; text-align: center; font-weight: 700; color: #6c757d; }
    .lb-user { display: flex; align-items: center; gap: 0.5rem; min-width: 0; }
    .lb-avatar { width: 28px; height: 28px; border-radius: 50%; object-fit: cover; background: #e9ecef; flex-shrink: 0; }
    .lb-user a { color: #1a5276; text-decoration: none; font-weight: 500; }
    .lb-user a:hover { color: #0d3b54; }
    .lb-country { font-size: 12px; color: #6c757d; }
    .lb-num { text-align: right; font-variant-numeric: tabular-nums; }
    .lb-points { font-weight: 600; }
    .tier-pill { display: inline-block; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; padding: 1px 7px; border-radius: 10px; }
    .lb-empty { text-align: center; color: #6c757d; padding: 1.5rem 0; font-size: 14px; }

    /* Feed sidebar */
    .side-card { border: 1px solid #dee2e6; border-radius: 8px; padding: 1rem; background: #f8f9fa; margin-bottom: 1.25rem; }
    .side-title { font-size: 14px; font-weight: 600; color: #1a1a2e; margin-bottom: 0.6rem; }
    .feed-list { list-style: none; padding: 0; margin: 0; }
    .feed-item { padding: 0.45rem 0; border-bottom: 1px solid #ececec; font-size: 13px; }
    .feed-item:last-child { border-bottom: none; }
    .feed-item a { color: #1a5276; text-decoration: none; font-weight: 500; }
    .feed-meta { color: #6c757d; font-size: 12px; margin-top: 1px; }
    .feed-lang { font-size: 10px; font-weight: 600; text-transform: uppercase; color: #6c757d; border: 1px solid #dee2e6; border-radius: 4px; padding: 0 4px; margin-left: 4px; }

    .cta-card { border: 1px solid #dee2e6; border-radius: 8px; padding: 1.1rem; background: #fff; }
    .btn-primary-navy, .btn-primary-navy:link, .btn-primary-navy:visited { display: inline-block; background: #1a1a2e; color: #fff !important; border: none; border-radius: 6px; padding: 0.55rem 1.2rem; font-size: 14px; font-weight: 500; text-decoration: none; text-align: center; }
    .btn-primary-navy:hover, .btn-primary-navy:focus { background: #0d0d1a; color: #fff !important; }
    .btn-outline-navy, .btn-outline-navy:link, .btn-outline-navy:visited { display: inline-block; background: transparent; color: #2d2d2d !important; border: 1px solid #dee2e6; border-radius: 6px; padding: 0.55rem 1.2rem; font-size: 14px; font-weight: 500; text-decoration: none; text-align: center; }
    .btn-outline-navy:hover, .btn-outline-navy:focus { background: #f8f9fa; color: #2d2d2d !important; }

    .countdown-line { font-size: 13px; color: #6c757d; margin-top: 0.4rem; }
    .countdown-line strong { color: #1a1a2e; }

    .contest-review-banner {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      background: #f8f9fa;
      border: 1px solid #dee2e6;
      border-left: 3px solid #27ae60;
      border-radius: 8px;
      padding: 12px 14px;
      margin-bottom: 18px;
    }
    .contest-review-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: #27ae60;
      flex-shrink: 0;
      margin-top: 5px;
    }
    .contest-review-banner strong { display: block; font-size: 14px; color: #1a1a2e; margin-bottom: 2px; }
    .contest-review-banner span { font-size: 13px; color: #6c757d; line-height: 1.5; }
  </style>
</head>
<body>
  <%- include('../default/main_site_header') %>

  <div class="contest-container">

    <% if (contest.reviewPhase) { %>
    <!-- Review-stage notice -->
    <div class="contest-review-banner" role="status">
      <span class="contest-review-dot" aria-hidden="true"></span>
      <div>
        <strong><%= isRu ? 'Конкурс завершён — идёт проверка решений' : 'The contest has ended — solutions are under review' %></strong>
        <span><%= isRu
          ? 'Приём решений закрыт. Сейчас мы вручную проверяем и подтверждаем каждое решение. Итоги и победители будут объявлены после завершения проверки.'
          : 'Submissions are closed. We are now manually reviewing and validating every solution. Final results and winners will be announced once the review is complete.' %></span>
      </div>
    </div>
    <% } %>

    <!-- Header -->
    <div>
      <div class="contest-eyebrow"><%= isRu ? 'Конкурс сообщества' : 'Community contest' %></div>
      <h1 class="contest-title"><%= isRu ? 'Июньский конкурс. Новые решения, эксклюзивный мерч' : 'June Contest. New solutions, exclusive merch' %></h1>
      <p class="contest-sub">
        <%= isRu
          ? 'Публикуй новые решения задач Савченко в LaTeX в течение июня. Каждый, кто публикует решение, автоматически участвует. Два полных набора мерча и кепки уезжают лучшим авторам месяца.'
          : 'Publish new LaTeX solutions to Savchenko problems through June. Everyone who publishes a solution automatically takes part. Two full merch sets and caps go to the month\'s best authors.' %>
      </p>
      <div class="contest-dates">
        <strong><%= fmtDate(contest.startDate) %></strong> — <strong><%= fmtDate(contest.endDate) %> 2026</strong>
        <% if (contest.reviewPhase) { %>
        <span class="countdown-line"><%= isRu ? '· конкурс завершён' : '· contest ended' %></span>
        <% } else { %>
        <span id="countdownLine" class="countdown-line" data-end="<%= contest.endDate %>"></span>
        <% } %>
      </div>
    </div>

    <!-- Live counter -->
    <div class="counter-card">
      <div class="counter-top">
        <div>
          <div class="counter-number" id="counterNumber"><%= contest.totalSolutions %></div>
          <div class="counter-label"><%= isRu ? 'новых решений за июнь' : 'new solutions in June' %></div>
        </div>
        <div style="text-align:right;">
          <div class="counter-goal">
            <%= isRu ? 'Цель сообщества' : 'Community goal' %>
            <strong style="color:#fff;"><%= contest.goalSolutions %></strong>
          </div>
          <% if (contest.stretchUnlocked) { %>
            <div style="font-size:12px;color:#27ae60;margin-top:3px;font-weight:600;"><%= isRu ? 'Цель достигнута — жеребьёвка открыта' : 'Goal reached — raffle unlocked' %></div>
          <% } %>
        </div>
      </div>
      <div style="position:relative;margin-top:1rem;">
        <div class="progress-track" style="margin-top:0;"><div class="progress-fill" id="progressFill"></div></div>
        <div id="milestoneTick" style="position:absolute;top:-3px;bottom:-3px;width:2px;background:rgba(255,255,255,0.35);border-radius:1px;pointer-events:none;"></div>
      </div>
      <div class="counter-foot" style="margin-top:0.5rem;">
        <span><span class="live-dot"></span><span id="participantsCount"><%= contest.participants %></span> <%= isRu ? 'участников' : 'participants' %></span>
        <span id="remainingGoal"></span>
      </div>
      <div style="margin-top:0.85rem;padding-top:0.75rem;border-top:1px solid rgba(255,255,255,0.12);font-size:13px;color:#c9c9d4;line-height:1.6;" id="communityMsg">
        <% const toStretch = Math.max(0, contest.goalSolutions - contest.totalSolutions); %>
        <% if (!contest.stretchUnlocked) { %>
          <%= isRu
            ? `До цели осталось ${toStretch} решений. Если каждый участник добавит ещё десяток — мы перешагнём ${contest.goalSolutions} вместе. Когда сообщество достигнет этой отметки, призовой фонд расширится: два дополнительных комплекта мерча уйдут в жеребьёвку среди всех, кто набрал не менее ${contest.stretchRaffleThreshold} баллов.`
            : `${toStretch} solutions to go. When the community hits ${contest.goalSolutions}, the prize pool expands: two extra merch sets enter a raffle open to everyone with at least ${contest.stretchRaffleThreshold} points. The top does not take them — they are drawn randomly.` %>
        <% } else { %>
          <%= isRu
            ? `Сообщество достигло ${contest.goalSolutions} решений. Два дополнительных комплекта мерча разыгрываются среди всех участников с не менее ${contest.stretchRaffleThreshold} баллами.`
            : `The community reached ${contest.goalSolutions} solutions. Two extra merch sets will be raffled among all participants with at least ${contest.stretchRaffleThreshold} points.` %>
        <% } %>
      </div>
    </div>

    <!-- Leaderboard (top of page) -->
    <div class="section">
      <div class="section-title"><%= isRu ? 'Таблица результатов' : 'Leaderboard' %></div>
      <table class="lb-table">
        <thead>
          <tr>
            <th class="lb-rank">#</th>
            <th><%= isRu ? 'Автор' : 'Author' %></th>
            <th class="lb-num"><%= isRu ? 'Решений' : 'Solutions' %></th>
            <th class="lb-num"><%= isRu ? 'Баллы' : 'Points' %></th>
          </tr>
        </thead>
        <tbody id="leaderboardBody">
          <% if (!contest.leaderboard.length) { %>
            <tr><td colspan="4" class="lb-empty"><%= isRu ? 'Пока никто не опубликовал новое решение. Стань первым.' : 'No new solutions yet. Be the first.' %></td></tr>
          <% } else { contest.leaderboard.forEach(function(row) { %>
            <tr>
              <td class="lb-rank"><%= row.rank == null ? '—' : row.rank %></td>
              <td>
                <div class="lb-user">
                  <% if (row.avatar) { %><img class="lb-avatar" src="<%= row.avatar %>" alt="" onerror="this.style.visibility='hidden'" /><% } else { %><span class="lb-avatar"></span><% } %>
                  <div style="min-width:0;">
                    <a href="/user/<%= row.username %>"><%= row.fullName || row.username %></a>
                    <% if (row.isOrganizer) { %>
                      <span class="tier-pill badge-org"><%= isRu ? 'организатор' : 'organizer' %></span>
                    <% } else if (row.tier) { %>
                      <span class="tier-pill <%= row.tier === 'grand' ? 'badge-grand' : (row.tier === 'silver' ? 'badge-silver' : 'badge-bronze') %>"><%= tierLabels[row.tier] %></span>
                    <% } %>
                    <% if (row.country) { %><div class="lb-country"><%= row.country %></div><% } %>
                  </div>
                </div>
              </td>
              <td class="lb-num"><%= row.solutions %></td>
              <td class="lb-num lb-points"><%= row.points %></td>
            </tr>
          <% }); } %>
        </tbody>
      </table>
    </div>

    <div class="contest-layout">
      <!-- Main column -->
      <div>
        <!-- Prizes -->
        <div class="section">
          <div class="section-title">
            <%= isRu ? 'Призы' : 'Prizes' %>
            <span class="exclusive-tag"><%= isRu ? 'Эксклюзив' : 'Exclusive' %></span>
          </div>
          <div class="prizes-section-label"><%= isRu ? 'Индивидуальные призы' : 'Individual prizes' %></div>
          <div class="prizes">
            <div class="prize">
              <span class="prize-badge badge-grand"><%= isRu ? 'Гран-при' : 'Grand' %></span>
              <div class="prize-h"><%= isRu ? 'Полный набор' : 'Full set' %></div>
              <p class="prize-p"><%= isRu ? 'Кепка, худи и шопер. Автору с наибольшим числом баллов за месяц.' : 'Cap, hoodie and shopper. To the author with the most points this month.' %></p>
            </div>
            <div class="prize">
              <span class="prize-badge badge-silver"><%= isRu ? 'Серебро' : 'Silver' %></span>
              <div class="prize-h"><%= isRu ? 'Полный набор' : 'Full set' %></div>
              <p class="prize-p"><%= isRu ? 'Кепка, худи и шопер. За второе место по баллам.' : 'Cap, hoodie and shopper. For second place by points.' %></p>
            </div>
            <div class="prize">
              <span class="prize-badge badge-bronze"><%= isRu ? 'Бронза' : 'Bronze' %></span>
              <div class="prize-h"><%= isRu ? 'Кепка' : 'Cap' %></div>
              <p class="prize-p"><%= isRu ? 'Фирменная кепка каждому, кто набрал не меньше ' + contest.bronzeThreshold + ' баллов.' : 'A branded cap for everyone who reaches ' + contest.bronzeThreshold + ' points.' %></p>
            </div>
          </div>

          <div class="prizes-section-label"><%= isRu ? 'Коллективные призы' : 'Community prizes' %></div>
          <div class="prizes-community">
            <div class="prize<%= contest.stretchUnlocked ? '' : ' prize-locked' %>">
              <span class="prize-badge badge-raffle"><%= isRu ? 'Жеребьёвка ×2' : 'Raffle ×2' %></span>
              <div class="prize-h"><%= isRu ? 'Два полных набора' : 'Two full sets' %></div>
              <p class="prize-p">
                <%= isRu
                  ? `Кепка, худи и шопер — два комплекта. Разыгрываются случайно среди всех участников, набравших не менее ${contest.stretchRaffleThreshold} баллов. Место в таблице не важно: шанс есть у каждого активного автора.`
                  : `Cap, hoodie and shopper — two sets. Drawn randomly among all participants with at least ${contest.stretchRaffleThreshold} points. Leaderboard position does not matter: any active author can win.` %>
              </p>
              <% if (!contest.stretchUnlocked) { %>
                <div class="prize-lock-note">
                  <%= isRu
                    ? `Разблокируется при достижении ${contest.goalSolutions} решений сообществом`
                    : `Unlocks when the community reaches ${contest.goalSolutions} solutions` %>
                </div>
              <% } %>
            </div>
            <div class="prize">
              <span class="prize-badge badge-spotlight"><%= isRu ? 'Редакторский выбор' : 'Editor\'s Pick' %></span>
              <div class="prize-h"><%= isRu ? 'Лучшее решение месяца' : 'Best solution of the month' %></div>
              <p class="prize-p">
                <%= isRu
                  ? 'Кепка, худи и шопер. Выбирается редакционно: одно решение, которое выделяется чёткостью изложения, глубиной вывода или сложностью задачи. Определяется вне таблицы результатов — количество решений на победу не влияет.'
                  : 'Cap, hoodie and shopper. Selected by editorial decision: one solution that stands out for clarity, depth of derivation, or difficulty of the problem. Awarded independently of the leaderboard — volume does not determine the winner.' %>
              </p>
            </div>
          </div>

          <!-- Merch photos -->
          <div style="margin-top:1rem;">
            <p class="merch-note">
              <%= isRu
                ? 'Мерч выпущен ограниченным тиражом производителем Creative Depo. Этот тираж эксклюзивный, повторного выпуска не будет.'
                : 'Merch produced in a limited run by Creative Depo. This run is exclusive and will not be reprinted.' %>
            </p>
            <div class="merch-grid">
              <img src="/img/blog/emixter_merch-front.jpeg" alt="<%= isRu ? 'Худи, кепка и шопер платформы' : 'Platform hoodie, cap and shopper' %>" onerror="this.style.display='none'" />
              <img src="/img/blog/contest_merch_side.jpeg" alt="<%= isRu ? 'Шопер платформы' : 'Platform shopper' %>" onerror="this.style.display='none'" />
              <img src="/img/blog/emixter_merch-box.jpeg" alt="<%= isRu ? 'Партия мерча в упаковке' : 'Merch batch in packaging' %>" onerror="this.style.display='none'" />
            </div>
          </div>
        </div>

        <!-- Rules -->
        <div class="section">
          <div class="section-title"><%= isRu ? 'Правила начисления баллов' : 'Scoring rules' %></div>
          <p style="font-size:13px;color:#6c757d;margin:0 0 0.9rem;line-height:1.6;">
            <%= isRu
              ? 'Полная версия от 8 июня. Балл начисляется за решённую задачу, а не за правку и не за языковую версию. Одна задача Савченко — одна единица, сколько бы раз вы её ни редактировали и на скольких бы языках ни оформляли.'
              : 'Full version, June 8. A point is awarded for a solved problem — not for an edit, not for a language version. One Savchenko problem is one unit, regardless of how many times you edit it or in how many languages.' %>
          </p>

          <ol style="font-size:14px;line-height:1.75;color:#2d2d2d;padding-left:1.4rem;margin:0 0 0.25rem;">
            <li style="margin-bottom:0.6rem;">
              <strong><%= isRu ? 'Единица зачёта' : 'Credit unit' %></strong><br>
              <%= isRu
                ? 'Зачётная единица — пара (номер задачи, автор). Первая публикация полного решения задачи приносит баллы один раз. Все последующие правки той же задачи тем же автором баллов не добавляют.'
                : 'The credit unit is the (problem, author) pair. The first publication of a complete solution earns points once. All subsequent edits to the same problem by the same author add no further points.' %>
            </li>
            <li style="margin-bottom:0.6rem;">
              <strong><%= isRu ? 'Базовый балл' : 'Base point' %></strong><br>
              <%= isRu
                ? 'Первое полное решение задачи, содержащее вывод и рассуждение в LaTeX, даёт 1.0 балл.'
                : 'The first complete solution to a problem — derivation and reasoning in LaTeX — earns 1.0 point.' %>
            </li>
            <li style="margin-bottom:0.6rem;">
              <strong><%= isRu ? 'Множители' : 'Multipliers' %></strong><br>
              <%= isRu
                ? 'Стакаются мультипликативно (см. таблицу ниже). Пример: английское первое решение ранее нерешённой задачи из главы 12 даёт 1.0 × 1.5 × 1.5 × 1.5 = 3.375 балла. Начисляется один раз, при первой публикации этой задачи этим автором.'
                : 'Stack multiplicatively (see table below). Example: an English-language first solution for a previously unsolved problem in chapter 12 gives 1.0 × 1.5 × 1.5 × 1.5 = 3.375 points. Awarded once, at first publication by this author.' %>
            </li>
            <li style="margin-bottom:0.6rem;">
              <strong><%= isRu ? 'Перевод своего решения' : 'Translating your own solution' %></strong><br>
              <%= isRu
                ? 'Если вы уже опубликовали решение задачи на одном языке и получили за него баллы, перевод на другой язык даёт +0.5 балла. Множители не применяются. Один перевод своего решения — 0.5 балла, один раз за задачу.'
                : 'If you already published a solution for a problem and earned points, translating it to another language earns +0.5 points. No multipliers apply. One self-translation per problem — 0.5 points, once.' %>
            </li>
            <li style="margin-bottom:0.6rem;">
              <strong><%= isRu ? 'Почему перевод 0.5, а не 1.5' : 'Why translation is 0.5, not 1.5' %></strong><br>
              <%= isRu
                ? 'Решая задачу на английском с нуля, вы создаёте новый контент и получаете ×1.5. Переводя своё же готовое решение, вы добавляете языковую версию, но не новый вывод. Это реальная работа — поэтому 0.5, но не равная оригинальному выводу — поэтому не 1.5.'
                : 'Solving a problem in English from scratch creates new content — that earns ×1.5. Translating your own existing solution adds a language version, not a new derivation. It is real work — hence 0.5 — but not equal to the original derivation — hence not 1.5.' %>
            </li>
            <li style="margin-bottom:0.6rem;">
              <strong><%= isRu ? 'Перевод чужого решения' : "Translating someone else's solution" %></strong><br>
              <%= isRu
                ? 'Не засчитывается. Ноль баллов.'
                : 'Not credited. Zero points.' %>
            </li>
            <li style="margin-bottom:0.6rem;">
              <strong><%= isRu ? 'Задача с уже существующим чужим решением' : 'Problem already solved by another author' %></strong><br>
              <%= isRu
                ? 'Ваше альтернативное решение засчитывается с базовым баллом 1.0, без множителя за нерешённую задачу — задача уже была покрыта. Альтернативные решения приветствуются.'
                : 'Your alternative solution earns the base 1.0 points, without the unsolved-problem multiplier — the problem was already covered. Alternative solutions are welcome.' %>
            </li>
            <li style="margin-bottom:0.6rem;">
              <strong><%= isRu ? 'Решения, опубликованные до конкурса' : 'Solutions published before the contest' %></strong><br>
              <%= isRu
                ? 'Задачи, решённые до 1 июня, не входят в зачёт. Но если вы переводите своё дореконкурсное решение на другой язык в ходе конкурса — перевод даёт 0.5 балла по правилу 4.'
                : 'Problems solved before June 1 are not counted. However, if you translate your own pre-contest solution to another language during the contest, that earns 0.5 points under rule 4.' %>
            </li>
            <li style="margin-bottom:0.6rem;">
              <strong><%= isRu ? 'Неполные решения' : 'Incomplete solutions' %></strong><br>
              <%= isRu
                ? 'Решение без вывода, без рассуждения или состоящее только из ответа не засчитывается. Опубликуйте заготовку, допишите вывод — и при следующей проверке решение зачтётся.'
                : 'A solution without derivation or reasoning, or consisting only of a final answer, is not credited. Publish a draft and complete the derivation — it will be credited on the next review.' %>
            </li>
            <li style="margin-bottom:0.6rem;">
              <strong><%= isRu ? 'Проверка' : 'Review' %></strong><br>
              <%= isRu
                ? 'Решения выборочно проверяются на соответствие правилам — особенно переводы (правило 4) и наличие реального вывода (правило 9). Если решение не проходит проверку, баллы снимаются.'
                : 'Solutions are spot-checked for compliance — especially translations (rule 4) and derivation quality (rule 9). Non-compliant solutions are removed from the score.' %>
            </li>
          </ol>

          <div class="section-title" style="font-size:15px;margin-top:1.5rem;"><%= isRu ? 'Множители (таблица)' : 'Multiplier table' %></div>
          <p style="font-size:13px;color:#6c757d;margin:0 0 0.25rem;">
            <%= isRu
              ? 'Применяются к базовому баллу, стакаются мультипликативно. Учитываются только при первой публикации задачи этим автором.'
              : 'Applied to the base point, stack multiplicatively. Only apply at the first publication of a problem by this author.' %>
          </p>
          <table class="mult-table">
            <thead>
              <tr><th><%= isRu ? 'Категория' : 'Category' %></th><th><%= isRu ? 'Множитель' : 'Multiplier' %></th></tr>
            </thead>
            <tbody>
              <tr><td><%= isRu ? 'Базовое решение' : 'Base solution' %></td><td>1.0</td></tr>
              <tr><td><%= isRu ? 'Ранее нерешённая задача' : 'Previously unsolved problem' %></td><td>×1.5</td></tr>
              <tr><td><%= isRu ? 'Главы 9, 10, 12, 14 (покрытие < 50%)' : 'Chapters 9, 10, 12, 14 (under 50% coverage)' %></td><td>×1.5</td></tr>
              <tr><td><%= isRu ? 'Решение на английском языке' : 'Solution in English' %></td><td>×1.5</td></tr>
              <tr style="border-top:2px solid #dee2e6;"><td><%= isRu ? 'Перевод своего уже засчитанного решения' : 'Self-translation of an already-credited solution' %></td><td>+0.5</td></tr>
            </tbody>
          </table>

          <div style="margin-top:1.25rem;padding:0.85rem 1rem;background:#f8f9fa;border-radius:6px;border:1px solid #dee2e6;font-size:13px;color:#6c757d;line-height:1.6;">
            <strong style="color:#2d2d2d;"><%= isRu ? 'О предстоящем перерасчёте' : 'Upcoming recalculation' %></strong><br>
            <%= isRu
              ? 'Текущая система начисляет баллы за каждую правку и за каждую языковую версию отдельно. Это ошибка подсчёта. После исправления таблица результатов будет пересчитана по правилам выше. Если у кого-то баллы изменятся — это приведение к честному значению, а не наказание.'
              : 'The current system awards points for every edit and every language version separately. This is a scoring bug. After the fix, the leaderboard will be recalculated per the rules above. If anyone\'s score changes, it is a correction to the fair value, not a penalty.' %>
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <div>
        <div class="cta-card">
          <div class="side-title"><%= isRu ? 'Как участвовать' : 'How to take part' %></div>
          <p style="font-size:13px;color:#6c757d;line-height:1.6;margin-bottom:0.85rem;">
            <%= isRu
              ? 'Дополнительных кнопок нет. Опубликуй новое решение в LaTeX, и ты в таблице. Не знаешь, с чего начать? Открой список нерешённых задач.'
              : 'No extra buttons. Publish a new LaTeX solution and you are on the board. Not sure where to start? Open the list of unsolved problems.' %>
          </p>
          <div style="display:flex;flex-direction:column;gap:0.5rem;">
            <a class="btn-primary-navy" href="/<%= lang %>/upload"><%= isRu ? 'Опубликовать решение' : 'Publish a solution' %></a>
            <a class="btn-outline-navy" href="/<%= lang %>/unsolved"><%= isRu ? 'Нерешённые задачи' : 'Unsolved problems' %></a>
          </div>
        </div>

        <div class="side-card">
          <div class="side-title"><%= isRu ? 'Последние решения' : 'Latest solutions' %></div>
          <ul class="feed-list" id="feedList">
            <% if (!contest.feed.length) { %>
              <li class="feed-item" style="color:#6c757d;"><%= isRu ? 'Здесь появятся новые решения.' : 'New solutions will appear here.' %></li>
            <% } else { contest.feed.forEach(function(f) { %>
              <li class="feed-item">
                <a href="/<%= f.language %>/<%= f.problem %>"><%= f.problem %></a>
                <span class="feed-lang"><%= f.language %></span>
                <div class="feed-meta"><%= f.fullName || f.username %></div>
              </li>
            <% }); } %>
          </ul>
        </div>

        <div class="side-card">
          <div class="side-title"><%= isRu ? 'Откуда идея' : 'Where the idea came from' %></div>
          <p style="font-size:13px;color:#6c757d;line-height:1.6;margin:0;">
            <%= isRu
              ? 'Конкурс предложил emixter в общем чате платформы. Мы доработали формат так, чтобы шанс на приз был у каждого активного автора.'
              : 'The contest was proposed by emixter in the platform chat. We shaped the format so every active author has a real shot at a prize.' %>
          </p>
        </div>
      </div>
    </div>
  </div>

  <script>
  (function() {
    const SLUG = <%- JSON.stringify(contest.slug) %>;
    const GOAL = <%= contest.goalSolutions %>;
    const FIRST_MILESTONE = <%= contest.firstMilestone %>;
    const STRETCH_RAFFLE_THRESHOLD = <%= contest.stretchRaffleThreshold %>;
    const isRu = <%= isRu ? 'true' : 'false' %>;
    const tierClass = { grand: 'badge-grand', silver: 'badge-silver', bronze: 'badge-bronze' };
    const tierLabel = { grand: isRu ? 'Гран-при' : 'Grand', silver: isRu ? 'Серебро' : 'Silver', bronze: isRu ? 'Бронза' : 'Bronze' };

    function esc(s) {
      return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function setProgress(total) {
      const pct = GOAL > 0 ? Math.min(100, Math.round((total / GOAL) * 100)) : 0;
      const fill = document.getElementById('progressFill');
      if (fill) fill.style.width = pct + '%';
      const rem = document.getElementById('remainingGoal');
      if (rem) {
        const left = Math.max(0, GOAL - total);
        rem.textContent = left > 0
          ? (isRu ? ('До цели осталось ' + left) : (left + ' to go'))
          : (isRu ? 'Цель достигнута' : 'Goal reached');
      }
      const tick = document.getElementById('milestoneTick');
      if (tick && GOAL > 0) {
        tick.style.left = Math.min(100, Math.round((FIRST_MILESTONE / GOAL) * 100)) + '%';
      }
    }

    function renderLeaderboard(rows) {
      const body = document.getElementById('leaderboardBody');
      if (!body) return;
      if (!rows.length) {
        body.innerHTML = '<tr><td colspan="4" class="lb-empty">' +
          (isRu ? 'Пока никто не опубликовал новое решение. Стань первым.' : 'No new solutions yet. Be the first.') + '</td></tr>';
        return;
      }
      body.innerHTML = rows.map(function(r) {
        const avatar = r.avatar
          ? '<img class="lb-avatar" src="' + esc(r.avatar) + '" alt="" onerror="this.style.visibility=\'hidden\'" />'
          : '<span class="lb-avatar"></span>';
        const tier = r.isOrganizer
          ? ' <span class="tier-pill badge-org">' + (isRu ? 'организатор' : 'organizer') + '</span>'
          : (r.tier
            ? ' <span class="tier-pill ' + (tierClass[r.tier] || '') + '">' + esc(tierLabel[r.tier] || '') + '</span>'
            : '');
        const country = r.country ? '<div class="lb-country">' + esc(r.country) + '</div>' : '';
        return '<tr>' +
          '<td class="lb-rank">' + (r.rank == null ? '—' : r.rank) + '</td>' +
          '<td><div class="lb-user">' + avatar +
            '<div style="min-width:0;"><a href="/user/' + esc(r.username) + '">' + esc(r.fullName || r.username) + '</a>' + tier + country + '</div>' +
          '</div></td>' +
          '<td class="lb-num">' + r.solutions + '</td>' +
          '<td class="lb-num lb-points">' + r.points + '</td>' +
        '</tr>';
      }).join('');
    }

    function renderFeed(feed) {
      const list = document.getElementById('feedList');
      if (!list) return;
      if (!feed.length) {
        list.innerHTML = '<li class="feed-item" style="color:#6c757d;">' + (isRu ? 'Здесь появятся новые решения.' : 'New solutions will appear here.') + '</li>';
        return;
      }
      list.innerHTML = feed.map(function(f) {
        return '<li class="feed-item">' +
          '<a href="/' + esc(f.language) + '/' + esc(f.problem) + '">' + esc(f.problem) + '</a>' +
          '<span class="feed-lang">' + esc(f.language) + '</span>' +
          '<div class="feed-meta">' + esc(f.fullName || f.username) + '</div>' +
        '</li>';
      }).join('');
    }

    function updateCommunityMsg(total, stretchUnlocked) {
      const el = document.getElementById('communityMsg');
      if (!el) return;
      const toGo = Math.max(0, GOAL - total);
      if (!stretchUnlocked) {
        el.textContent = isRu
          ? ('До цели осталось ' + toGo + ' решений. Когда сообщество достигнет ' + GOAL + ', призовой фонд расширится: два дополнительных комплекта мерча уйдут в жеребьёвку среди всех, кто набрал не менее ' + STRETCH_RAFFLE_THRESHOLD + ' баллов. Место в таблице не важно — шанс у каждого.')
          : (toGo + ' solutions to go. When the community hits ' + GOAL + ', the prize pool expands: two extra merch sets enter a raffle open to everyone with at least ' + STRETCH_RAFFLE_THRESHOLD + ' points. The top does not take them — they are drawn randomly.');
      } else {
        el.textContent = isRu
          ? ('Сообщество достигло ' + GOAL + ' решений. Два дополнительных комплекта мерча разыгрываются среди всех с не менее ' + STRETCH_RAFFLE_THRESHOLD + ' баллами.')
          : ('The community reached ' + GOAL + ' solutions. Two extra merch sets will be raffled among all participants with at least ' + STRETCH_RAFFLE_THRESHOLD + ' points.');
      }
    }

    function refresh() {
      fetch('/challenge/' + SLUG + '/data', { headers: { 'Accept': 'application/json' } })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (!d || d.error) return;
          const n = document.getElementById('counterNumber');
          if (n) n.textContent = d.totalSolutions;
          const p = document.getElementById('participantsCount');
          if (p) p.textContent = d.participants;
          setProgress(d.totalSolutions);
          updateCommunityMsg(d.totalSolutions, d.stretchUnlocked);
          renderLeaderboard(d.leaderboard || []);
          renderFeed(d.feed || []);
        })
        .catch(function() {});
    }

    // Countdown
    (function() {
      const el = document.getElementById('countdownLine');
      if (!el) return;
      const end = new Date(el.dataset.end + 'T23:59:59+03:00'); // 23:59 Moscow time (MSK, UTC+3)
      function tick() {
        const diff = end - new Date();
        if (diff <= 0) { el.innerHTML = isRu ? ' · <strong>Конкурс завершён</strong>' : ' · <strong>Contest ended</strong>'; return; }
        const hours = Math.floor(diff / 3600000);
        const mins = Math.floor((diff % 3600000) / 60000);
        const secs = Math.floor((diff % 60000) / 1000);
        el.innerHTML = isRu
          ? (' · осталось <strong>' + hours + ' ч ' + mins + ' мин ' + secs + ' с</strong>')
          : (' · <strong>' + hours + 'h ' + mins + 'm ' + secs + 's</strong> left');
      }
      tick();
      setInterval(tick, 1000);
    })();

    setProgress(<%= contest.totalSolutions %>);
    setInterval(refresh, 30000);
  })();
  </script>

  <%- include('../default/main_site_search_script') %>
  <script src="/js/analytics.js"></script>
</body>
</html>

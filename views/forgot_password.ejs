<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <%- include(`default/head_${lang}.ejs`) %>
    <%- include('default/main_site_header_head') %>
    <link rel="stylesheet" href="/css/css-latex/login.css" />
    <title><%= lang === 'ru' ? 'Сброс пароля' : 'Forgot Password' %></title>
    <script src="/js/analytics.js"></script>
</head>
<body class="auth-page">
    <%- include('default/header.ejs') %>
    <div class="container1">
        <h2><%= lang === 'ru' ? 'Сброс пароля' : 'Forgot Password' %></h2>
        <% if (error) { %>
            <p class="error"><%= error %></p>
        <% } %>
        <% if (success) { %>
            <p class="success"><%= success %></p>
        <% } %>
        <% if (!success) { %>
        <p style="font-size: 14px; color: #6c757d; margin-bottom: 16px;">
            <%= lang === 'ru'
                ? 'Введите адрес электронной почты, связанный с вашим аккаунтом.'
                : 'Enter the email address associated with your account.' %>
        </p>
        <form action="/forgot-password" method="POST">
            <input type="hidden" name="lang" value="<%= lang %>">
            <div class="form-group">
                <label for="email"><%= lang === 'ru' ? 'Электронная почта' : 'Email' %></label>
                <input type="email" id="email" name="email" required />
            </div>
            <button type="submit" class="submit-button"><%= lang === 'ru' ? 'Отправить ссылку для сброса' : 'Send Reset Link' %></button>
        </form>
        <% } %>
        <p style="margin-top: 16px;">
            <a href="/<%= lang %>/login"><%= lang === 'ru' ? 'Вернуться к входу' : 'Back to login' %></a>
        </p>
    </div>
    <%- include(`default/footer_${lang}.ejs`) %>
    <%- include('default/main_site_footer_scripts') %>
</body>
</html>

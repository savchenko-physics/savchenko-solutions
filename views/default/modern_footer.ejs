<%
  const fLang = typeof lang !== 'undefined' ? lang : 'en';
  const fUser = typeof username !== 'undefined' ? username : null;
%>
<style>
  /* Self-contained so the footer looks identical on every page regardless of the
     host page's global CSS. Some pages load a LaTeX stylesheet that forces serif
     fonts on h1–h4 and centers list items; these scoped rules override that. */
  .ss-site-footer, .ss-site-footer * {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif !important;
    text-align: left !important;
    box-sizing: border-box;
  }
</style>
<footer class="ss-site-footer" style="background: #1a1a2e; color: #fff; padding: 2.5rem 0 1.5rem; margin-top: 3rem; font-size: 0.9rem;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; margin-bottom: 2rem;">
      <!-- Problems -->
      <div>
        <h4 style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: rgba(255,255,255,0.5); margin-bottom: 0.75rem;">
          <%= fLang === 'ru' ? 'Задачи' : 'Problems' %>
        </h4>
        <ul style="list-style: none; padding: 0; margin: 0; line-height: 2;">
          <li><a href="/<%= fLang %>/" style="color: rgba(255,255,255,0.7); text-decoration: none;"><%= fLang === 'ru' ? 'Савченко' : 'Savchenko Solutions' %></a></li>
          <!-- Problempedia link removed for now -->
          <li><a href="/<%= fLang %>/unsolved" style="color: rgba(255,255,255,0.7); text-decoration: none;"><%= fLang === 'ru' ? 'Нерешённые задачи' : 'Unsolved Problems' %></a></li>
          <li><a href="/compete" style="color: rgba(255,255,255,0.7); text-decoration: none;"><%= fLang === 'ru' ? 'Задачи недели' : 'Weekly Challenges' %></a></li>
        </ul>
      </div>

      <!-- Learn -->
      <div>
        <h4 style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: rgba(255,255,255,0.5); margin-bottom: 0.75rem;">
          <%= fLang === 'ru' ? 'Обучение' : 'Learn' %>
        </h4>
        <ul style="list-style: none; padding: 0; margin: 0; line-height: 2;">
          <li><a href="/<%= fLang %>/study-guide" style="color: rgba(255,255,255,0.7); text-decoration: none;"><%= fLang === 'ru' ? 'Руководство' : 'Study Guide' %></a></li>
          <li><a href="/paths" style="color: rgba(255,255,255,0.7); text-decoration: none;"><%= fLang === 'ru' ? 'Учебные пути' : 'Study Paths' %></a></li>
          <li><a href="/tools" style="color: rgba(255,255,255,0.7); text-decoration: none;"><%= fLang === 'ru' ? 'Инструменты' : 'Tools' %></a></li>
          <li><a href="/blog" style="color: rgba(255,255,255,0.7); text-decoration: none;"><%= fLang === 'ru' ? 'Блог' : 'Blog' %></a></li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h4 style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: rgba(255,255,255,0.5); margin-bottom: 0.75rem;">
          <%= fLang === 'ru' ? 'Сообщество' : 'Community' %>
        </h4>
        <ul style="list-style: none; padding: 0; margin: 0; line-height: 2;">
          <li><a href="/discuss" style="color: rgba(255,255,255,0.7); text-decoration: none;"><%= fLang === 'ru' ? 'Форум' : 'Discussion Forum' %></a></li>
          <li><a href="/<%= fLang %>/contributors" style="color: rgba(255,255,255,0.7); text-decoration: none;"><%= fLang === 'ru' ? 'Авторы' : 'Contributors' %></a></li>
          <li>
            <a href="https://github.com/savchenko-physics" style="color: rgba(255,255,255,0.7); text-decoration: none;">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" style="vertical-align: -2px; margin-right: 4px;">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
              </svg>GitHub
            </a>
          </li>
          <li><a href="mailto:aliaksandr@melnichenka.com" style="color: rgba(255,255,255,0.7); text-decoration: none;"><%= fLang === 'ru' ? 'Связаться' : 'Contact' %></a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1.25rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem;">
      <span style="color: rgba(255,255,255,0.5); font-size: 0.82rem;">
        &copy; 2023&ndash;2026 Savchenko Solutions. Content licensed under <strong>CC BY-SA 4.0</strong>.
      </span>
    </div>
  </div>
</footer>

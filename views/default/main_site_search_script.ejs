<script>
(function () {
  const searchInput = document.getElementById("searchInput");
  const searchResults = document.getElementById("searchResults");
  const searchResultsList = document.querySelector("#searchResults ul");
  const clearButton = document.getElementById("clearSearch");
  if (!searchInput || !searchResults || !searchResultsList) return;

  let lastSearchResults = "";
  let activeIndex = -1;
  let currentResults = [];

  function escSnippet(str) {
    if (!str) return '';
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function highlightSnippet(text, query) {
    if (!text || !query) return escSnippet(text);
    const escaped = escSnippet(text);
    const terms = query.trim().split(/\s+/).filter(t => t.length > 1);
    if (!terms.length) return escaped;
    const pattern = terms.map(t => t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')).join('|');
    return escaped.replace(new RegExp('(' + pattern + ')', 'gi'), '<mark style="background:#fff3cd;padding:0 1px;border-radius:2px;">$1</mark>');
  }

  document.addEventListener("click", function (event) {
    if (!searchInput.contains(event.target) && !searchResults.contains(event.target)) {
      searchResults.style.display = "none";
      activeIndex = -1;
    }
  });

  searchInput.addEventListener("focus", () => {
    if (searchInput.value.trim().length > 0 && lastSearchResults) {
      searchResultsList.innerHTML = lastSearchResults;
      searchResults.style.display = "block";
    }
  });

  function updateActiveItem() {
    const items = searchResultsList.querySelectorAll("li.cdx-menu-item");
    items.forEach((item, i) => {
      if (i === activeIndex) {
        item.style.backgroundColor = "#f0f0f0";
        item.setAttribute("aria-selected", "true");
      } else {
        item.style.backgroundColor = "";
        item.removeAttribute("aria-selected");
      }
    });
  }

  searchInput.addEventListener("keydown", function (e) {
    const items = searchResultsList.querySelectorAll("li.cdx-menu-item");
    if (!items.length) return;

    if (e.key === "ArrowDown") {
      e.preventDefault();
      activeIndex = Math.min(activeIndex + 1, items.length - 1);
      updateActiveItem();
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      activeIndex = Math.max(activeIndex - 1, -1);
      updateActiveItem();
    } else if (e.key === "Enter") {
      e.preventDefault();
      if (activeIndex >= 0 && activeIndex < currentResults.length) {
        window.location.href = currentResults[activeIndex].relativePath;
      } else {
        const query = searchInput.value.trim();
        if (query) {
          const currentLang = "<%= typeof lang !== 'undefined' ? lang : 'en' %>";
          window.location.href = `/global-search?search=${encodeURIComponent(query)}&lang=${encodeURIComponent(currentLang)}`;
        }
      }
    } else if (e.key === "Escape") {
      searchResults.style.display = "none";
      activeIndex = -1;
    }
  });

  searchInput.addEventListener("input", async function () {
    const query = searchInput.value.trim();
    const currentLang = "<%= typeof lang !== 'undefined' ? lang : 'en' %>";
    activeIndex = -1;

    if (clearButton) clearButton.style.display = this.value ? "block" : "none";

    if (query.length === 0) {
      searchResults.style.display = "none";
      searchResultsList.innerHTML = "";
      lastSearchResults = "";
      currentResults = [];
      return;
    }

    try {
      const response = await fetch(
        `/search?q=${encodeURIComponent(query)}&lang=${encodeURIComponent(currentLang)}`
      );
      const data = await response.json();

      if (data.results.length > 0) {
        const limitedResults = data.results.slice(0, 10);
        currentResults = limitedResults;
        const resultsHTML = limitedResults
          .map(
            (result, index) => `
                    <li id="cdx-menu-item-${index}" role="option" class="cdx-menu-item cdx-menu-item--enabled" style="padding: 0; transition: background-color 0.1s;">
                        <a href="${result.relativePath}" class="cdx-menu-item__content text-dark text-decoration-none d-block" style="padding: 8px 12px;">
                            <div class="d-flex align-items-start">
                                <svg class="me-2 flex-shrink-0" viewBox="0 0 24 24" width="16" height="16" style="margin-top: 3px;">
                                    <path fill="#9e9e9e" d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                                </svg>
                                <div style="min-width: 0; flex: 1;">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span>
                                            <strong>${result.name}</strong>${result.section ? ' &mdash; ' + result.section : ''}
                                        </span>
                                        ${result.confidence === "high" ? '<small style="color: #9e9e9e; font-size: 0.7em;">&#9733;</small>' : ""}
                                    </div>
                                    ${result.snippet ? '<div style="color: #6c757d; font-size: 12px; line-height: 1.4; margin-top: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">' + highlightSnippet(result.snippet, query) + '</div>' : ''}
                                    <div style="color: #999; font-size: 11px; margin-top: 1px;">
                                        ${result.chapter ? result.chapterNum + '. ' + result.chapter : ''}
                                        <span style="background: #e9ecef; border-radius: 3px; padding: 0 4px; font-size: 10px; margin-left: 4px;">${result.lang.toUpperCase()}</span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </li>
                `
          )
          .join("");

        const fullResultsHTML = `
            <li class="cdx-menu-item" style="padding: 0; border-top: 1px solid #dee2e6;">
                <a href="/global-search?search=${encodeURIComponent(query)}&lang=${encodeURIComponent(currentLang)}" class="text-decoration-none d-block" style="padding: 8px 12px; color: #6c757d; font-size: 13px;">
                    Press Enter for full results
                </a>
            </li>
        `;

        searchResultsList.innerHTML = resultsHTML + fullResultsHTML;
        lastSearchResults = resultsHTML + fullResultsHTML;
        searchResults.style.display = "block";
      } else {
        currentResults = [];
        const noResultsHTML = `
                    <li class="cdx-menu-item cdx-menu-item--enabled p-4">
                        <div class="text-center">
                            <svg class="mb-3" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6c757d" stroke-width="1.5">
                                <circle cx="11" cy="11" r="8"/>
                                <path d="M21 21l-4.35-4.35"/>
                                <path d="M8 11h6"/>
                            </svg>
                            <h6 class="mb-3 text-secondary">
                                <%= typeof lang !== 'undefined' && lang === 'ru' ? 'Ничего не найдено.' : 'No results found.' %>
                            </h6>
                            <div class="d-flex gap-2 justify-content-center" style="white-space: nowrap;">
                                <a href="/<%= typeof lang !== 'undefined' ? lang : 'en' %>/upload"
                                   class="search-dropdown-upload-cta edit-button btn btn-outline-light rounded-pill px-3"
                                   style="background-color: #007bff; font-size: 0.85rem;"
                                   data-chapter="1">
                                    <svg class="me-2" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                                        <polyline points="17 8 12 3 7 8"/>
                                        <line x1="12" y1="3" x2="12" y2="15"/>
                                    </svg>
                                    <%= __('menu.upload') %>
                                </a>
                                <a href="/global-search?search=${encodeURIComponent(query)}"
                                   class="btn btn-outline-light rounded-pill px-3"
                                   style="border-color: #6c757d; color: #6c757d; font-size: 0.85rem;">
                                    <svg class="me-2" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="11" cy="11" r="8"/>
                                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                                        <line x1="11" y1="8" x2="11" y2="14"/>
                                        <line x1="8" y1="11" x2="14" y2="11"/>
                                    </svg>
                                    <%= __('menu.advancedSearch') %>
                                </a>
                            </div>
                        </div>
                    </li>
                `;
        searchResultsList.innerHTML = noResultsHTML;
        lastSearchResults = noResultsHTML;
        searchResults.style.display = "block";
      }
    } catch (error) {
      console.error("Error fetching search results:", error);
    }
  });

  if (clearButton) {
    clearButton.addEventListener("click", function () {
      searchInput.value = "";
      searchResults.style.display = "none";
      searchResultsList.innerHTML = "";
      currentResults = [];
      activeIndex = -1;
      this.style.display = "none";
      searchInput.focus();
    });
  }
})();
</script>

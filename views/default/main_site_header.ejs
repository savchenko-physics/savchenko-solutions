                <!-- Mobile: Learn -->
                <div class="mobile-nav-group mb-2">
                  <button class="mobile-nav-group-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#mobileLearn">
                    <%= navLang === 'ru' ? 'Обучение' : 'Learn' %>
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M4 6l4 4 4-4"/></svg>
                  </button>
                  <div class="collapse" id="mobileLearn">
                    <a href="/<%= navLang %>/study-guide" class="mobile-nav-link"><%= navLang === 'ru' ? 'Руководство' : 'Study Guide' %></a>

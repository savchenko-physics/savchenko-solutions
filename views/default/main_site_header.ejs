<% 
  const navLang = typeof lang !== 'undefined' ? lang : 'en';
  /* Logged-in user only: username on /user/:name is the profile viewed, not the session — use sessionUsername there */
  const navUser = (typeof usernameCurrent !== 'undefined' && usernameCurrent)
    ? usernameCurrent
    : (typeof sessionUsername !== 'undefined'
        ? (sessionUsername || null)
        : ((typeof username !== 'undefined' && username) ? username : null));
  let navPic = null;
  if (navUser) {
    if (typeof profilePictureCurrent !== 'undefined' && profilePictureCurrent) {
      navPic = profilePictureCurrent;
    } else if (typeof profilePicture !== 'undefined' && profilePicture) {
      navPic = profilePicture;
    }
    if (!navPic) navPic = '/img/profile_images/Default_placeholder.svg';
  }
  const navShowViewsButton = typeof showViewsButton !== 'undefined' && showViewsButton;
  const langHrefEn = typeof langSwitchEnUrl !== 'undefined' ? langSwitchEnUrl : '/en';
  const langHrefRu = typeof langSwitchRuUrl !== 'undefined' ? langSwitchRuUrl : '/ru';
%>
  <!-- ============================
       HERO / NAVIGATION (shared with eng_page)
  ============================ -->
  <header class="hero-section">
    <nav class="navbar navbar-expand-lg navbar-light">
      <div class="container-fluid px-4 align-items-center">
        <!-- Logo + Title -->
        <a class="navbar-brand d-flex align-items-center" href="/<%= navLang %>/">
          <img 
            src="/img/logo.svg" 
            alt="<%= __('title') %> Logo" 
            class="logo-img me-2"
          />
          <div>
            <h1 class="site-title mb-0"><%= __('title') %></h1>
            <p class="site-motto mb-0"><%= __('motto') %></p>
          </div>
        </a>

        <!-- Centered search bar on the same line (desktop/tablet) -->
        <div class="flex-grow-1 d-none d-md-flex justify-content-center px-3">
          <div class="searchbar-wrapper position-relative w-100" style="max-width: 520px;">
            <svg class="search-icon position-absolute" viewBox="0 0 24 24" width="20" height="20" style="left: 15px; top: 50%; transform: translateY(-50%); z-index: 1;">
              <path fill="#6c757d" d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
            </svg>
            <input
              type="text"
              id="searchInput"
              class="form-control form-control-lg searchbar-input"
              placeholder="<%= __('menu.searchPlaceholder') %>"
              style="padding-left: 45px; padding-right: 40px;"
            />
            <button 
              type="button" 
              id="clearSearch" 
              class="btn position-absolute" 
              style="right: 10px; top: 50%; transform: translateY(-50%); display: none; background: none; border: none; padding: 5px;">
              <svg viewBox="0 0 24 24" width="16" height="16">
                <path fill="#6c757d" d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
              </svg>
            </button>
            <div
              id="searchResults"
              class="search-results position-absolute bg-white border rounded shadow-sm"
              style="display: none; z-index: 1000; width: 100%;"
            >
              <ul class="list-unstyled mb-0"></ul>
            </div>
          </div>
        </div>

        <!-- Toggle button for mobile -->
        <button
          class="navbar-toggler d-flex align-items-center gap-2 border-0 pe-0 d-lg-none ms-auto"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarSupportedContent"
          aria-controls="navbarSupportedContent"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <% if (navLang === 'en') { %>
            <a href="<%= langHrefRu %>" class="nav-link fw-bold language-nav-link">RU</a>
          <% } else { %>
            <a href="<%= langHrefEn %>" class="nav-link fw-bold language-nav-link">EN</a>
          <% } %>

          <% if (navUser) { %>
            <a href="/user/<%= navUser %>" class="nav-link fw-bold">
              <img
                src="<%= navPic %>"
                alt="Profile Picture"
                class="rounded-circle"
                width="36"
                height="36"
              />
            </a>
          <% } else { %>
            <a
              href="/<%= navLang %>/login"
              class="edit-button header-upload-btn text-decoration-none d-inline-flex align-items-center btn btn-sm btn-outline-dark rounded-pill"
            >
              <%= __('menu.login') %>
            </a>
          <% } %>
        </button>

        <!-- Right side items: language + user -->
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav ms-auto align-items-center">
            <% if (navShowViewsButton) { %>
            <li class="nav-item px-2 d-none d-md-block">
              <button class="views-button" id="viewsButton" type="button">
                <i class="fas fa-eye"></i>
                <span id="viewCount">-</span>
              </button>
            </li>
            <% } %>
            <li class="nav-item px-2 d-none d-md-block">
              <a
                href="/<%= navLang %>/upload"
                class="edit-button header-upload-btn text-decoration-none d-inline-flex align-items-center btn btn-sm btn-outline-dark rounded-pill"
                data-chapter="1"
              >
                <svg class="upload-icon" viewBox="0 0 24 24" width="14" height="14">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"></path>
                </svg>
                <span class="upload-text ms-2"><%= __('upload.upload') %></span>
              </a>
            </li>
            <li class="nav-item px-2 language-switch">
              <% if (navLang === 'en') { %>
                <a href="<%= langHrefRu %>" class="nav-link fw-bold language-nav-link">RU</a>
              <% } else { %>
                <a href="<%= langHrefEn %>" class="nav-link fw-bold language-nav-link">EN</a>
              <% } %>
            </li>
            <li class="nav-item px-2">
              <% if (navUser) { %>
                <a href="/user/<%= navUser %>" class="d-flex align-items-center">
                  <img
                    src="<%= navPic %>"
                    alt="Profile Picture"
                    class="rounded-circle"
                    width="40"
                    height="40"
                  />
                </a>
              <% } else { %>
                <a
                  href="/<%= navLang %>/login"
                  class="edit-button header-upload-btn text-decoration-none d-inline-flex align-items-center btn btn-sm btn-outline-dark rounded-pill"
                >
                  <%= __('menu.login') %>
                </a>
              <% } %>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container hero-content"></div>
  </header>

<%
  const navLang = typeof lang !== 'undefined' ? lang : 'en';
  const navUser = (typeof usernameCurrent !== 'undefined' && usernameCurrent)
    ? usernameCurrent
    : (typeof sessionUsername !== 'undefined'
        ? (sessionUsername || null)
        : ((typeof username !== 'undefined' && username) ? username : null));
  let navPic = null;
  if (navUser) {
    if (typeof profilePictureCurrent !== 'undefined' && profilePictureCurrent) {
      navPic = profilePictureCurrent;
    } else if (typeof profilePicture !== 'undefined' && profilePicture) {
      navPic = profilePicture;
    }
    if (!navPic) navPic = '/img/profile_images/Default_placeholder.svg';
  }
  const navShowViewsButton = typeof showViewsButton !== 'undefined' && showViewsButton;
  const langHrefEn = typeof langSwitchEnUrl !== 'undefined' ? langSwitchEnUrl : '/en';
  const langHrefRu = typeof langSwitchRuUrl !== 'undefined' ? langSwitchRuUrl : '/ru';
%>
  <header class="hero-section">
    <nav class="navbar navbar-expand-lg navbar-light">
      <div class="container-fluid px-4 align-items-center">
        <!-- Logo + Title -->
        <a class="navbar-brand d-flex align-items-center" href="/<%= navLang %>/">
          <img src="/img/logo.svg" alt="<%= __('title') %> Logo" class="logo-img me-2" />
          <div class="d-none d-sm-block">
            <h1 class="site-title mb-0"><%= __('title') %></h1>
            <p class="site-motto mb-0"><%= __('motto') %></p>
          </div>
        </a>

        <!-- Centered search bar (desktop/tablet) -->
        <div class="flex-grow-1 d-none d-md-flex justify-content-center px-3">
          <div class="searchbar-wrapper position-relative w-100" style="max-width: 420px;">
            <svg class="search-icon position-absolute" viewBox="0 0 24 24" width="20" height="20" style="left: 15px; top: 50%; transform: translateY(-50%); z-index: 1;">
              <path fill="#6c757d" d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
            </svg>
            <input type="text" id="searchInput" class="form-control form-control-lg searchbar-input" placeholder="<%= __('menu.searchPlaceholder') %>" style="padding-left: 45px; padding-right: 40px;" />
            <button type="button" id="clearSearch" class="btn position-absolute" style="right: 10px; top: 50%; transform: translateY(-50%); display: none; background: none; border: none; padding: 5px;">
              <svg viewBox="0 0 24 24" width="16" height="16"><path fill="#6c757d" d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
            </button>
            <div id="searchResults" class="search-results position-absolute bg-white border rounded shadow-sm" style="display: none; z-index: 1000; width: 100%;">
              <ul class="list-unstyled mb-0"></ul>
            </div>
          </div>
        </div>

        <!-- Mobile: lang + avatar + hamburger -->
        <div class="d-flex align-items-center gap-2 d-lg-none ms-auto">
          <% if (navLang === 'en') { %>
            <a href="<%= langHrefRu %>" class="nav-link fw-bold language-nav-link" style="font-size:13px;">RU</a>
          <% } else { %>
            <a href="<%= langHrefEn %>" class="nav-link fw-bold language-nav-link" style="font-size:13px;">EN</a>
          <% } %>
          <% if (navUser) { %>
            <a href="/user/<%= navUser %>" class="nav-link p-0">
              <img src="<%= navPic %>" alt="Profile" class="rounded-circle" width="32" height="32" />
            </a>
          <% } %>
          <button class="navbar-toggler border-0 p-1" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
        </div>

        <!-- Collapsible nav content -->
        <div class="collapse navbar-collapse" id="navbarMain">
          <ul class="navbar-nav ms-auto align-items-lg-center">

            <% if (navShowViewsButton) { %>
            <li class="nav-item px-1 d-none d-md-block">
              <button class="views-button" id="viewsButton" type="button">
                <i class="fas fa-eye"></i> <span id="viewCount"><%= typeof totalViews !== 'undefined' ? totalViews : '-' %></span>
              </button>
            </li>
            <% } %>

            <!-- Problems dropdown -->
            <li class="nav-item dropdown px-1">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="font-size:14px;font-weight:500;color:#2d2d2d;">
                <%= navLang === 'ru' ? 'Задачи' : 'Problems' %>
              </a>
              <ul class="dropdown-menu dropdown-menu-hover">
                <li>
                  <a class="dropdown-item d-flex align-items-start gap-2 py-2" href="/<%= navLang %>/">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="#6c757d" class="mt-1 flex-shrink-0"><path d="M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811V2.828zm7.5-.141c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492V2.687zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783z"/></svg>
                    <div>
                      <div style="font-weight:500;color:#2d2d2d;"><%= navLang === 'ru' ? 'Савченко' : 'Savchenko' %></div>
                      <div style="font-size:12px;color:#6c757d;"><%= navLang === 'ru' ? '2023 задачи, 14 глав' : '2,023 problems, 14 chapters' %></div>
                    </div>
                  </a>
                </li>
                <!-- Problempedia link removed for now -->
                <li>

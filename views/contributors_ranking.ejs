<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contributors - Savchenko Solutions</title>
    <meta name="description" content="Savchenko Solutions contributor leaderboard and activity data.">
    <link rel="icon" type="image/svg+xml" href="/img/logo.svg">
    <link rel="icon" type="image/png" href="/img/logo.png">
    <link rel="apple-touch-icon" href="/img/logo.png">
    <!-- Bootstrap 5: required for main_site_header (navbar, grid, collapse) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/design-system.css" />
    <link rel="stylesheet" href="/css/main_page.css" />
    <style>
        :root {
            --sv-primary: #1a1a2e;
            --sv-text: #2d2d2d;
            --sv-secondary: #6c757d;
            --sv-border: #dee2e6;
            --sv-bg: #ffffff;
            --sv-card: #f8f9fa;
            --sv-heat-0: #ebedf0;
            --sv-heat-1: #b3c6d9;
            --sv-heat-2: #6d93b8;
            --sv-heat-3: #3a6a9e;
            --sv-heat-4: #1a1a2e;
        }

        body {
            margin: 0;
            color: var(--sv-text);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: var(--sv-bg);
        }

        .contributors-page {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px 16px 32px;
        }

        .page-title {
            font-size: 28px;
            font-weight: 600;
            color: var(--sv-primary);
            margin: 0;
        }

        .page-subtitle {
            margin: 8px 0 24px;
            color: var(--sv-secondary);
            font-size: 15px;
        }

        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 18px;
        }

        .stat-tile {
            border: 1px solid var(--sv-border);
            background: var(--sv-bg);
            border-radius: 8px;
            padding: 14px;
            text-align: center;
        }

        .stat-value {
            font-size: 32px;
            font-weight: 700;
            color: var(--sv-primary);
            line-height: 1.1;
        }

        .stat-label {
            margin-top: 6px;
            font-size: 13px;
            color: var(--sv-secondary);
        }

        .card {
            border: 1px solid var(--sv-border);
            background: var(--sv-bg);
            border-radius: 8px;
            padding: 14px;
            margin-bottom: 18px;
        }

        .section-title {
            margin: 0 0 12px;
            color: var(--sv-primary);
            font-size: 17px;
            font-weight: 600;
        }

        #world-map {
            width: 100%;
            height: 300px;
            display: block;
        }

        .map-tooltip {
            position: fixed;
            pointer-events: none;
            background: var(--sv-bg);
            border: 1px solid var(--sv-border);
            border-radius: 6px;
            padding: 6px 8px;
            color: var(--sv-text);
            font-size: 12px;
            opacity: 0;
            transition: opacity 120ms linear;
        }

        .leaderboard-table {
            width: 100%;
            border-collapse: collapse;
        }

        .leaderboard-table thead th {
            font-size: 13px;
            color: var(--sv-secondary);
            text-align: left;
            border-bottom: 1px solid var(--sv-border);
            padding: 10px 8px;
            cursor: pointer;
            user-select: none;
            white-space: nowrap;
        }

        .leaderboard-table tbody td {
            border-bottom: 1px solid var(--sv-border);
            padding: 9px 8px;
            font-size: 14px;
            vertical-align: middle;
        }

        .leaderboard-table tbody tr:nth-child(even) {
            background: var(--sv-card);
        }

        .leaderboard-table tbody tr:hover {
            background: #eef2f6;
        }

        .leaderboard-table tbody tr {
            cursor: pointer;
        }

        .top-rank {
            font-weight: 700;
        }

        .contributor-cell {
            display: flex;
            align-items: center;
            gap: 9px;
            min-width: 220px;
        }

        .avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid var(--sv-border);
            background: #fff;
        }

        .contributor-main {
            line-height: 1.2;
        }

        .contributor-name {
            color: var(--sv-text);
            font-size: 14px;
        }

        .contributor-username {
            color: var(--sv-secondary);
            font-size: 12px;
        }

        .pagination-row {
            margin-top: 12px;
            display: flex;
            justify-content: space-between;
            gap: 8px;
        }

        .btn-nav {
            border: 1px solid var(--sv-border);
            background: var(--sv-bg);
            color: var(--sv-primary);
            border-radius: 6px;
            padding: 6px 10px;
            font-size: 13px;
        }

        .btn-nav:disabled {
            color: var(--sv-secondary);
            background: var(--sv-card);
        }

        .heatmap-shell {
            overflow-x: auto;
            padding-bottom: 8px;
        }

        .heatmap-wrap {
            display: flex;
            gap: 8px;
            min-width: 760px;
        }

        .heatmap-y {
            width: 30px;
            color: var(--sv-secondary);
            font-size: 11px;
            padding-top: 18px;
        }

        .heatmap-y div {
            height: 13px;
            line-height: 13px;
            margin-bottom: 2px;
        }

        .heatmap-main {
            flex: 1;
        }

        .heatmap-months {
            display: grid;
            grid-template-columns: repeat(53, 11px);
            gap: 2px;
            height: 16px;
            margin-bottom: 2px;
            color: var(--sv-secondary);
            font-size: 10px;
        }

        .heatmap-grid {
            display: grid;
            grid-template-columns: repeat(53, 11px);
            grid-auto-rows: 11px;
            gap: 2px;
        }

        .heat-cell {
            width: 11px;
            height: 11px;
            border-radius: 2px;
            background: var(--sv-heat-0);
        }

        .skeleton {
            background: linear-gradient(90deg, #eceff2, #f3f5f7, #eceff2);
            background-size: 200% 100%;
            animation: pulse 1.2s linear infinite;
            border-radius: 4px;
            color: transparent;
        }

        @keyframes pulse {
            0% { background-position: 0% 0%; }
            100% { background-position: -200% 0%; }
        }

        @media (max-width: 900px) {
            .stats-row {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 768px) {
            .contributors-page {
                padding: 16px 12px 24px;
            }
            .leaderboard-table thead th,
            .leaderboard-table tbody td {
                font-size: 12px;
                padding: 8px 6px;
            }
            .contributor-cell {
                min-width: 170px;
            }
        }
    </style>
</head>
<body>
    <%- include('default/main_site_header') %>

    <main class="contributors-page">
        <h1 class="page-title">Contributors</h1>
        <p id="contributors-subtitle" class="page-subtitle skeleton">Loading contributor summary...</p>

        <section class="stats-row">
            <article class="stat-tile">
                <div id="stat-contributors" class="stat-value skeleton">0000</div>
                <div class="stat-label">Contributors</div>
            </article>
            <article class="stat-tile">
                <div id="stat-solutions" class="stat-value skeleton">0000</div>
                <div class="stat-label">Solutions</div>
            </article>
            <article class="stat-tile">
                <div id="stat-countries" class="stat-value skeleton">0000</div>
                <div class="stat-label">Countries</div>
            </article>
            <article class="stat-tile">
                <div id="stat-languages" class="stat-value" style="font-size: 20px;">Russian, English</div>
                <div class="stat-label">Languages</div>
            </article>
        </section>

        <section class="card">
            <h2 class="section-title">Geographic Distribution</h2>
            <svg id="world-map" viewBox="0 0 960 300" preserveAspectRatio="xMidYMid meet"></svg>
        </section>

        <section class="card">
            <h2 class="section-title">Leaderboard</h2>
            <div style="overflow-x:auto;">
                <table class="leaderboard-table">
                    <thead>
                        <tr>
                            <th data-sort="rank">Rank</th>
                            <th data-sort="contributor">Contributor</th>
                            <th data-sort="solutions">Solutions</th>
                            <th data-sort="score">Score</th>
                            <th data-sort="joined">Joined</th>
                            <th data-sort="lastActive">Last Active</th>
                        </tr>
                    </thead>
                    <tbody id="leaderboard-body"></tbody>
                </table>
            </div>
            <div class="pagination-row">
                <button id="prev-page" class="btn-nav" type="button">Previous</button>
                <span id="page-info" style="font-size:13px;color:#6c757d;align-self:center;">Page 1</span>
                <button id="next-page" class="btn-nav" type="button">Next</button>
            </div>
        </section>

        <section class="card">
            <h2 class="section-title">Platform Contribution Activity (Last 12 Months)</h2>
            <div class="heatmap-shell">
                <div class="heatmap-wrap">
                    <div class="heatmap-y">
                        <div></div>
                        <div>Mon</div>
                        <div></div>
                        <div>Wed</div>
                        <div></div>
                        <div>Fri</div>
                        <div></div>
                    </div>
                    <div class="heatmap-main">
                        <div id="platform-months" class="heatmap-months"></div>
                        <div id="platform-heatmap" class="heatmap-grid"></div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <div id="map-tooltip" class="map-tooltip"></div>

    <%- include('default/modern_footer') %>
    <%- include('default/main_site_footer_scripts') %>

    <script src="https://cdn.jsdelivr.net/npm/d3@7"></script>
    <script>
        const lang = "<%= lang %>";
        const state = {
            page: 1,
            limit: 25,
            sortBy: "score",
            sortOrder: "desc",
            total: 0,
        };

        const heatColors = ["#ebedf0", "#b3c6d9", "#6d93b8", "#3a6a9e", "#1a1a2e"];

        function fmtMonthYear(dateInput) {
            if (!dateInput) return "N/A";
            const d = new Date(dateInput);
            return d.toLocaleDateString("en-US", { month: "short", year: "numeric" });
        }

        function fmtLong(dateInput) {
            if (!dateInput) return "N/A";
            const d = new Date(dateInput);
            return d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
        }

        function setStat(id, value, removeSkeleton = true) {
            const el = document.getElementById(id);
            if (!el) return;
            el.textContent = value;
            if (removeSkeleton) el.classList.remove("skeleton");
        }

        function heatColor(value, max) {
            if (!value) return heatColors[0];
            const ratio = max > 0 ? value / max : 0;
            if (ratio >= 0.75) return heatColors[4];
            if (ratio >= 0.5) return heatColors[3];
            if (ratio >= 0.25) return heatColors[2];
            return heatColors[1];
        }

        function buildCalendarDays(dayCounts) {
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const start = new Date(today);
            start.setDate(start.getDate() - 364);

            const startDay = (start.getDay() + 6) % 7;
            start.setDate(start.getDate() - startDay);

            const result = [];
            const countMap = new Map(dayCounts.map((x) => [String(x.day).slice(0, 10), x.count]));
            for (let i = 0; i < 371; i += 1) {
                const d = new Date(start);
                d.setDate(start.getDate() + i);
                const key = d.toISOString().slice(0, 10);
                result.push({
                    date: d,
                    count: countMap.get(key) || 0,
                    week: Math.floor(i / 7),
                    dow: (d.getDay() + 6) % 7,
                });
            }
            return result;
        }

        function renderHeatmap(dayCounts) {
            const grid = document.getElementById("platform-heatmap");
            const months = document.getElementById("platform-months");
            if (!grid || !months) return;

            const days = buildCalendarDays(dayCounts);
            const max = dayCounts.reduce((m, x) => Math.max(m, x.count), 0);

            grid.innerHTML = "";
            months.innerHTML = "";

            const labels = new Array(53).fill("");
            for (const day of days) {
                if (day.date.getDate() === 1) {
                    labels[day.week] = day.date.toLocaleDateString("en-US", { month: "short" });
                }
            }
            labels.forEach((m) => {
                const div = document.createElement("div");
                div.textContent = m;
                months.appendChild(div);
            });

            days.forEach((day) => {
                const cell = document.createElement("div");
                cell.className = "heat-cell";
                cell.style.gridColumn = String(day.week + 1);
                cell.style.gridRow = String(day.dow + 1);
                cell.style.background = heatColor(day.count, max);
                const dateLabel = day.date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
                cell.title = `${day.count} contributions on ${dateLabel}`;
                grid.appendChild(cell);
            });
        }

        async function fetchJSON(url) {
            const res = await fetch(url);
            if (!res.ok) throw new Error(`Failed: ${url}`);
            return res.json();
        }

        async function loadStats() {
            const stats = await fetchJSON("/api/contributors/stats");
            setStat("stat-contributors", stats.contributors.toLocaleString());
            setStat("stat-solutions", stats.solutions.toLocaleString());
            setStat("stat-countries", stats.countries.toLocaleString());
            setStat("stat-languages", stats.languages || "Russian, English", false);

            const subtitle = document.getElementById("contributors-subtitle");
            subtitle.classList.remove("skeleton");
            subtitle.textContent = `${stats.contributors.toLocaleString()} people from ${stats.countries.toLocaleString()} countries maintaining ${stats.solutions.toLocaleString()} solutions under Creative Commons.`;
        }

        function renderRows(rows) {
            const tbody = document.getElementById("leaderboard-body");
            tbody.innerHTML = "";

            rows.forEach((row) => {
                const tr = document.createElement("tr");
                tr.addEventListener("click", () => {
                    window.location.href = `/user/${row.username}`;
                });

                const rankClass = row.rank <= 3 ? "top-rank" : "";
                const countryPrefix = row.countryFlag ? `${row.countryFlag} ` : "";
                tr.innerHTML = `
                    <td class="${rankClass}">${row.rank}</td>
                    <td>
                        <div class="contributor-cell">
                            <img class="avatar" src="${row.profilePicture}" alt="${row.fullName}">
                            <div class="contributor-main">
                                <div class="contributor-name">${countryPrefix}${row.fullName}</div>
                                <div class="contributor-username">@${row.username}</div>
                            </div>
                        </div>
                    </td>
                    <td>${Number(row.solutions || 0).toLocaleString()}</td>
                    <td>${Number(row.score || 0).toLocaleString()}</td>
                    <td>${fmtMonthYear(row.joinedAt)}</td>
                    <td>${fmtLong(row.lastActiveAt)}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        async function loadLeaderboard() {
            const query = new URLSearchParams({
                page: String(state.page),
                limit: String(state.limit),
                sortBy: state.sortBy,
                sortOrder: state.sortOrder,
            });
            const data = await fetchJSON(`/api/contributors/leaderboard?${query.toString()}`);
            state.total = data.total;
            renderRows(data.rows);

            document.getElementById("prev-page").disabled = !data.hasPrev;
            document.getElementById("next-page").disabled = !data.hasNext;
            const totalPages = Math.max(1, Math.ceil((data.total || 0) / state.limit));
            document.getElementById("page-info").textContent = `Page ${state.page} of ${totalPages}`;
        }

        async function loadMap() {
            const [geojson, mapData] = await Promise.all([
                fetchJSON("https://raw.githubusercontent.com/holtzy/D3-graph-gallery/master/DATA/world.geojson"),
                fetchJSON("/api/contributors/map"),
            ]);

            const counts = new Map(mapData.map((x) => [String(x.country).toLowerCase(), Number(x.contributors || 0)]));
            const max = Math.max(0, ...mapData.map((x) => Number(x.contributors || 0)));
            const svg = d3.select("#world-map");
            svg.selectAll("*").remove();

            const width = 960;
            const height = 300;
            const projection = d3.geoNaturalEarth1().fitSize([width, height], geojson);
            const path = d3.geoPath().projection(projection);
            const scale = d3.scaleLinear().domain([0, Math.max(1, max)]).range(["#ffffff", "#1a1a2e"]);
            const tooltip = document.getElementById("map-tooltip");

            svg.selectAll("path.country")
                .data(geojson.features)
                .join("path")
                .attr("class", "country")
                .attr("d", path)
                .attr("fill", (d) => {
                    const name = String(d.properties?.name || "").toLowerCase();
                    const count = counts.get(name) || 0;
                    return scale(count);
                })
                .attr("stroke", "#dee2e6")
                .attr("stroke-opacity", 0.7)
                .attr("stroke-width", 0.6)
                .on("mousemove", (event, d) => {
                    const name = d.properties?.name || "Unknown";
                    const count = counts.get(String(name).toLowerCase()) || 0;
                    tooltip.textContent = `${name}: ${count}`;
                    tooltip.style.left = `${event.clientX + 12}px`;
                    tooltip.style.top = `${event.clientY + 12}px`;
                    tooltip.style.opacity = "1";
                })
                .on("mouseleave", () => {
                    tooltip.style.opacity = "0";
                });
        }

        async function loadHeatmap() {
            const data = await fetchJSON("/api/contributors/heatmap");
            renderHeatmap(data);
        }

        function bindSortEvents() {
            document.querySelectorAll("th[data-sort]").forEach((th) => {
                th.addEventListener("click", async () => {
                    const key = th.getAttribute("data-sort");
                    if (state.sortBy === key) {
                        state.sortOrder = state.sortOrder === "desc" ? "asc" : "desc";
                    } else {
                        state.sortBy = key;
                        state.sortOrder = key === "contributor" || key === "joined" ? "asc" : "desc";
                    }
                    state.page = 1;
                    await loadLeaderboard();
                });
            });
        }

        function bindPagination() {
            document.getElementById("prev-page").addEventListener("click", async () => {
                if (state.page <= 1) return;
                state.page -= 1;
                await loadLeaderboard();
            });
            document.getElementById("next-page").addEventListener("click", async () => {
                state.page += 1;
                await loadLeaderboard();
            });
        }

        async function init() {
            bindSortEvents();
            bindPagination();
            await Promise.all([loadStats(), loadLeaderboard(), loadHeatmap(), loadMap()]);
        }

        init().catch((error) => {
            console.error("Contributors page failed to load:", error);
        });
    </script>
</body>
</html>

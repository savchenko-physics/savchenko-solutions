<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Meta -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="content-language" content="en" />
  <meta name="keywords" content="<%= __('meta.keywords') %>" />
  <meta name="description" content="<%= __('meta.description') %>" />
  <meta name="author" content="<%= __('meta.author') %>" />
  <meta name="date" content="<%= __('meta.date') %>" scheme="YYYY-MM" />
  <meta property="og:title" content="<%= __('title') %>" />
  <meta property="og:image" content="https://savchenkosolutions.com/img/logo.png" />
  <meta property="og:description" content="<%= __('meta.ogDescription') %>" />
  <meta name="yandex-verification" content="6cfda41f74038368" />
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
  <link rel="icon" type="image/png" href="/img/logo.png" />
  <link rel="apple-touch-icon" href="/img/logo.png" />
  
  <!-- jQuery -->
  <script src="/js/jquery-1.10.1.min.js"></script>

  <!-- Bootstrap 5 (via CDN) -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  
  <!-- Google Fonts: Roboto -->
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />

  
  <!-- Design system + page CSS -->
  <link rel="stylesheet" href="/css/design-system.css" />
  <link rel="stylesheet" href="/css/main_page.css" />
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <title><%= __('title') %></title>
</head>

<body>
  <%- include('default/main_site_header') %>

  <!-- ============================
       MAIN CONTENT (FULL WIDTH)
  ============================ -->
  <main class="container-fluid mt-1 mb-4 px-3 px-md-4">
    <!-- Compact Introduction -->
      <div class="compact-intro mb-4">
        <div class="row align-items-start g-3 compact-intro-row">
          <div class="col-12 col-sm-auto col-lg-3 intro-team-col">
            <figure class="intro-team-figure mb-0">
              <img
                src="/img/team.webp"
                alt="<%= lang === 'en' ? 'Savchenko Solutions team' : 'Команда Savchenko Solutions' %>"
                class="intro-team-img img-fluid"
                width="450"
                height="450"
                loading="lazy"
                decoding="async"
              />
              <figcaption class="intro-team-caption">
                <%= __({ phrase: 'description.teamPhotoCaption', locale: lang }) %>
              </figcaption>
            </figure>
          </div>
          <div class="col-12 col-sm col-lg-5 compact-intro-main">
            <p class="intro-text mb-3">
              <%- __({ phrase: 'description.introFirst', locale: lang }, { uniqueSolutions: solutionProgress.totalUniqueSolutions.toLocaleString(lang === 'ru' ? 'ru-RU' : 'en-US') }) %>
            </p>
            <!-- Stacked action cards (left) + progress panel (right) -->
            <div class="row g-3 align-items-stretch intro-actions-stats-row">
              <div class="col-12 intro-actions-stats-col d-flex flex-column">
                <div class="intro-actions flex-grow-1">
                  <a href="/<%= lang %>/study-guide" class="action-link primary-action">
                    <span class="action-content">
                      <strong class="action-title d-inline-flex align-items-center gap-2">
                        <svg aria-hidden="true" focusable="false" viewBox="0 0 16 16" width="17" height="17" fill="currentColor">
                          <path d="M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.251 2.251 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z"></path>
                        </svg>
                        <span>
                          <% if (lang === 'en') { %>Contributing Guide<% } else { %>Руководство по участию<% } %>
                        </span>
                      </strong>
                      <span class="action-desc">
                        <% if (lang === 'en') { %>Learn how to submit solutions, edit problems, and earn recognition<% } else { %>Узнайте, как отправлять решения, редактировать задачи и получать признание<% } %>
                      </span>
                    </span>
                  </a>
                  <a href="/<%= lang %>/upload" class="action-link secondary-action">
                    <span class="action-content">
                      <strong class="action-title d-inline-flex align-items-center gap-2">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                          <path d="M12 3v14" />
                          <path d="M6 9l6-6 6 6" />
                          <path d="M5 19h14" />
                        </svg>
                        <span>
                          <% if (lang === 'en') { %>Upload Solution<% } else { %>Загрузить решение<% } %>
                        </span>
                      </strong>
                      <span class="action-desc">
                        <% if (lang === 'en') { %>Quick upload - no registration needed<% } else { %>Быстрая загрузка - регистрация не требуется<% } %>
                      </span>
                    </span>
                  </a>
                </div>
              </div>
              <div class="col-12 solution-progress-stats-col d-flex flex-column">
                <% 
                  var _tp = solutionProgress.totalProblems;
                  var _curBar = _tp > 0 ? ((solutionProgress.currentLangSolutions / _tp) * 100).toFixed(1) : '0';
                  var _otherBar = _tp > 0 ? (((solutionProgress.totalUniqueSolutions - solutionProgress.currentLangSolutions) / _tp) * 100).toFixed(1) : '0';
                %>
                <div class="solution-progress-panel w-100">
                  <div class="solution-coverage-card">
                    <div class="solution-coverage-head">
                      <span class="solution-coverage-eyebrow"><%= __('unsolved.overallProgress') %></span>
                      <a href="/<%= lang %>/unsolved" class="solution-coverage-detail" title="<%= __('unsolved.title') %>">
                        <span class="solution-coverage-detail-text"><%= lang === 'en' ? 'Breakdown' : 'Детали' %></span>
                        <svg class="solution-coverage-detail-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                          <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </a>
                    </div>
                    <div class="solution-coverage-metric" aria-live="polite">
                      <span id="engHomeProgressCounter" class="solution-coverage-num">0</span>
                      <span class="solution-coverage-slash" aria-hidden="true">/</span>
                      <span class="solution-coverage-total"><%= _tp %></span>
                    </div>
                    <p class="solution-coverage-meta">
                      <span class="solution-coverage-caption"><%= __('unsolved.totalSolved') %></span>
                      <span class="solution-coverage-meta-sep" aria-hidden="true">·</span>
                      <span class="solution-coverage-pct-wrap">
                        <span id="engHomePercentageCounter" class="solution-coverage-pct-value">0</span><span class="solution-coverage-pct-unit">%</span>
                      </span>
                    </p>
                    <div class="solution-coverage-bar" role="presentation">
                      <div class="solution-coverage-bar-track">
                        <div class="solution-coverage-bar-current" style="width: <%= _curBar %>%"></div>
                        <div class="solution-coverage-bar-other" style="width: <%= _otherBar %>%"></div>
                      </div>
                    </div>
                  </div>
                  <hr class="solution-progress-divider">
                  <p class="info-team-members">
                    <% if (lang === 'en') { %>
                      <span class="info-team-label-inline">Core Team:</span>
                      <a href="/user/astrosander/">astrosander</a>,
                      <a href="/user/emixter/">emixter</a>,
                      <a href="/user/igor/">igor</a>,
                      <a href="/user/Ismail">Ismail</a>
                      <a href="<%= lang === 'en' ? '/about#team' : '/ru/about#team' %>" class="info-more">+more</a>
                    <% } else { %>
                      <span class="info-team-label-inline">Команда:</span>
                      <a href="/user/astrosander/">astrosander</a>,
                      <a href="/user/emixter/">emixter</a>,
                      <a href="/user/igor/">igor</a>,
                      <a href="/user/Ismail">Ismail</a>
                      <a href="<%= lang === 'en' ? '/about#team' : '/ru/about#team' %>" class="info-more">+ещё</a>
                    <% } %>
                  </p>
                </div>
              </div>
            </div>
          </div>
          <div class="col-12 col-lg-4 intro-youtube-col">
            <!-- YouTube Video (kept in current position) -->
            <div class="mb-3">
              <a href="https://www.youtube.com/watch?v=d-x7Lk-mfTs" target="_blank" class="video-preview">
                <img
                  src="/img/yt_preview.jpg"
                  alt="Watch on YouTube"
                  class="img-fluid"
                />
                <div class="play-button-overlay">
                  <svg width="48" height="48" viewBox="0 0 68 48" fill="none">
                    <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/>
                    <path d="M45 24L27 14v20" fill="white"/>
                  </svg>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>

    <!-- Chapter & Sections + Sidebar with Top Authors & Contributions -->
    <div class="row">
      <!-- Statistics Button (visible on mobile) -->
      <div class="col-12 d-lg-none mb-4">
        <div class="problem-statements">
          <!-- Download PDF Button -->
          <a href="<%= lang === 'en' ? '/en/savchenko_en.pdf' : '/savchenko.pdf' %>" 
            class="pdf-download-btn"
            style="border-bottom-left-radius: 0px; border-bottom-right-radius: 0px;">
            <div class="pdf-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="16" y1="13" x2="8" y2="13" />
                <line x1="16" y1="17" x2="8" y2="17" />
                <line x1="10" y1="9" x2="8" y2="9" />
              </svg>
            </div>
            <div class="pdf-text">
              <span class="pdf-label"><%= __('description.problemStatements') %></span>
              <span class="pdf-action"><%= __('description.downloadPDF') %></span>
            </div>
          </a>

          <!-- Statistics Button -->
          <a href="/<%= lang %>/unsolved" 
             class="pdf-download-btn"
             style="border-top-left-radius: 0; border-top-right-radius: 0;">
            <div class="pdf-icon">
              <svg aria-hidden="true" focusable="false" viewBox="0 0 16 16" width="20" height="20" fill="currentColor">
                <path d="M1.5 1.75V13.5h13.75a.75.75 0 0 1 0 1.5H.75a.75.75 0 0 1-.75-.75V1.75a.75.75 0 0 1 1.5 0Zm14.28 2.53-5.25 5.25a.75.75 0 0 1-1.06 0L7 7.06 4.28 9.78a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042l3.25-3.25a.75.75 0 0 1 1.06 0L10 7.94l4.72-4.72a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042Z"></path>
              </svg>
            </div>
            <div class="pdf-text">
              <span class="pdf-label"><%= __('description.statistics') %></span>
              <span class="pdf-action"><%= __('description.viewStats') %></span>
            </div>
          </a>
        </div>
      </div>

      <!-- Main content column -->
      <div class="col-12 col-lg-9 mb-5">
        <!-- Chapters and Problems -->
        <% chapters.forEach((chapter, chapterIndex)=> {
            const hasContent = chapter.sections.some(section => 
                section.problems.some(column => column.length > 0)
            );
            if (hasContent) { %>
        <div class="chapter-block mb-4" id="<%= chapterIndex + 1 %>">
          <div class="d-flex align-items-center mb-3 flex-wrap justify-content-between gap-2">
            <div class="d-flex align-items-center flex-wrap">
              <h4 class="chapter-title me-2 text-secondary mb-0 d-inline">
                <%= __('chapter') %> <%= chapterIndex + 1 %>:
              </h4>
              <h4 class="chapter-name mb-0 d-inline">
                <%= chapter.title %>
              </h4>
            </div>
            <!-- Upload Button -->
            <a
              href="/<%= lang %>/upload"
              class="text-decoration-none d-inline-flex align-items-center btn btn-sm btn-outline-dark rounded-pill chapter-upload-pill"
              data-chapter="<%= chapterIndex + 1 %>"
            >
              <span class="upload-text me-2"><%= __('upload.upload') %></span>
              <svg class="upload-icon" viewBox="0 0 24 24" width="14" height="14">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"></path>
              </svg>
            </a>
          </div>
          <hr />
          <!-- Sections -->
          <% chapter.sections.forEach((section, sectionIndex) => {
               const hasProblems = section.problems.some(column => column.length > 0);
               if (hasProblems) { %>
          <div class="mb-4">
            <h5 class="section-title mb-2" id="<%= section.number %>">
              § <%= section.number %> - <%= section.title %>
            </h5>
            <div class="problems-grid">
              <% const allProblems = section.problems.flat(); 
                 allProblems.forEach((problem) => { %>
              <div class="problem-item">
                <a href="/<%= lang %>/<%= problem %>" class="problem-link">
                  <%= problem %>
                </a>
              </div>
              <% }); %>
            </div>
          </div>
          <% } }); %>
        </div>
        <% } }); %>
      </div>

      <!-- Sidebar column -->
      <div class="col-12 col-lg-3">
        <!-- Problem Statements PDF (visible on desktop) -->
        <div class="problem-statements mb-4 d-none d-lg-block">
          <div class="buttons-container bg-white rounded-3">
            <!-- PDF Download Button -->
            <a href="<%= lang === 'en' ? '/en/savchenko_en.pdf' : '/savchenko.pdf' %>" 
               class="pdf-download-btn" style="border-top-left-radius: 12px; border-top-right-radius: 12px; border-bottom-left-radius: 0; border-bottom-right-radius: 0;">
              <div class="pdf-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                  <line x1="16" y1="13" x2="8" y2="13" />
                  <line x1="16" y1="17" x2="8" y2="17" />
                  <line x1="10" y1="9" x2="8" y2="9" />
                </svg>
              </div>
              <div class="pdf-text">
                <span class="pdf-label"><%= __('description.problemStatements') %></span>
                <span class="pdf-action"><%= __('description.downloadPDF') %></span>
              </div>
            </a>

            <!-- Statistics Button -->
            <a href="/<%= lang %>/unsolved" 
               class="pdf-download-btn"
               style="border-radius: 0 0 12px 12px;">
              <div class="pdf-icon">
                <svg aria-hidden="true" focusable="false" viewBox="0 0 16 16" width="20" height="20" fill="currentColor">
                  <path d="M1.5 1.75V13.5h13.75a.75.75 0 0 1 0 1.5H.75a.75.75 0 0 1-.75-.75V1.75a.75.75 0 0 1 1.5 0Zm14.28 2.53-5.25 5.25a.75.75 0 0 1-1.06 0L7 7.06 4.28 9.78a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042l3.25-3.25a.75.75 0 0 1 1.06 0L10 7.94l4.72-4.72a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042Z"></path>
                </svg>
              </div>
              <div class="pdf-text">
                <span class="pdf-label"><%= __('description.statistics') %></span>
                <span class="pdf-action"><%= __('description.viewStats') %></span>
              </div>
            </a>
          </div>
        </div>

        <!-- Top Authors -->
        <div class="top-authors text-center br-10 shadow-sm d-none d-lg-block">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="mb-0"><%= __('description.topAuthors') %></h3>
                <a href="/<%= lang %>/contributors" class="btn btn-outline-primary btn-sm">
                    <% if (lang === 'en') { %>View All<% } else { %>Смотреть всех<% } %>
                </a>
            </div>
            <!-- Wrap table in table-responsive to allow horizontal scrolling on mobile -->
            <div class="table-responsive">
                <table class="table table-hover mx-auto">
                    <thead class="thead-light">
                        <tr>
                            <th scope="col" style="width: 10%; opacity: 0.8;">#</th>
                            <th scope="col" style="width: 45%; opacity: 0.8;"><%= __('description.profile') %></th>
                            <th scope="col" style="width: 45%; opacity: 0.8;"><%= __('description.contributions') %></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% topAuthors.forEach((author, index) => { %>
                            <tr>
                                <td>
                                    <% if (index === 0) { %>🥇
                                    <% } else if (index === 1) { %>🥈
                                    <% } else if (index === 2) { %>🥉
                                    <% } else { %><%= index + 1 %>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="<%= author.profile_picture || '/img/profile_images/Default_placeholder.svg' %>" 
                                             alt="<%= author.username %>" 
                                             class="rounded-circle me-2" 
                                             width="24" height="24">
                                        <a href="/user/<%= author.username %>" 
                                           class="text-dark text-decoration-none">
                                            <%= author.username %>
                                        </a>
                                    </div>
                                </td>
                                <td><%= author.rank %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <div class="text-center mt-3">
                <a href="/<%= lang %>/contributors" class="text-muted small">
                    <% if (lang === 'en') { %>View complete ranking →<% } else { %>Полный рейтинг →<% } %>
                </a>
            </div>
        </div>

        <!-- Recent Contributions -->
        <div class="contributions text-center mt-3 bg-white br-10 p-3 shadow-sm d-none d-lg-block">
            <h3 class="text-center mb-4"><%= __('description.contributions2') %></h3>
            <div class="contribution-history timeline ms-2">
                <% recentContributions.forEach((contribution, index) => { %>
                <div class="timeline-item" style="opacity: <%= index >= recentContributions.length - 3 ? Math.max(0.5, 1 - ((index - (recentContributions.length - 3)) * 0.15)) : 1 %>;">
                    <div class="timeline-content nbl-bg">
                        <strong><%= contribution.version %></strong> 
                        <% if (lang === 'en') { %>
                        <span class="text-muted">
                            <a href="/<%= lang %>/contributions/<%= contribution.id %>" class="text-primary text-decoration-none">
                                <%= lang === 'en' ? 'edited' : 'изменена' %>
                            </a> 
                            <span class="text-dark font-weight-bold"><%= contribution.editor %></span>
                        </span>
                        <% } else { %>
                        <span class="text-muted">
                            <a href="/<%= lang %>/contributions/<%= contribution.id %>" class="text-primary text-decoration-none">
                                <%= lang === 'en' ? 'edited' : 'изменена' %>
                            </a> 
                            <span class="text-dark font-weight-bold"><%= contribution.editor %></span>
                        </span>
                        <% } %>
                        <br>
                        <span style="font-size: 0.8rem; color: #888;"><%= new Date(contribution.timestamp).toISOString() %></span>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>
      </div>
    </div>
  </main>

  <!-- ============================
       POP-UP & OVERLAY
  ============================ -->
  <div id="edit-popup">
    <h3><%= __('popup.title') %></h3>
    <input
      type="text"
      id="problem-name"
      placeholder="<%= __('popup.placeholder') %>"
    />
    <button id="submit-problem"><%= __('popup.submit') %></button>
    <button id="cancel-edit"><%= __('popup.cancel') %></button>
  </div>
  <div id="popup-overlay"></div>

  <!-- ============================
       FOOTER
  ============================ -->
  <footer class="bg-dark text-white py-5 border-top mt-5">
    <div class="container">
      <div class="row align-items-center text-center text-md-start">
        <div class="col-md-6 mb-4 mb-md-0">
          <!-- Brand / Title -->
          <a href="/<%= lang %>/" class="d-inline-flex align-items-center text-decoration-none mb-3">
            <img
              src="/img/logo.svg"
              alt="<%= __('title') %> Logo"
              style="height: 32px;"
              class="me-2"
            />
            <span class="fw-bold h5 mb-0 text-white"><%= __('title') %></span>
          </a>
          <!-- Copyright & Basic Info -->
          <p class="mb-0">
            <small>
              © <strong>Savchenko Solutions</strong>, 2023-2025
              <br />
              All solutions are contributed by their respective authors and are
              based on original textbook content, which remains the property of
              the textbook authors.
            </small>
          </p>
        </div>
        
        <!-- License & Contact -->
        <div class="col-md-6 text-md-end">
          <p class="small mb-2">
            Unless otherwise noted, solutions are provided under the
            <strong>CC BY-SA 4.0</strong> license.
            Commercial use of any material requires written permission.
          </p>
          <p class="small mb-0">
            Contact: 
            <a
              href="mailto:aliaksandr@melnichenka.com"
              class="text-decoration-none text-white"
            >
              aliaksandr@melnichenka.com
            </a>
          </p>
        </div>
      </div>
    </div>
  </footer>

  <!-- ============================
       SCRIPTS
  ============================ -->
  <style>
    .search-results {
        text-align: left;
        font-size: 0.85rem;
    }
    .search-results ul {
        padding: 0;
        margin: 0;
    }
    .search-results li {
        padding: 8px 12px;
        cursor: pointer;
    }
    .search-results li:hover {
        background-color: #f1f1f1;
    }
    .bg-dark {
      animation: fadeInFooter 0.8s ease-in-out;
    }
    @keyframes fadeInFooter {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Add these mobile-specific styles */
    @media (max-width: 768px) {
        .site-title {
            font-size: 1.1rem;
        }
        .site-motto {
            font-size: 0.66rem;
        }
        .hero-subtitle {
            font-size: 1.5rem;
        }
        .hero-tagline {
            font-size: 0.9rem;
        }
        .logo-img {
            width: 32px;
            height: 32px;
            object-fit: contain;
        }
        .searchbar-input {
            font-size: 1rem;
            padding: 0.5rem 2.5rem;
        }

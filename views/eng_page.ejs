<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Meta -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="content-language" content="en" />
  <meta name="keywords" content="<%= __('meta.keywords') %>" />
  <meta name="description" content="<%= __('meta.description') %>" />
  <meta name="author" content="<%= __('meta.author') %>" />
  <meta name="date" content="<%= __('meta.date') %>" scheme="YYYY-MM" />
  <meta property="og:title" content="<%= __('title') %>" />
  <meta property="og:image" content="https://savchenkosolutions.com/img/logo.png" />
  <meta property="og:description" content="<%= __('meta.ogDescription') %>" />
  <meta name="yandex-verification" content="6cfda41f74038368" />
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
  <link rel="icon" type="image/png" href="/img/logo.png" />
  <link rel="apple-touch-icon" href="/img/logo.png" />
  

  <!-- Bootstrap 5 (via CDN) -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  
  <!-- Google Fonts: Roboto -->
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />

  
  <!-- Design system + page CSS -->
  <link rel="stylesheet" href="/css/design-system.css" />
  <link rel="stylesheet" href="/css/main_page.css" />
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <title><%= __('title') %></title>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Savchenko Solutions",
    "url": "https://savchenkosolutions.com",
    "description": "<%= solutionProgress.totalUniqueSolutions.toLocaleString('en-US') %> peer-reviewed solutions to Savchenko's Problems in Physics. Free under Creative Commons.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://savchenkosolutions.com/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <script src="/js/analytics.js"></script>
</head>

<body>
  <%- include('default/main_site_header') %>

  <!-- ============================
       MAIN CONTENT (FULL WIDTH)
  ============================ -->
  <main class="container-fluid mt-1 mb-4 px-3 px-md-4">
    <!-- Compact Introduction -->
      <div class="compact-intro mb-4">
        <div class="row align-items-start g-3 compact-intro-row">
          <div class="col-12 col-sm-auto col-lg-3 intro-team-col">
            <figure class="intro-team-figure mb-0">
              <img
                src="/img/team.webp"
                alt="<%= lang === 'en' ? 'Savchenko Solutions team' : 'Команда Savchenko Solutions' %>"
                class="intro-team-img img-fluid"
                width="450"
                height="450"
                loading="lazy"
                decoding="async"
              />
              <figcaption class="intro-team-caption">
                <%= __({ phrase: 'description.teamPhotoCaption', locale: lang }) %>
              </figcaption>
            </figure>
          </div>
          <div class="col-12 col-sm col-lg-5 compact-intro-main">
            <p class="intro-text mb-3">
              <%- __({ phrase: 'description.introFirst', locale: lang }, { uniqueSolutions: solutionProgress.totalUniqueSolutions.toLocaleString(lang === 'ru' ? 'ru-RU' : 'en-US') }) %>
            </p>
            <!-- Stacked action cards (left) + progress panel (right) -->
            <div class="row g-3 align-items-stretch intro-actions-stats-row">
              <div class="col-12 intro-actions-stats-col d-flex flex-column">
                <div class="intro-actions flex-grow-1">
                  <a href="/<%= lang %>/study-guide" class="action-link primary-action">
                    <span class="action-content">
                      <strong class="action-title d-inline-flex align-items-center gap-2">
                        <svg aria-hidden="true" focusable="false" viewBox="0 0 16 16" width="17" height="17" fill="currentColor">
                          <path d="M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.251 2.251 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.251 2.251 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z"></path>
                        </svg>
                        <span>
                          <% if (lang === 'en') { %>Contributing Guide<% } else { %>Руководство по участию<% } %>
                        </span>
                      </strong>
                      <span class="action-desc">
                        <% if (lang === 'en') { %>Learn how to submit solutions, edit problems, and earn recognition<% } else { %>Узнайте, как отправлять решения, редактировать задачи и получать признание<% } %>
                      </span>
                    </span>
                  </a>
                  <a href="/<%= lang %>/upload" class="action-link secondary-action">
                    <span class="action-content">
                      <strong class="action-title d-inline-flex align-items-center gap-2">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                          <path d="M12 3v14" />
                          <path d="M6 9l6-6 6 6" />
                          <path d="M5 19h14" />
                        </svg>
                        <span>
                          <% if (lang === 'en') { %>Upload Solution<% } else { %>Загрузить решение<% } %>
                        </span>
                      </strong>
                      <span class="action-desc">
                        <% if (lang === 'en') { %>Quick upload - no registration needed<% } else { %>Быстрая загрузка - регистрация не требуется<% } %>
                      </span>
                    </span>
                  </a>
                </div>
              </div>
              <div class="col-12 solution-progress-stats-col d-flex flex-column">
                <% 
                  var _tp = solutionProgress.totalProblems;
                  var _curBar = _tp > 0 ? ((solutionProgress.currentLangSolutions / _tp) * 100).toFixed(1) : '0';
                  var _otherBar = _tp > 0 ? (((solutionProgress.totalUniqueSolutions - solutionProgress.currentLangSolutions) / _tp) * 100).toFixed(1) : '0';
                %>
                <div class="solution-progress-panel w-100">
                  <div class="solution-coverage-card">
                    <div class="solution-coverage-head">
                      <span class="solution-coverage-eyebrow"><%= __('unsolved.overallProgress') %></span>
                      <a href="/<%= lang %>/unsolved" class="solution-coverage-detail" title="<%= __('unsolved.title') %>">
                        <span class="solution-coverage-detail-text"><%= lang === 'en' ? 'Breakdown' : 'Детали' %></span>
                        <svg class="solution-coverage-detail-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                          <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </a>
                    </div>
                    <div class="solution-coverage-metric" aria-live="polite">
                      <span id="engHomeProgressCounter" class="solution-coverage-num">0</span>
                      <span class="solution-coverage-slash" aria-hidden="true">/</span>
                      <span class="solution-coverage-total"><%= _tp %></span>
                    </div>
                    <p class="solution-coverage-meta">
                      <span class="solution-coverage-caption"><%= __('unsolved.totalSolved') %></span>
                      <span class="solution-coverage-meta-sep" aria-hidden="true">·</span>
                      <span class="solution-coverage-pct-wrap">
                        <span id="engHomePercentageCounter" class="solution-coverage-pct-value">0</span><span class="solution-coverage-pct-unit">%</span>
                      </span>
                    </p>
                    <div class="solution-coverage-bar" role="presentation">
                      <div class="solution-coverage-bar-track">
                        <div class="solution-coverage-bar-current" style="width: <%= _curBar %>%"></div>
                        <div class="solution-coverage-bar-other" style="width: <%= _otherBar %>%"></div>
                      </div>
                    </div>
                  </div>
                  <hr class="solution-progress-divider">
                  <p class="info-team-members">
                    <% if (lang === 'en') { %>
                      <span class="info-team-label-inline">Core Team:</span>
                      <a href="/user/astrosander/">astrosander</a>,
                      <a href="/user/emixter/">emixter</a>,
                      <a href="/user/igor/">igor</a>,
                      <a href="/user/Ismail">Ismail</a>
                      <a href="<%= lang === 'en' ? '/about#team' : '/ru/about#team' %>" class="info-more">+more</a>
                    <% } else { %>
                      <span class="info-team-label-inline">Команда:</span>
                      <a href="/user/astrosander/">astrosander</a>,
                      <a href="/user/emixter/">emixter</a>,
                      <a href="/user/igor/">igor</a>,
                      <a href="/user/Ismail">Ismail</a>
                      <a href="<%= lang === 'en' ? '/about#team' : '/ru/about#team' %>" class="info-more">+ещё</a>
                    <% } %>
                  </p>
                </div>
              </div>
            </div>
          </div>
          <div class="col-12 col-lg-4 intro-youtube-col">
            <!-- YouTube Video (kept in current position) -->
            <div class="mb-3">
              <a href="https://www.youtube.com/watch?v=d-x7Lk-mfTs" target="_blank" class="video-preview">
                <img
                  src="/img/yt_preview.jpg"
                  alt="Watch on YouTube"
                  class="img-fluid"
                />
                <div class="play-button-overlay">
                  <svg width="48" height="48" viewBox="0 0 68 48" fill="none">
                    <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/>
                    <path d="M45 24L27 14v20" fill="white"/>
                  </svg>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>

    <!-- Two-column layout -->
    <%
      const _totalProblems = solutionProgress.totalProblems;
      const _totalSolved = solutionProgress.totalUniqueSolutions;
      const _totalUnsolved = _totalProblems - _totalSolved;
      const _overallPct = _totalProblems > 0 ? ((_totalSolved / _totalProblems) * 100).toFixed(1) : '0';
    %>
    <div class="home-layout">
      <!-- LEFT COLUMN: Progress + Chapters -->
      <div class="home-main">
        <!-- Overall Progress Bar -->
        <div class="overall-progress mb-4">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <span style="font-size: 14px; font-weight: 600; color: #2d2d2d;">
              <%= _totalSolved.toLocaleString(lang === 'ru' ? 'ru-RU' : 'en-US') %> / <%= _totalProblems.toLocaleString(lang === 'ru' ? 'ru-RU' : 'en-US') %>
              <%= lang === 'ru' ? 'задач решено' : 'problems solved' %>
              (<%= _overallPct %>%)
            </span>
            <div class="d-flex align-items-center gap-3">
              <a href="<%= lang === 'en' ? '/en/savchenko_en.pdf' : '/savchenko.pdf' %>"
                 class="text-decoration-none" style="font-size: 13px; color: #1a5276;">
                <%= lang === 'ru' ? 'Скачать учебник' : 'Download Textbook' %>
              </a>
            </div>
          </div>
          <div style="height: 8px; border-radius: 4px; background: #ebedf0; overflow: hidden;">
            <div style="height: 100%; width: <%= _overallPct %>%; background: #1a1a2e; border-radius: 4px; transition: width 0.6s ease;"></div>
          </div>
          <p style="font-size: 13px; color: #6c757d; margin: 6px 0 0;">
            <%= _totalUnsolved %> <%= lang === 'ru' ? 'задач ещё не решены.' : 'problems still unsolved.' %>
            <a href="/<%= lang %>/unsolved" style="color: #1a5276;"><%= lang === 'ru' ? 'Сможете решить одну?' : 'Can you solve one?' %></a>
          </p>
        </div>

        <!-- Chapter Grid -->
        <div class="chapter-grid">
          <% chapters.forEach((chapter, chapterIndex) => {
            const chNum = chapterIndex + 1;
            let chSolved = 0;
            let chTotal = 0;
            const chSections = [];
            chapter.sections.forEach(section => {
              const sMax = parseInt(section.maximum) || 0;
              const allProbs = section.problems.flat();
              const sSolved = allProbs.length;
              chTotal += sMax;
              chSolved += sSolved;
              const sectionProblems = [];
              for (let p = 1; p <= sMax; p++) {
                const probName = section.number + '.' + p;
                const isSolved = allProbs.includes(probName);
                sectionProblems.push({ name: probName, solved: isSolved });
              }
              chSections.push({ number: section.number, title: section.title, solved: sSolved, total: sMax, problems: sectionProblems });
            });
            const chPct = chTotal > 0 ? ((chSolved / chTotal) * 100).toFixed(0) : '0';
          %>
          <div class="chapter-card" id="ch-<%= chNum %>">
            <div class="chapter-card-header" data-chapter="<%= chNum %>">
              <div class="d-flex align-items-start gap-3">
                <span class="chapter-num"><%= chNum %></span>
                <div class="flex-grow-1">
                  <div class="chapter-card-name"><%= chapter.title %></div>
                  <% if (lang === 'ru') { %>
                    <%
                      const enChapterNames = ['Kinematics','Dynamics','Oscillations and Waves','Fluid Mechanics','Molecular Physics','Electrostatics','Motion of charged particles in an electric field','Electric current','Constant magnetic field','Motion of charged particles in complex fields','Electromagnetic induction','Electromagnetic waves','Geometrical optics. Photometry. Quantum nature of light','Special theory of relativity'];
                    %>
                    <div class="chapter-card-name-alt"><%= enChapterNames[chapterIndex] || '' %></div>
                  <% } %>
                  <div class="chapter-card-progress">
                    <div class="chapter-mini-bar">
                      <div class="chapter-mini-bar-fill" style="width: <%= chPct %>%;"></div>
                    </div>
                    <span class="chapter-card-count"><%= chSolved %> / <%= chTotal %> <%= lang === 'ru' ? 'решено' : 'solved' %></span>
                  </div>
                </div>
                <svg class="chapter-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M4 6l4 4 4-4" stroke="#6c757d" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
            <div class="chapter-content">
              <% chSections.forEach(sec => { %>
              <div class="section-block">
                <div class="section-header" id="<%= sec.number %>">
                  <span class="section-name">&sect; <%= sec.number %> &mdash; <%= sec.title %></span>
                  <span class="section-count"><%= sec.solved %> / <%= sec.total %></span>
                </div>
                <div class="problem-dots">
                  <% sec.problems.forEach(prob => { %>
                  <a href="<%= prob.solved ? '/' + lang + '/' + prob.name : '/' + lang + '/upload' %>"
                     class="problem-dot <%= prob.solved ? 'solved' : 'unsolved' %>"
                     title="<%= (lang === 'ru' ? 'Задача ' : 'Problem ') + prob.name %>"><%= prob.name.split('.')[2] %></a>
                  <% }); %>
                </div>
              </div>
              <% }); %>
            </div>
          </div>
          <% }); %>
        </div>

        <!-- Problempedia callout removed for now -->

        <!-- Latest from the Blog (in main column) -->
        <div id="blogWidgetMain" style="display:none; margin-top: 1.5rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
            <h3 style="font-size: 16px; font-weight: 600; color: #2d2d2d; margin: 0;">
              <%= lang === 'ru' ? 'Блог' : 'Latest from the Blog' %>
            </h3>
            <a href="/blog" style="font-size: 13px; color: #1a5276; text-decoration: none; font-weight: 500;">
              <%= lang === 'ru' ? 'Все' : 'View all' %> &rarr;
            </a>
          </div>
          <div id="blogWidgetMainList" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1rem;"></div>
        </div>
      </div>

      <!-- RIGHT COLUMN: Sticky Sidebar -->
      <div class="home-sidebar">
        <div class="sidebar-sticky">

          <!-- Challenge of the Week Widget -->
          <% if (typeof challengeWidget !== 'undefined' && challengeWidget) { %>
          <div class="sidebar-section" style="margin-bottom: 1.25rem;">
            <div style="padding: 1rem; background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 8px;">
              <div style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #1a1a2e; margin-bottom: 0.4rem;">
                <%= lang === 'ru' ? 'Задача недели' : 'Challenge of the Week' %>
              </div>
              <p style="font-size: 14px; color: #2d2d2d; margin: 0 0 0.5rem 0; line-height: 1.4;">
                <%
                  const challengePreview = (challengeWidget.problem_statement || '')
                    .replace(/\$([^$]+)\$/g, '$1')
                    .replace(/\s+/g, ' ')
                    .trim();
                %>
                <%= challengePreview.length > 100 ? challengePreview.substring(0, 100) + '...' : challengePreview %>
              </p>
              <div style="font-size: 13px; color: #6c757d; margin-bottom: 0.5rem;">
                <span id="homeWidgetCountdown" data-end="<%= challengeWidget.week_end %>"></span>
                &middot; <%= challengeWidget.submission_count %> <%= lang === 'ru' ? 'решений' : 'submissions' %>
              </div>
              <a href="/compete/<%= challengeWidget.id %>" style="display: inline-block; background: #1a1a2e; color: #fff; padding: 0.35rem 0.9rem; border-radius: 6px; font-size: 13px; font-weight: 500; text-decoration: none;">
                <%= lang === 'ru' ? 'Попробовать' : 'Try it' %>
              </a>
            </div>
          </div>
          <% } %>

          <!-- Top Authors -->
          <div class="sidebar-section">
            <div class="sidebar-section-header">
              <h3 class="sidebar-title"><%= lang === 'ru' ? 'Лучшие авторы' : 'Top Authors' %></h3>
              <a href="/<%= lang %>/contributors" class="sidebar-view-all"><%= lang === 'ru' ? 'Все' : 'View All' %> &rarr;</a>
            </div>
            <div class="top-authors-list">
              <div class="top-authors-header">
                <span class="ta-rank-col">#</span>
                <span class="ta-user-col"><%= lang === 'ru' ? 'Пользователь' : 'User' %></span>
                <span class="ta-score-col"><%= lang === 'ru' ? 'Балл' : 'Score' %></span>
              </div>
              <% topAuthors.forEach((author, index) => { %>
              <div class="top-author-row">
                <span class="ta-rank-col">
                  <% if (index === 0) { %>
                    <span class="rank-badge rank-gold">1</span>
                  <% } else if (index === 1) { %>
                    <span class="rank-badge rank-silver">2</span>
                  <% } else if (index === 2) { %>
                    <span class="rank-badge rank-bronze">3</span>
                  <% } else { %>
                    <span class="rank-num"><%= index + 1 %></span>
                  <% } %>
                </span>
                <span class="ta-user-col">
                  <img src="<%= author.profile_picture || '/img/profile_images/Default_placeholder.svg' %>"
                       alt="<%= author.username %>"
                       class="ta-avatar" width="24" height="24" />
                  <a href="/user/<%= author.username %>" class="ta-username"><%= author.username %></a>
                </span>
                <span class="ta-score-col ta-score-value"><%= author.rank %></span>
              </div>
              <% }); %>
            </div>
          </div>

          <!-- Recent Changes (GitHub commit thread style) -->
          <div class="sidebar-section mt-4">
            <div class="sidebar-section-header">
              <h3 class="sidebar-title"><%= lang === 'ru' ? 'Последние изменения' : 'Recent Changes' %></h3>
            </div>
            <div class="commit-thread">
              <% recentContributions.slice(0, 8).forEach(contribution => { %>
              <div class="commit-entry<%= contribution.isNew ? ' new-solution' : '' %>">
                <div class="commit-dot-wrapper">
                  <span class="commit-hline"></span>
                  <span class="commit-dot"></span>
                  <span class="commit-hline"></span>
                </div>
                <div class="commit-entry-body">
                  <div class="commit-entry-main">
                    <a href="/<%= lang %>/<%= contribution.version %>" class="commit-problem"><%= contribution.version %></a>
                    <span class="commit-action"><%= contribution.isNew ? (lang === 'ru' ? 'добавлена' : 'new') : (lang === 'ru' ? 'изменена' : 'edited') %></span>
                    <span class="commit-by"><%= lang === 'ru' ? '' : 'by' %></span>
                    <% if (contribution.hasUser) { %>
                      <a href="/user/<%= contribution.editor %>" class="commit-author"><%= contribution.editor %></a>
                    <% } else { %>
                      <span class="commit-author-anon"><%= lang === 'ru' ? 'Аноним' : 'Anonymous' %></span>
                    <% } %>
                  </div>
                  <div class="commit-entry-footer">
                    <time class="commit-time" datetime="<%= contribution.relativeTime %>"><%= contribution.timestamp %></time>
                    <a href="/<%= lang %>/contributions/<%= contribution.id %>" class="commit-id">#<%= contribution.id %></a>
                  </div>
                </div>
              </div>
              <% }); %>
            </div>
            <a href="/<%= lang %>/contributions/all" class="sidebar-view-all" style="display: inline-block; margin-top: 8px;">
              <%= lang === 'ru' ? 'Посмотреть все' : 'View all' %> &rarr;
            </a>
          </div>

          <!-- Blog widget moved to main column -->

        </div>
      </div>
    </div>

  </main>

  <!-- ============================
       POP-UP & OVERLAY
  ============================ -->
  <div id="edit-popup">
    <h3><%= __('popup.title') %></h3>
    <input
      type="text"
      id="problem-name"
      placeholder="<%= __('popup.placeholder') %>"
    />
    <button id="submit-problem"><%= __('popup.submit') %></button>
    <button id="cancel-edit"><%= __('popup.cancel') %></button>
  </div>
  <div id="popup-overlay"></div>

  <!-- ============================
       FOOTER
  ============================ -->
  <%- include('default/modern_footer') %>

  <!-- ============================
       SCRIPTS
  ============================ -->
  <style>
    .search-results {
        text-align: left;
        font-size: 0.85rem;
    }
    .search-results ul {
        padding: 0;
        margin: 0;
    }
    .search-results li {
        padding: 8px 12px;
        cursor: pointer;
    }
    .search-results li:hover {
        background-color: #f1f1f1;
    }
    .bg-dark {
      animation: fadeInFooter 0.8s ease-in-out;
    }
    @keyframes fadeInFooter {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Add these mobile-specific styles */
    @media (max-width: 768px) {
        .site-title {
            font-size: 1.1rem;
        }
        .site-motto {
            font-size: 0.66rem;
        }
        .hero-subtitle {
            font-size: 1.5rem;
        }
        .hero-tagline {
            font-size: 0.9rem;
        }
        .logo-img {
            width: 32px;
            height: 32px;
            object-fit: contain;
        }
        .searchbar-input {
            font-size: 1rem;
            padding: 0.5rem 2.5rem;
        }
        .chapter-title, .chapter-name {
            font-size: 1.2rem;
        }
        .section-title {
            font-size: 1rem;
        }
        .problem-item {
            font-size: 0.9rem;
        }
    }

    @media (max-width: 768px) {
      .problems-grid {
        display: grid;
        gap: 0.5rem;
        grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
      }
    }

    /* Header Summit Link */
    .summit-header-link {
      color: rgba(255, 255, 255, 0.8) !important;
      transition: opacity 0.3s ease;
    }

    .summit-header-link:hover {
      opacity: 1 !important;
      color: white !important;
    }

    /* Platform News Banner */
    .platform-news-banner {
      background: #fff9e6;
      border-left: 4px solid #c9a227;
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    }

    .news-label {
      display: inline-block;
      background: #ffc107;
      color: #000;
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 0.75rem;
      letter-spacing: 0.5px;
    }

    .news-text {
      color: #664d03;
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 1rem;
    }

    .feedback-link {
      display: inline-block;
      color: #856404;
      font-size: 0.9rem;
      font-weight: 500;
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: color 0.2s ease;
    }

    .feedback-link:hover {
      color: #533f03;
      text-decoration: underline;
    }

    /* Compact Introduction */
    .compact-intro {
      background: white;
      border-radius: 0;
      padding: 1rem 1.25rem;
      box-shadow: none;
    }

    .compact-intro-row {
      --intro-team-photo-max: min(100%, 239px);
      --intro-team-figure-max: min(100%, 23.3rem);
    }

    .intro-team-col {
      display: flex;
      justify-content: center;
    }

    @media (min-width: 992px) {
      .compact-intro-row {
        --intro-team-photo-max: min(100%, 289px);
        --intro-team-figure-max: min(100%, 30.4rem);
      }

      /* Team column 5% narrower than col-lg-3 (25% → 23.75%); rest split 5:4 */
      .compact-intro-row > .intro-team-col {
        flex: 0 0 23.75%;
        max-width: 23.75%;
        width: 23.75%;
      }

      .compact-intro-row > .compact-intro-main {
        flex: 0 0 42.3611%;
        max-width: 42.3611%;
        width: 42.3611%;
      }

      .compact-intro-row > .intro-youtube-col {
        flex: 0 0 33.8889%;
        max-width: 33.8889%;
        width: 33.8889%;
      }
    }

    .intro-team-figure {
      max-width: var(--intro-team-figure-max);
      margin-left: auto;
      margin-right: auto;
      width: 100%;
    }

    .intro-team-img {
      display: block;
      width: 100%;
      max-width: var(--intro-team-photo-max);
      height: auto;
      margin-left: auto;
      margin-right: auto;
      aspect-ratio: 1;
      object-fit: cover;
    }

    .intro-team-caption {
      margin-top: 0.55rem;
      font-size: 0.9rem;
      font-weight: 600;
      line-height: 1.42;
      color: #64748b;
      letter-spacing: 0.01em;
      text-align: center;
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
    }

    .intro-text {
      color: #495057;
      font-size: 0.95rem;
      line-height: 1.5;
      margin-bottom: 0.75rem;
    }

    /* Stats column = 90% of former col-md-7 (7/12 × 0.9 = 52.5%); actions fill remainder */
    @media (min-width: 768px) {
      .intro-actions-stats-row {
        align-items: flex-start;
      }

      .intro-actions-stats-row > .intro-actions-stats-col {
        flex: 0 0 47.5%;
        max-width: 47.5%;
        width: 47.5%;
      }

      .intro-actions-stats-row > .solution-progress-stats-col {
        flex: 0 0 52.5%;
        max-width: 52.5%;
        width: 52.5%;
      }
    }

    .intro-actions {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      width: 100%;
    }

    .intro-actions .action-link {
      width: 100%;
      box-sizing: border-box;
      gap: 0.6rem;
      padding: 0.7rem 0.85rem;
    }

    .intro-actions .action-content {
      gap: 0.26rem;
    }

    .intro-actions .action-title {
      font-size: 0.9rem;
    }

    .intro-actions .action-desc {
      font-size: 0.78rem;
      line-height: 1.38;
    }

    .action-link {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 0.95rem 1.1rem;
      border-radius: 0;
      text-decoration: none;
      transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
      border: 1px solid transparent;
    }

    .action-link.primary-action {
      background: #e9f2ff;
      color: #0056b3;
      border-color: #bcd4ff;
    }

    .action-link.primary-action:hover {
      box-shadow: none;
      background: #dbe8ff;
      color: #00408a;
    }

    .action-link.secondary-action {
      background: #f8f9fb;
      color: #495057;
      border-color: #dde2ea;
    }

    .action-link.secondary-action:hover {
      background: #eef2f8;
      border-color: #bcd4ff;
      color: #0056b3;
    }

    .action-icon {
      font-size: 1.75rem;
      flex-shrink: 0;
    }

    .action-content {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      flex: 1;
    }

    .action-title {
      font-size: 1.05rem;
      font-weight: 600;
    }

    .action-desc {
      font-size: 0.9rem;
      line-height: 1.45;
      opacity: 0.9;
    }

    /* Solution progress — aligned with /:lang/unsolved data + bar semantics */
    .solution-progress-panel {
      background: #f4f5f7;
      border: 1px solid rgba(15, 23, 42, 0.07);
      border-radius: 0;
      padding: 0.62rem 0.88rem 0.55rem;
      box-shadow: none;
      font-size: 0.84rem;
      position: relative;
      overflow: hidden;
    }

    .solution-progress-panel::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 4px;
      background: #9a8a5c;
      opacity: 0.9;
      border-radius: 0;
    }

    .solution-coverage-card {
      position: relative;
      z-index: 1;
      padding-left: 0.42rem;
    }

    .solution-coverage-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.4rem;
      margin-bottom: 0.32rem;
    }

    .solution-coverage-eyebrow {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #64748b;
      line-height: 1.2;
    }

    .solution-coverage-detail {
      display: inline-flex;
      align-items: center;
      gap: 0.15rem;
      font-size: 0.78rem;
      font-weight: 500;
      color: #475569;
      text-decoration: none;
      padding: 0.12rem 0.28rem;
      margin: -0.12rem -0.28rem;
      border-radius: 0;
      transition: color 0.2s ease, background-color 0.2s ease;
    }

    .solution-coverage-detail:hover {
      color: #0f172a;
      background-color: rgba(15, 23, 42, 0.04);
    }

    .solution-coverage-detail-icon {
      opacity: 0.65;
      transition: transform 0.25s ease, opacity 0.2s ease;
    }

    .solution-coverage-detail:hover .solution-coverage-detail-icon {
      opacity: 1;
      transform: translateX(2px);
    }

    .solution-coverage-metric {
      display: flex;
      align-items: baseline;
      justify-content: center;
      gap: 0.12rem;
      font-family: ui-sans-serif, system-ui, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      font-variant-numeric: tabular-nums;
      font-feature-settings: "tnum" 1;
      margin: 0 0 0.2rem;
    }

    .solution-coverage-num {
      font-size: 1.52rem;
      font-weight: 650;
      color: #0f172a;
      line-height: 1;
      letter-spacing: -0.02em;
    }

    .solution-coverage-slash {
      font-size: 1.02rem;
      font-weight: 400;
      color: #94a3b8;
      margin: 0 0.02rem;
    }

    .solution-coverage-total {
      font-size: 1.02rem;
      font-weight: 600;
      color: #334155;
    }

    .solution-coverage-meta {
      margin: 0 0 0.26rem;
      text-align: center;
      font-size: 0.8rem;
      line-height: 1.3;
      color: #64748b;
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: center;
      gap: 0.2rem;
    }

    .solution-coverage-caption {
      margin: 0;
    }

    .solution-coverage-meta-sep {
      color: #cbd5e1;
      user-select: none;
    }

    .solution-coverage-pct-wrap {
      font-variant-numeric: tabular-nums;
      font-feature-settings: "tnum" 1;
      color: #475569;
      white-space: nowrap;
    }

    .solution-coverage-pct-value {
      font-weight: 600;
      color: #1e293b;
    }

    .solution-coverage-pct-unit {
      font-weight: 500;
      color: #64748b;
      margin-left: 0.05rem;
    }

    .solution-coverage-bar-track {
      display: flex;
      height: 5px;
      border-radius: 0;
      overflow: hidden;
      background: rgba(15, 23, 42, 0.06);
    }

    .solution-coverage-bar-current {
      height: 100%;
      background: #5a9e5e;
      transition: width 0.85s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .solution-coverage-bar-other {
      height: 100%;
      background: #5b9fd4;
      transition: width 0.85s cubic-bezier(0.22, 1, 0.36, 1);
    }

    @media (prefers-reduced-motion: reduce) {
      .solution-coverage-bar-current,
      .solution-coverage-bar-other {
        transition: none;
      }
    }

    .solution-progress-divider {
      margin: 0.3rem 0 0.28rem;
      border: none;
      border-top: 1px solid rgba(15, 23, 42, 0.08);
    }

    .solution-progress-panel .info-team-members {
      line-height: 1.32;
      font-size: 0.82rem;
      margin-bottom: 0;
    }

    .info-team-label {
      font-weight: 600;
      color: #495057;
      margin: 0 0 0.2rem 0;
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .info-team-label-inline {
      font-weight: 600;
      margin-right: 0.25rem;
    }

    .info-team-members {
      color: #6c757d;
      margin: 0;
      line-height: 1.3;
      font-size: 0.78rem;
    }

    .info-team-members a {
      color: #007bff;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s ease;
    }

    .info-team-members a:hover {
      color: #0056b3;
      text-decoration: underline;
    }

    .info-more {
      color: #6c757d !important;
      font-weight: 400 !important;
      font-style: italic;
      margin-left: 0.25rem;
    }

    .info-more:hover {
      color: #495057 !important;
    }

    /* Video Preview */
    .video-preview {
      position: relative;
      display: block;
      border-radius: 0;
      overflow: hidden;
      transition: opacity 0.2s ease;
      box-shadow: none;
    }

    .video-preview:hover {
      opacity: 0.92;
    }

    .video-preview img {
      width: 100%;
      display: block;
    }

    .play-button-overlay {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
      opacity: 0.9;
      transition: opacity 0.3s ease;
    }

    .video-preview:hover .play-button-overlay {
      opacity: 1;
    }

    @media (max-width: 768px) {
      .platform-news-banner {
        padding: 1rem;
      }

      .news-text {
        font-size: 0.9rem;
      }

      .feedback-link {
        font-size: 0.85rem;
      }

      .compact-intro {
        padding: 0.9rem 1rem;
      }

      .intro-actions {
        gap: 0.5rem;
      }

      .intro-actions .action-link {
        padding: 0.68rem 0.8rem;
      }

      .intro-actions .action-title {
        font-size: 0.86rem;
      }

      .intro-actions .action-desc {
        font-size: 0.74rem;
      }

      .action-link {
        padding: 0.85rem 0.95rem;
      }

      .action-icon {
        font-size: 1.5rem;
      }

      .action-title {
        font-size: 1rem;
      }

      .action-desc {
        font-size: 0.85rem;
      }

      .solution-progress-panel {
        padding: 0.58rem 0.78rem 0.5rem;
        font-size: 0.8rem;
      }

      .solution-coverage-head {
        margin-bottom: 0.26rem;
      }

      .solution-coverage-eyebrow {
        font-size: 0.62rem;
      }

      .solution-coverage-detail {
        font-size: 0.72rem;
      }

      .solution-coverage-metric {
        margin-bottom: 0.16rem;
      }

      .solution-coverage-num {
        font-size: 1.38rem;
      }

      .solution-coverage-slash {
        font-size: 0.95rem;
      }

      .solution-coverage-total {
        font-size: 0.94rem;
      }

      .solution-coverage-meta {
        font-size: 0.76rem;
        margin-bottom: 0.2rem;
      }

      .solution-coverage-bar-track {
        height: 4px;
      }

      .solution-progress-divider {
        margin: 0.24rem 0 0.22rem;
      }

      .solution-progress-panel .info-team-members {
        font-size: 0.78rem;
        line-height: 1.28;
      }

      .compact-intro-row {
        --intro-team-photo-max: min(100%, 209px);
        --intro-team-figure-max: min(100%, 21.85rem);
      }

      .intro-team-caption {
        font-size: 0.82rem;
        text-align: center;
      }

      .info-team-members {
        font-size: 0.8rem;
      }

      .play-button-overlay svg {
        width: 36px;
        height: 36px;
      }
    }

    /* ===== Chapter Grid ===== */
    .chapter-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1px;
      background: #dee2e6;
      border: 1px solid #dee2e6;
      border-radius: 8px;
      overflow: hidden;
    }
    @media (min-width: 768px) {
      .chapter-grid {
        grid-template-columns: 1fr 1fr;
      }
    }
    .chapter-card {
      background: #fff;
    }
    .chapter-card-header {
      padding: 14px 16px;
      cursor: pointer;
      user-select: none;
      transition: background-color 0.15s ease;
    }
    .chapter-card-header:hover {
      background: #f8f9fa;
    }
    .chapter-num {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      border-radius: 6px;
      background: #1a1a2e;
      color: #fff;
      font-weight: 600;
      font-size: 14px;
      flex-shrink: 0;
    }
    .chapter-card-name {
      font-size: 14px;
      font-weight: 600;
      color: #2d2d2d;
      line-height: 1.3;
    }
    .chapter-card-name-alt {
      font-size: 12px;
      color: #6c757d;
      line-height: 1.3;
    }
    .chapter-card-progress {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 6px;
    }
    .chapter-mini-bar {
      flex: 1;
      height: 4px;
      background: #ebedf0;
      border-radius: 2px;
      overflow: hidden;
    }
    .chapter-mini-bar-fill {
      height: 100%;
      background: #27ae60;
      border-radius: 2px;
      transition: width 0.6s ease;
    }
    .chapter-card-count {
      font-size: 12px;
      color: #6c757d;
      white-space: nowrap;
    }
    .chapter-chevron {
      flex-shrink: 0;
      transition: transform 0.2s ease;
      margin-top: 4px;
    }
    .chapter-card.open .chapter-chevron {
      transform: rotate(180deg);
    }
    .chapter-content {
      display: none;
      border-top: 1px solid #dee2e6;
      padding: 12px 16px 16px;
    }
    .chapter-card.open .chapter-content {
      display: block;
    }
    .section-block {
      margin-bottom: 12px;
    }
    .section-block:last-child {
      margin-bottom: 0;
    }
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 6px;
    }
    .section-name {
      font-size: 13px;
      font-weight: 600;
      color: #2d2d2d;
    }
    .section-count {
      font-size: 12px;
      color: #6c757d;
      white-space: nowrap;
    }
    .problem-dots {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
    }
    .problem-dot {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 24px;
      border-radius: 4px;
      font-size: 11px;
      text-decoration: none;
      font-weight: 500;
      line-height: 1;
      transition: opacity 0.15s ease;
    }
    a.problem-dot.solved,
    a.problem-dot.solved:link,
    a.problem-dot.solved:visited,
    a.problem-dot.solved:hover,
    a.problem-dot.solved:active {
      background: #27ae60;
      color: #fff;
    }
    a.problem-dot.solved:hover {
      opacity: 0.85;
    }
    a.problem-dot.unsolved,
    a.problem-dot.unsolved:link,
    a.problem-dot.unsolved:visited,
    a.problem-dot.unsolved:hover,
    a.problem-dot.unsolved:active {
      background: #ebedf0;
      color: #6c757d;
    }
    a.problem-dot.unsolved:hover {
      background: #dee2e6;
    }

    /* Overall progress bar */
    .overall-progress {
      margin-bottom: 20px;
    }

    /* ===== Two-Column Layout ===== */
    .home-layout {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 32px;
      align-items: start;
    }
    @media (max-width: 991px) {
      .home-layout {
        grid-template-columns: 1fr;
      }
    }

    .home-sidebar {
      min-width: 0;
    }
    .sidebar-sticky {
      position: sticky;
      top: 80px;
    }
    @media (max-width: 991px) {
      .sidebar-sticky {
        position: static;
      }
    }

    /* Sidebar sections */
    .sidebar-section {
      background: #fff;
      border: 1px solid #dee2e6;
      border-radius: 8px;
      padding: 16px;
    }
    .sidebar-section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }
    .sidebar-title {
      font-size: 16px;
      font-weight: 600;
      color: #2d2d2d;
      margin: 0;
    }
    .sidebar-view-all {
      font-size: 13px;
      color: #1a5276;
      text-decoration: none;
      font-weight: 500;
    }
    .sidebar-view-all:hover {
      color: #0d3b54;
      text-decoration: underline;
    }

    /* ===== Top Authors ===== */
    .top-authors-list {
      font-size: 14px;
    }
    .top-authors-header {
      display: flex;
      align-items: center;
      padding: 0 0 8px;
      border-bottom: 1px solid #dee2e6;
      margin-bottom: 4px;
      font-size: 12px;
      font-weight: 600;
      color: #6c757d;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .top-author-row {
      display: flex;
      align-items: center;
      padding: 8px 0;
    }
    .ta-rank-col {
      width: 32px;
      flex-shrink: 0;
      text-align: center;
    }
    .ta-user-col {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }
    .ta-score-col {
      width: 48px;
      flex-shrink: 0;
      text-align: right;
    }
    .ta-avatar {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .ta-username {
      color: #1a5276;
      text-decoration: none;
      font-weight: 500;
      font-size: 14px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .ta-username:hover {
      color: #0d3b54;
      text-decoration: underline;
    }
    .ta-score-value {
      font-weight: 600;
      color: #2d2d2d;
      font-size: 14px;
    }

    /* Rank badges (top 3) */
    .rank-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      font-size: 12px;
      font-weight: 700;
      color: #fff;
    }
    .rank-gold {
      background: #FFD700;
      color: #5c4a00;
    }
    .rank-silver {
      background: #C0C0C0;
      color: #3d3d3d;
    }
    .rank-bronze {
      background: #CD7F32;
      color: #fff;
    }
    .rank-num {
      font-size: 13px;
      font-weight: 500;
      color: #6c757d;
    }

    /* ===== Commit Thread (Recent Changes) ===== */
    .commit-thread {
      position: relative;
      padding-left: 0;
    }
    /* Continuous vertical line through dot centers */
    .commit-thread::before {
      content: '';
      position: absolute;
      left: 13px;
      top: 12px;
      bottom: 12px;
      width: 2px;
      background: #dee2e6;
    }
    .commit-entry {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 6px 0;
      position: relative;
    }
    .commit-dot-wrapper {
      display: flex;
      align-items: center;
      flex-shrink: 0;
      width: 28px;
      margin-top: 2px;
      position: relative;

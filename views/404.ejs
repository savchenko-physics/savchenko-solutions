<!DOCTYPE html>
<% const pageLang = typeof lang !== 'undefined' ? lang : 'en'; %>
<html lang="<%= pageLang %>">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta http-equiv="content-language" content="<%= pageLang %>" />
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
  <link rel="icon" type="image/png" href="/img/logo.png" />
  <link rel="apple-touch-icon" href="/img/logo.png" />
  <title><%= __('page404.title') %> — <%= __('title') %></title>

  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
  />
  <link rel="stylesheet" href="/css/design-system.css" />
  <link rel="stylesheet" href="/css/main_page.css" />
</head>
<body class="d-flex flex-column min-vh-100">
  <%- include('default/main_site_header', {
    langSwitchEnUrl: '/en',
    langSwitchRuUrl: '/ru'
  }) %>

  <main class="flex-grow-1 d-flex align-items-center">
    <div style="max-width: 480px; margin: 80px auto; text-align: center; padding: 0 20px;">
      <h1 style="font-size: 72px; font-weight: 700; color: #1a1a2e; margin-bottom: 8px;">404</h1>
      <p style="font-size: 18px; color: #2d2d2d; margin-bottom: 24px;">
        <%= pageLang === 'ru' ? 'Этой задачи пока не существует.' : "This problem doesn't exist yet." %>
      </p>
      <div style="margin-bottom: 16px;">
        <input type="text" id="search404" placeholder="<%= pageLang === 'ru' ? 'Поиск задачи...' : 'Search for a problem...' %>"
          style="width: 100%; max-width: 360px; height: 40px; padding: 0 16px;
          border: 1px solid #dee2e6; border-radius: 6px; font-size: 14px;">
      </div>
      <p style="font-size: 14px; color: #6c757d;">
        <a href="/<%= pageLang %>/" style="color: #1a5276;"><%= pageLang === 'ru' ? 'Все главы' : 'Browse all chapters' %></a> &middot;
        <a href="/upload" style="color: #1a5276;"><%= pageLang === 'ru' ? 'Загрузить решение' : 'Upload a solution' %></a> &middot;
        <a href="/<%= pageLang %>/unsolved" style="color: #1a5276;"><%= pageLang === 'ru' ? 'Нерешённые задачи' : 'View unsolved problems' %></a>
      </p>
    </div>
  </main>

  <%- include('default/modern_footer', { lang: pageLang }) %>

  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
  ></script>
  <script>
    document.getElementById('search404').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        const q = this.value.trim();
        if (q) window.location.href = '/global-search?q=' + encodeURIComponent(q);
      }
    });
  </script>
  <%- include('default/main_site_search_script') %>
</body>
</html>

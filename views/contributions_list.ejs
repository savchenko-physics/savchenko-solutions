<!DOCTYPE html>
<html lang="<%= lang %>">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= problemName === 'all' ? (lang === 'ru' ? 'Все изменения' : 'All Contributions') : 'History - ' + problemName %> | <%= __('title') %></title>
    <meta name="description" content="<%= problemName === 'all' ? (lang === 'ru' ? 'История всех изменений решений задач Савченко' : 'Complete history of all contributions to Savchenko Solutions') : 'Contribution history for problem ' + problemName %>" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/design-system.css" />
    <link rel="stylesheet" href="/css/main_page.css" />

    <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
    <link rel="icon" type="image/png" href="/img/logo.png" />
    <link rel="apple-touch-icon" href="/img/logo.png" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #fff;
            color: #2d2d2d;
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .cl-container {
            max-width: 960px;
            margin: 0 auto;
            padding: 0 24px;
            flex: 1;
        }

        /* Breadcrumb */
        .cl-breadcrumb {
            padding: 16px 0 0;
            font-size: 13px;
            color: #6c757d;
        }
        .cl-breadcrumb a {
            color: #1a5276;
            text-decoration: none;
        }
        .cl-breadcrumb a:hover {
            text-decoration: underline;
        }
        .cl-breadcrumb-sep {
            margin: 0 6px;
            color: #adb5bd;
        }

        /* Page header */
        .cl-header {
            padding: 24px 0 20px;
            border-bottom: 1px solid #dee2e6;
        }
        .cl-header-row {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
        }
        .cl-title {
            font-size: 24px;
            font-weight: 600;
            color: #1a1a2e;
            margin: 0 0 4px;
        }
        .cl-subtitle {
            font-size: 14px;
            color: #6c757d;
            margin: 0;
        }
        .cl-cta {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            background: #1a1a2e;
            color: #fff !important;
            border-radius: 6px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: background 0.15s ease;
            flex-shrink: 0;
        }
        .cl-cta:hover {
            background: #2d2d4e;
            color: #fff !important;
        }

        /* Stats bar */
        .cl-stats {
            display: flex;
            gap: 24px;
            padding: 16px 0;
            border-bottom: 1px solid #dee2e6;
            font-size: 14px;
        }
        .cl-stat {
            display: flex;
            align-items: center;
            gap: 6px;
            color: #6c757d;
        }
        .cl-stat-num {
            font-weight: 600;
            color: #2d2d2d;
        }

        /* Date group */
        .cl-date-group {
            margin-top: 24px;
        }
        .cl-date-header {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 0;
            margin-bottom: 0;
        }
        .cl-date-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            color: #6c757d;
        }
        .cl-date-label {
            font-size: 14px;
            font-weight: 600;
            color: #2d2d2d;
        }

        /* Commit list (GitHub style) */
        .cl-commit-list {
            border: 1px solid #dee2e6;
            border-radius: 8px;
            overflow: hidden;
        }
        .cl-commit-row {
            display: flex;
            align-items: center;
            padding: 10px 16px;
            border-bottom: 1px solid #dee2e6;
            gap: 12px;
            transition: background 0.1s ease;
        }
        .cl-commit-row:last-child {
            border-bottom: none;
        }
        .cl-commit-row:hover {
            background: #f8f9fa;
        }

        /* Dot badge (git-commit icon style) */
        .cl-commit-badge {
            display: flex;
            align-items: center;
            flex-shrink: 0;
            width: 32px;
            justify-content: center;
            position: relative;
        }
        /* Vertical line connecting dots */
        .cl-commit-row .cl-commit-badge::before {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: 50%;
            width: 2px;
            background: #dee2e6;
            transform: translateX(-50%);
        }
        .cl-commit-row:first-child .cl-commit-badge::before {
            top: 50%;
        }
        .cl-commit-row:last-child .cl-commit-badge::before {
            bottom: 50%;
        }
        .cl-commit-row:only-child .cl-commit-badge::before {
            display: none;
        }
        .cl-commit-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #1a1a2e;
            border: 2px solid #fff;
            box-sizing: content-box;
            position: relative;
            z-index: 1;
        }
        .cl-commit-dot::before,
        .cl-commit-dot::after {
            content: '';
            position: absolute;
            top: 50%;
            height: 2px;
            width: 10px;
            background: #dee2e6;
            transform: translateY(-50%);
        }
        .cl-commit-dot::before {
            right: 100%;
        }
        .cl-commit-dot::after {
            left: 100%;
        }
        .cl-commit-row.is-new .cl-commit-dot {
            background: #27ae60;
        }

        /* Main content area */
        .cl-commit-main {
            flex: 1;
            min-width: 0;
        }
        .cl-commit-title {
            display: flex;
            align-items: baseline;
            gap: 6px;
            flex-wrap: wrap;
        }
        .cl-commit-problem {
            font-weight: 600;
            font-size: 14px;
            color: #1a5276;
            text-decoration: none;
        }
        .cl-commit-problem:hover {
            color: #0d3b54;
            text-decoration: underline;
        }
        .cl-commit-label {
            font-size: 12px;
            font-weight: 500;
            padding: 1px 8px;
            border-radius: 12px;
            white-space: nowrap;
        }
        .cl-label-new {
            background: #dcffe4;
            color: #1a7f37;
        }
        .cl-label-edit {
            background: #f0f3f6;
            color: #6c757d;
        }

        .cl-commit-meta {
            display: flex;
            align-items: center;
            gap: 4px;
            margin-top: 2px;
            font-size: 13px;
            color: #6c757d;
        }
        .cl-commit-avatar {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            flex-shrink: 0;
        }
        .cl-commit-user {
            color: #2d2d2d;
            text-decoration: none;
            font-weight: 500;
        }
        .cl-commit-user:hover {
            text-decoration: underline;
            color: #1a5276;
        }
        .cl-commit-anon {
            color: #6c757d;
            font-style: italic;
        }

        /* Right-side metadata */
        .cl-commit-right {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }
        .cl-commit-hash {
            font-size: 12px;
            font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
            color: #1a5276;
            text-decoration: none;
            background: #f0f3f6;
            padding: 2px 8px;
            border-radius: 4px;
            border: 1px solid #dee2e6;
            white-space: nowrap;
        }
        .cl-commit-hash:hover {
            background: #e1e7ed;
            text-decoration: none;
        }
        .cl-commit-time {
            font-size: 13px;
            color: #8c959f;
            white-space: nowrap;
        }

        /* Empty state */
        .cl-empty {
            text-align: center;
            padding: 64px 24px;
        }
        .cl-empty-icon {
            width: 48px;
            height: 48px;
            margin: 0 auto 16px;
            color: #adb5bd;
        }
        .cl-empty h3 {
            font-size: 20px;
            font-weight: 600;
            color: #2d2d2d;
            margin: 0 0 8px;
        }
        .cl-empty p {
            font-size: 14px;
            color: #6c757d;
            margin: 0 0 20px;
        }

        /* CTA banner */
        .cl-contribute-banner {
            margin: 32px 0;
            padding: 20px 24px;
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
        }
        .cl-banner-text {
            flex: 1;
            min-width: 200px;
        }
        .cl-banner-text h4 {
            font-size: 16px;
            font-weight: 600;
            color: #1a1a2e;
            margin: 0 0 4px;
        }
        .cl-banner-text p {
            font-size: 14px;
            color: #6c757d;
            margin: 0;
        }

        .cl-show-more-wrap {
            display: flex;
            justify-content: center;
            margin: 18px 0 8px;
        }
        .cl-show-more-btn {
            border: 1px solid #dee2e6;
            background: #fff;
            color: #1a5276;
            border-radius: 6px;
            padding: 8px 14px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
        }
        .cl-show-more-btn:hover {
            background: #f8f9fa;
            color: #0d3b54;
        }

        /* Responsive */
        @media (max-width: 640px) {
            .cl-header-row {
                flex-direction: column;
            }
            .cl-stats {
                flex-wrap: wrap;
                gap: 12px;
            }
            .cl-commit-row {
                padding: 10px 12px;
                flex-wrap: wrap;
            }
            .cl-commit-right {
                width: 100%;
                justify-content: flex-end;
                margin-top: 4px;
            }
            .cl-commit-badge {
                display: none;
            }
        }
    </style>
    <script src="/js/analytics.js"></script>
</head>

<body>
    <%- include('default/main_site_header', {
        langSwitchEnUrl: '/en/contributions/' + problemName,
        langSwitchRuUrl: '/ru/contributions/' + problemName
    }) %>

    <div class="cl-container">
        <!-- Breadcrumb -->
        <nav class="cl-breadcrumb" aria-label="breadcrumb">
            <a href="/<%= lang %>/"><%= lang === 'ru' ? 'Главная' : 'Home' %></a>
            <span class="cl-breadcrumb-sep">/</span>
            <% if (problemName === 'all') { %>
                <span><%= lang === 'ru' ? 'Все изменения' : 'All Contributions' %></span>
            <% } else { %>
                <a href="/<%= lang %>/<%= problemName %>"><%= problemName %></a>
                <span class="cl-breadcrumb-sep">/</span>
                <span><%= lang === 'ru' ? 'История' : 'History' %></span>
            <% } %>
        </nav>

        <!-- Header -->
        <div class="cl-header">
            <div class="cl-header-row">
                <div>
                    <h1 class="cl-title">
                        <% if (problemName === 'all') { %>
                            <%= lang === 'ru' ? 'Все изменения' : 'All Contributions' %>
                        <% } else { %>
                            <%= lang === 'ru' ? 'История задачи' : 'History for' %> <%= problemName %>
                        <% } %>
                    </h1>
                    <p class="cl-subtitle">
                        <% if (problemName === 'all') { %>
                            <%= lang === 'ru' ? 'Полная история изменений решений. Каждое изменение проверяется сообществом.' : 'Complete record of every solution change. Each contribution is peer-reviewed.' %>
                        <% } else { %>
                            <%= lang === 'ru' ? 'Все редакции этой задачи' : 'Every revision of this problem\'s solution' %>
                        <% } %>
                    </p>
                </div>
                <a href="/<%= lang %>/upload" class="cl-cta">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M7.75 2a.75.75 0 01.75.75V7h4.25a.75.75 0 110 1.5H8.5v4.25a.75.75 0 11-1.5 0V8.5H2.75a.75.75 0 010-1.5H7V2.75A.75.75 0 017.75 2z"/></svg>
                    <%= lang === 'ru' ? 'Добавить решение' : 'Contribute' %>
                </a>
            </div>
        </div>

        <% if (contributions.length > 0) { %>

        <!-- Stats -->
        <div class="cl-stats">
            <div class="cl-stat">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="color: #6c757d;"><path d="M11.93 8.5a4.002 4.002 0 01-7.86 0H.75a.75.75 0 010-1.5h3.32a4.002 4.002 0 017.86 0h3.32a.75.75 0 010 1.5zM10.5 7.75a2.5 2.5 0 10-5 0 2.5 2.5 0 005 0z"/></svg>
                <span class="cl-stat-num"><%= stats.total %></span>
                <%= lang === 'ru' ? 'изменений' : 'contributions' %>
            </div>
            <div class="cl-stat">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="color: #6c757d;"><path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 010-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5zm10.5-1h-8a1 1 0 00-1 1v6.708A2.486 2.486 0 014.5 9h8zM5 12.25v3.25a.25.25 0 00.4.2l1.45-1.087a.25.25 0 01.3 0L8.6 15.7a.25.25 0 00.4-.2v-3.25a.25.25 0 00-.25-.25h-3.5a.25.25 0 00-.25.25z"/></svg>
                <span class="cl-stat-num"><%= stats.uniqueProblems %></span>
                <%= lang === 'ru' ? 'задач' : 'problems' %>
            </div>
            <div class="cl-stat">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="color: #6c757d;"><path d="M2 5.5a3.5 3.5 0 115.898 2.549 5.507 5.507 0 013.034 4.084.75.75 0 11-1.482.235 4.001 4.001 0 00-7.9 0 .75.75 0 01-1.482-.236A5.507 5.507 0 013.102 8.05 3.49 3.49 0 012 5.5zM11 4a.75.75 0 100 1.5 1.5 1.5 0 01.666 2.844.75.75 0 00-.416.672v.352a.75.75 0 00.574.73c1.2.289 2.162 1.2 2.522 2.372a.75.75 0 101.434-.44 5.01 5.01 0 00-2.56-3.012A3 3 0 0011 4zM5.5 3a2 2 0 100 4 2 2 0 000-4z"/></svg>
                <span class="cl-stat-num"><%= stats.uniqueContributors %></span>
                <%= lang === 'ru' ? 'авторов' : 'contributors' %>
            </div>
        </div>

        <!-- Grouped commit list -->
        <% Object.entries(grouped).forEach(([dateLabel, entries]) => { %>
        <div class="cl-date-group">
            <div class="cl-date-header">
                <div class="cl-date-icon">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M11.93 8.5a4.002 4.002 0 01-7.86 0H.75a.75.75 0 010-1.5h3.32a4.002 4.002 0 017.86 0h3.32a.75.75 0 010 1.5zM10.5 7.75a2.5 2.5 0 10-5 0 2.5 2.5 0 005 0z"/></svg>
                </div>
                <span class="cl-date-label">
                    <%= lang === 'ru' ? 'Изменения за' : 'Contributions on' %> <%= dateLabel %>
                </span>
            </div>
            <div class="cl-commit-list">
                <% entries.forEach(contribution => { %>
                <div class="cl-commit-row<%= contribution.isNew ? ' is-new' : '' %>">
                    <div class="cl-commit-badge">
                        <div class="cl-commit-dot"></div>
                    </div>
                    <div class="cl-commit-main">
                        <div class="cl-commit-title">
                            <a href="/<%= contribution.language %>/<%= contribution.problem_name %>" class="cl-commit-problem"><%= contribution.problem_name %></a>
                            <% if (contribution.isNew) { %>
                                <span class="cl-commit-label cl-label-new"><%= lang === 'ru' ? 'новое' : 'new solution' %></span>
                            <% } else { %>
                                <span class="cl-commit-label cl-label-edit"><%= lang === 'ru' ? 'правка' : 'edit' %></span>
                            <% } %>
                        </div>
                        <div class="cl-commit-meta">
                            <% if (contribution.username) { %>
                                <img src="<%= contribution.profile_picture || '/img/profile_images/Default_placeholder.svg' %>"
                                     alt="" class="cl-commit-avatar" width="20" height="20" loading="lazy" />
                                <a href="/user/<%= contribution.username %>" class="cl-commit-user"><%= contribution.username %></a>
                            <% } else { %>
                                <span class="cl-commit-anon"><%= lang === 'ru' ? 'Аноним' : 'Anonymous' %></span>
                            <% } %>
                            <span><%= lang === 'ru' ? 'в' : 'at' %> <time class="cl-local-time" datetime="<%= new Date(contribution.edited_at).toISOString() %>"><%= formatTime(contribution.edited_at) %></time></span>
                        </div>
                    </div>
                    <div class="cl-commit-right">
                        <a href="/<%= contribution.language %>/contributions/<%= contribution.id %>" class="cl-commit-hash" title="<%= lang === 'ru' ? 'Посмотреть изменения' : 'View changes' %>">#<%= contribution.id %></a>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>
        <% }); %>

        <% if (pagination && pagination.hasMore) { %>
        <div class="cl-show-more-wrap">
            <a
                class="cl-show-more-btn"
                href="/<%= lang %>/contributions/<%= problemName %>?offset=<%= pagination.nextOffset %>&limit=<%= pagination.limit %>">
                <%= lang === 'ru' ? 'Показать ещё' : 'Show more' %>
                (<%= stats.total - pagination.nextOffset %>)
            </a>
        </div>
        <% } %>

        <!-- Contribute banner -->
        <div class="cl-contribute-banner">
            <div class="cl-banner-text">
                <h4><%= lang === 'ru' ? 'Помогите расширить коллекцию' : 'Help expand the collection' %></h4>
                <p><%= lang === 'ru' ? '507 задач ещё не имеют решений. Каждое решение проходит рецензию и лицензируется CC BY-SA 4.0.' : 'Hundreds of problems still need solutions. Every contribution is peer-reviewed and licensed CC BY-SA 4.0.' %></p>
            </div>
            <a href="/<%= lang %>/upload" class="cl-cta">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v14"/><path d="M6 9l6-6 6 6"/><path d="M5 19h14"/></svg>
                <%= lang === 'ru' ? 'Загрузить решение' : 'Upload Solution' %>
            </a>
        </div>

        <% } else { %>

        <!-- Empty state -->
        <div class="cl-empty">
            <div class="cl-empty-icon">
                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M11.93 8.5a4.002 4.002 0 01-7.86 0H.75a.75.75 0 010-1.5h3.32a4.002 4.002 0 017.86 0h3.32a.75.75 0 010 1.5zM10.5 7.75a2.5 2.5 0 10-5 0 2.5 2.5 0 005 0z"/></svg>
            </div>
            <h3><%= lang === 'ru' ? 'Нет записей' : 'No contributions yet' %></h3>
            <p><%= lang === 'ru' ? 'Эта задача ещё не имеет истории изменений.' : 'This problem doesn\'t have any recorded contributions yet.' %></p>
            <% if (problemName !== 'all') { %>
            <a href="/<%= lang %>/edit/<%= problemName %>" class="cl-cta">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M11.013 1.427a1.75 1.75 0 012.474 0l1.086 1.086a1.75 1.75 0 010 2.474l-8.61 8.61c-.21.21-.47.364-.756.445l-3.251.93a.75.75 0 01-.927-.928l.929-3.25a1.75 1.75 0 01.445-.758l8.61-8.61zm1.414 1.06a.25.25 0 00-.354 0L3.463 11.1a.25.25 0 00-.064.108l-.563 1.97 1.971-.564a.25.25 0 00.108-.064l8.609-8.61a.25.25 0 000-.353l-1.086-1.086z"/></svg>
                <%= lang === 'ru' ? 'Добавить решение' : 'Be the first to contribute' %>
            </a>
            <% } %>
        </div>

        <% } %>
    </div>

    <%- include('default/modern_footer') %>
    <%- include('default/main_site_search_script') %>

    <script>
      // Server emits the time portion in its own timezone (UTC). Reformat to
      // the viewer's local timezone using the ISO value carried on datetime=.
      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.cl-local-time[datetime]').forEach(el => {
          const d = new Date(el.getAttribute('datetime'));
          if (isNaN(d.getTime())) return;
          el.textContent = d.toLocaleTimeString(undefined, {
            hour: '2-digit',
            minute: '2-digit'
          });
        });
      });
    </script>
</body>

</html>
                <% if (starredSolutions && starredSolutions.length > 0) { %>
                <div style="display:flex;flex-wrap:wrap;gap:6px;">
                    <% starredSolutions.forEach(function(s) { %>
                    <a href="/<%= s.language %>/<%= s.problem_name %>" style="display:inline-block;padding:4px 10px;border:1px solid #dee2e6;border-radius:6px;font-size:13px;color:#1a5276;text-decoration:none;transition:background 0.15s;">
                        <%= s.problem_name %> (<%= s.language %>)
                    </a>
                    <% }); %>
                </div>
                <% } else { %>
                <p style="font-size:13px;color:#6c757d;margin:0;"><%= lang === 'ru' ? 'Нет избранных задач. Добавляйте задачи в избранное для быстрого доступа.' : 'No starred problems yet. Star problems to bookmark them for later.' %></p>

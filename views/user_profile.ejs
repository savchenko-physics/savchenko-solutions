                <span id="last-active"><%= lang === 'ru' ? 'Последняя активность' : 'Last active' %> &mdash;</span>
            </div>
        </section>

        <% if (typeof isOwner !== 'undefined' && isOwner) { %>
        <!-- My Activity (owner only) -->
        <section class="card" style="margin-top:16px;">
            <h2 class="section-title"><%= lang === 'ru' ? 'Моя активность' : 'My Activity' %></h2>

            <!-- Starred Problems -->

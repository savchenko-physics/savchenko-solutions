                <% if (recentForumActivity && recentForumActivity.length > 0) { %>
                <div style="display:flex;flex-direction:column;gap:6px;">
                    <% recentForumActivity.forEach(function(f) { %>
                    <a href="/discuss/<%= f.category_slug %>/<%= f.topic_id %>-<%= f.slug %>" style="display:flex;align-items:center;gap:8px;padding:6px 10px;border:1px solid #dee2e6;border-radius:6px;text-decoration:none;color:#2d2d2d;font-size:13px;transition:background 0.15s;">
                        <span style="color:#6c757d;font-size:12px;flex-shrink:0;width:40px;"><%= f.type === 'topic' ? (lang === 'ru' ? 'Тема' : 'Topic') : (lang === 'ru' ? 'Ответ' : 'Reply') %></span>

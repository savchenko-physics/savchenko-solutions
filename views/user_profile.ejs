    </main>

    <%- include('default/modern_footer') %>
    <%- include('default/main_site_footer_scripts') %>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/d3@7"></script>
    <script src="https://cdn.jsdelivr.net/npm/d3-sankey@0.12.3/dist/d3-sankey.min.js"></script>
    <script>
        const username = "<%= username %>";
        const lang = "<%= lang %>";
        const sessionUsername = <%- sessionUsername ? JSON.stringify(sessionUsername) : "null" %>;
        const heatColors = ["#ebedf0", "#b3c6d9", "#6d93b8", "#3a6a9e", "#1a1a2e"];
        let profileAuthor = {
            username: username,
            fullName: username,
            profilePicture: "/img/profile_images/Default_placeholder.svg",
        };
        let contribPage = 1;
        let radarChart = null;
        let timelineChart = null;

        function fmtMonthYear(dateInput) {
            if (!dateInput) return "\u2014";
            const d = new Date(dateInput);
            return d.toLocaleDateString(lang === "ru" ? "ru-RU" : "en-US", { month: "short", year: "numeric" });
        }

        function relTime(dateInput) {
            if (!dateInput) return "\u2014";
            const d = new Date(dateInput).getTime();
            const diff = Math.floor((Date.now() - d) / 1000);
            if (lang === "ru") {
                if (diff < 60) return "\u0442\u043e\u043b\u044c\u043a\u043e \u0447\u0442\u043e";
                if (diff < 3600) return `${Math.floor(diff / 60)} \u043c\u0438\u043d. \u043d\u0430\u0437\u0430\u0434`;
                if (diff < 86400) return `${Math.floor(diff / 3600)} \u0447. \u043d\u0430\u0437\u0430\u0434`;
                if (diff < 2592000) return `${Math.floor(diff / 86400)} \u0434\u043d. \u043d\u0430\u0437\u0430\u0434`;
                if (diff < 31536000) return `${Math.floor(diff / 2592000)} \u043c\u0435\u0441. \u043d\u0430\u0437\u0430\u0434`;
                return `${Math.floor(diff / 31536000)} \u043b\u0435\u0442 \u043d\u0430\u0437\u0430\u0434`;
            }
            if (diff < 60) return "just now";
            if (diff < 3600) return `${Math.floor(diff / 60)} min ago`;
            if (diff < 86400) return `${Math.floor(diff / 3600)} h ago`;
            if (diff < 2592000) return `${Math.floor(diff / 86400)} days ago`;
            if (diff < 31536000) return `${Math.floor(diff / 2592000)} months ago`;
            return `${Math.floor(diff / 31536000)} years ago`;
        }

        function fmtCommitDate(iso) {
            if (!iso) return "\u2014";
            const d = new Date(iso);
            return d.toLocaleDateString(lang === "ru" ? "ru-RU" : "en-US", {
                month: "short",
                day: "numeric",
                year: "numeric",
            });
        }

        function escapeHtml(s) {
            if (s == null || s === undefined) return "";
            return String(s)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;");
        }

        async function fetchJSON(url) {
            const res = await fetch(url);
            if (!res.ok) throw new Error(`Failed: ${url}`);
            return res.json();
        }

        /* ── Heatmap ── */

        function buildHeatScale(dayCounts) {
            const positives = (dayCounts || [])
                .map((x) => Number(x.count || 0))
                .filter((n) => n > 0)
                .sort((a, b) => a - b);

            if (!positives.length) {
                return { thresholds: [1, 1, 1, 1], cap: 1 };
            }

            const percentile = (p) => {
                const idx = Math.max(0, Math.min(positives.length - 1, Math.floor((positives.length - 1) * p)));
                return positives[idx];
            };

            const cap = Math.max(1, percentile(0.95));
            const q1 = Math.max(1, percentile(0.25));
            const q2 = Math.max(q1, percentile(0.5));
            const q3 = Math.max(q2, percentile(0.75));
            const q4 = Math.max(q3, cap);
            return { thresholds: [q1, q2, q3, q4], cap };
        }

        function heatColor(value, scaleMeta) {
            const n = Number(value || 0);
            if (n <= 0) return heatColors[0];
            const clamped = Math.min(n, scaleMeta.cap);
            const [t1, t2, t3, t4] = scaleMeta.thresholds;
            if (clamped >= t4) return heatColors[4];
            if (clamped >= t3) return heatColors[3];
            if (clamped >= t2) return heatColors[2];
            if (clamped >= t1) return heatColors[1];
            return heatColors[1];
        }

        function localDateKey(d) {
            const y = d.getFullYear();
            const m = String(d.getMonth() + 1).padStart(2, "0");
            const day = String(d.getDate()).padStart(2, "0");
            return `${y}-${m}-${day}`;
        }

        function buildCalendarDays(dayCounts, view) {
            const countMap = new Map(dayCounts.map((x) => [String(x.day).slice(0, 10), x.count]));

            if (!view || view.kind === "rolling") {
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                const start = new Date(today);
                start.setDate(start.getDate() - 364);
                const startDay = (start.getDay() + 6) % 7;
                start.setDate(start.getDate() - startDay);

                const result = [];
                for (let i = 0; i < 371; i += 1) {
                    const d = new Date(start);
                    d.setDate(start.getDate() + i);
                    const key = localDateKey(d);
                    result.push({
                        date: d,
                        count: countMap.get(key) || 0,
                        week: Math.floor(i / 7),
                        dow: (d.getDay() + 6) % 7,
                    });
                }
                return result;
            }

            const Y = view.year;
            const jan1 = new Date(Y, 0, 1);
            jan1.setHours(0, 0, 0, 0);
            const dec31 = new Date(Y, 11, 31);
            dec31.setHours(0, 0, 0, 0);
            const start = new Date(jan1);
            const startDay = (jan1.getDay() + 6) % 7;
            start.setDate(jan1.getDate() - startDay);

            const result = [];
            for (let i = 0; i < 371; i += 1) {
                const d = new Date(start);
                d.setDate(start.getDate() + i);
                const key = localDateKey(d);
                const inYear = d >= jan1 && d <= dec31;
                const count = inYear ? (countMap.get(key) || 0) : 0;
                result.push({
                    date: d,
                    count,
                    week: Math.floor(i / 7),
                    dow: (d.getDay() + 6) % 7,
                });
            }
            return result;
        }

        function calculateStreaks(dayCounts, view) {
            const set = new Set(dayCounts.filter((x) => x.count > 0).map((x) => String(x.day).slice(0, 10)));
            const sortedDays = [...set].sort();
            let longest = 0;
            let run = 0;
            let prev = null;

            sortedDays.forEach((key) => {
                const day = new Date(key + "T12:00:00");
                if (!prev) {
                    run = 1;
                } else {
                    const diff = Math.round((day - prev) / 86400000);
                    run = diff === 1 ? run + 1 : 1;
                }
                if (run > longest) longest = run;
                prev = day;
            });

            let current = 0;
            if (view && view.kind === "year") {
                const y = view.year;
                const nowY = new Date().getFullYear();
                if (y < nowY || y > nowY) {
                    return { longest, current: 0 };
                }
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                const yearEnd = new Date(y, 11, 31);
                yearEnd.setHours(0, 0, 0, 0);
                const end = today <= yearEnd ? today : yearEnd;
                for (let i = 0; i < 400; i += 1) {
                    const d = new Date(end);
                    d.setDate(end.getDate() - i);
                    if (d.getFullYear() !== y) break;
                    const key = localDateKey(d);
                    if (set.has(key)) current += 1;
                    else break;
                }
                return { longest, current };
            }

            const today = new Date();
            today.setHours(0, 0, 0, 0);
            for (let i = 0; i < 365; i += 1) {
                const d = new Date(today);
                d.setDate(today.getDate() - i);
                const key = localDateKey(d);
                if (set.has(key)) current += 1;
                else break;
            }
            return { longest, current };
        }

        let heatmapTooltipHideTimer = null;
        let heatmapTooltipScrollBound = false;

        function getHeatmapCellTooltipEl() {
            return document.getElementById("heatmap-cell-tooltip");
        }

        function ensureHeatmapTooltipOnBody() {
            const tip = getHeatmapCellTooltipEl();
            if (tip && tip.parentElement !== document.body) {
                document.body.appendChild(tip);
            }
        }

        function hideHeatmapCellTooltip() {
            const tip = getHeatmapCellTooltipEl();
            if (!tip) return;
            tip.classList.remove("heatmap-cell-tooltip--visible");
            tip.hidden = true;
            tip.setAttribute("aria-hidden", "true");
        }

        function showHeatmapCellTooltip(cell) {
            const tip = getHeatmapCellTooltipEl();
            if (!tip) return;
            const text = cell.getAttribute("data-heatmap-tip");
            if (!text) return;
            ensureHeatmapTooltipOnBody();
            tip.textContent = text;
            tip.hidden = false;
            tip.setAttribute("aria-hidden", "false");
            requestAnimationFrame(() => {
                tip.classList.add("heatmap-cell-tooltip--visible");
                const r = cell.getBoundingClientRect();
                const margin = 8;
                const tw = tip.offsetWidth;
                const th = tip.offsetHeight;
                let left = r.left + r.width / 2 - tw / 2;
                let top = r.top - th - margin;
                if (top < margin) top = r.bottom + margin;
                const vw = window.innerWidth;
                const vh = window.innerHeight;
                left = Math.max(margin, Math.min(left, vw - tw - margin));
                top = Math.max(margin, Math.min(top, vh - th - margin));
                tip.style.left = `${left}px`;
                tip.style.top = `${top}px`;
            });
        }

        function scheduleHideHeatmapCellTooltip() {
            clearTimeout(heatmapTooltipHideTimer);
            heatmapTooltipHideTimer = setTimeout(() => {
                hideHeatmapCellTooltip();
            }, 80);
        }

        function cancelHideHeatmapCellTooltip() {
            clearTimeout(heatmapTooltipHideTimer);
        }

        function bindHeatmapTooltipDismissOnce() {
            if (heatmapTooltipScrollBound) return;
            const shell = document.querySelector(".heatmap-shell");
            if (!shell) return;
            heatmapTooltipScrollBound = true;
            shell.addEventListener("scroll", hideHeatmapCellTooltip, { passive: true });
            window.addEventListener("scroll", hideHeatmapCellTooltip, { passive: true });
            window.addEventListener("resize", hideHeatmapCellTooltip, { passive: true });
        }

        function renderHeatmapYearNav(years, view) {
            const nav = document.getElementById("heatmap-year-nav");
            nav.innerHTML = "";
            const addBtn = (label, active, yearVal) => {
                const li = document.createElement("li");
                const btn = document.createElement("button");
                btn.type = "button";
                btn.textContent = label;
                if (active) btn.classList.add("is-active");
                btn.addEventListener("click", () => loadHeatmap(yearVal));
                li.appendChild(btn);
                nav.appendChild(li);
            };

            const rolling = !view || view.kind === "rolling";
            addBtn(lang === "ru" ? "12 \u043c\u0435\u0441." : "12 months", rolling, null);
            (years || []).forEach((y) => {
                const active = view && view.kind === "year" && view.year === y;
                addBtn(String(y), active, y);
            });
        }

        function renderHeatmap(payload) {
            const data = Array.isArray(payload) ? { days: payload, view: { kind: "rolling" }, years: [] } : payload;
            const dayCounts = data.days || [];
            const view = data.view || { kind: "rolling" };
            const years = data.years || [];

            const grid = document.getElementById("user-heatmap");
            const months = document.getElementById("user-months");
            const days = buildCalendarDays(dayCounts, view);
            const scaleMeta = buildHeatScale(dayCounts);

            grid.innerHTML = "";
            months.innerHTML = "";

            const loc = lang === "ru" ? "ru-RU" : "en-US";
            const labels = new Array(53).fill("");
            for (const day of days) {
                if (day.date.getDate() === 1) {
                    if (view.kind === "year" && day.date.getFullYear() !== view.year) continue;
                    labels[day.week] = day.date.toLocaleDateString(loc, { month: "short" });
                }
            }
            labels.forEach((m) => {
                const div = document.createElement("div");
                div.textContent = m;
                months.appendChild(div);
            });

            function ordinalDayEn(n) {
                const j = n % 10;
                const k = n % 100;
                if (k >= 11 && k <= 13) return `${n}th`;
                if (j === 1) return `${n}st`;
                if (j === 2) return `${n}nd`;
                if (j === 3) return `${n}rd`;
                return `${n}th`;
            }

            function ruContribWord(n) {
                const mod10 = n % 10;
                const mod100 = n % 100;
                if (mod10 === 1 && mod100 !== 11) return "\u0432\u043a\u043b\u0430\u0434";
                if (mod10 >= 2 && mod10 <= 4 && (mod100 < 10 || mod100 >= 20)) return "\u0432\u043a\u043b\u0430\u0434\u0430";
                return "\u0432\u043a\u043b\u0430\u0434\u043e\u0432";
            }

            bindHeatmapTooltipDismissOnce();

            const today = new Date();
            today.setHours(23, 59, 59, 999);

            days.forEach((day) => {
                if (day.date > today) return;
                const cell = document.createElement("div");
                cell.className = "heat-cell";
                cell.style.gridColumn = String(day.week + 1);
                cell.style.gridRow = String(day.dow + 1);
                cell.style.background = heatColor(day.count, scaleMeta);
                let tipText;
                if (lang === "ru") {
                    const ruDate = day.date.toLocaleDateString("ru-RU", { day: "numeric", month: "long" });
                    tipText = `${day.count} ${ruContribWord(day.count)} ${ruDate}.`;
                } else {
                    const monthLong = day.date.toLocaleDateString("en-US", { month: "long" });
                    const contribWord = day.count === 1 ? "contribution" : "contributions";
                    tipText = `${day.count} ${contribWord} on ${monthLong} ${ordinalDayEn(day.date.getDate())}.`;
                }
                cell.setAttribute("data-heatmap-tip", tipText);
                cell.setAttribute("aria-label", tipText);
                cell.addEventListener("mouseenter", () => {
                    cancelHideHeatmapCellTooltip();
                    showHeatmapCellTooltip(cell);
                });
                cell.addEventListener("mouseleave", scheduleHideHeatmapCellTooltip);
                grid.appendChild(cell);
            });

            const total = dayCounts.reduce((sum, x) => sum + Number(x.count || 0), 0);
            const summaryEl = document.getElementById("heatmap-contrib-summary");
            if (view.kind === "rolling") {
                summaryEl.innerHTML = `<strong>${total.toLocaleString(loc)}</strong> ${lang === "ru" ? "\u0432\u043a\u043b\u0430\u0434\u043e\u0432 \u0437\u0430 \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u0435 12 \u043c\u0435\u0441\u044f\u0446\u0435\u0432" : "contributions in the last year"}`;
            } else {
                summaryEl.innerHTML = `<strong>${total.toLocaleString(loc)}</strong> ${lang === "ru" ? "\u0432\u043a\u043b\u0430\u0434\u043e\u0432 \u0437\u0430" : "contributions in"} ${view.year}`;
            }

            const streaks = calculateStreaks(dayCounts, view);
            const streakEl = document.getElementById("streak-line");
            const yNow = new Date().getFullYear();
            if (view.kind === "rolling") {
                streakEl.textContent = lang === "ru"
                    ? `\u0421\u0435\u0440\u0438\u044f: ${streaks.longest} \u0434\u043d. \u0422\u0435\u043a\u0443\u0449\u0430\u044f \u0441\u0435\u0440\u0438\u044f: ${streaks.current} \u0434\u043d.`
                    : `Longest streak: ${streaks.longest} days. Current streak: ${streaks.current} days.`;
            } else {
                const curPart =
                    view.year < yNow
                        ? ""
                        : streaks.current > 0
                            ? (lang === "ru" ? ` \u0422\u0435\u043a\u0443\u0449\u0430\u044f \u0441\u0435\u0440\u0438\u044f: ${streaks.current} \u0434\u043d.` : ` Current streak: ${streaks.current} days.`)
                            : (lang === "ru" ? " \u0422\u0435\u043a\u0443\u0449\u0430\u044f \u0441\u0435\u0440\u0438\u044f: \u2014" : " Current streak: \u2014");
                streakEl.textContent = lang === "ru"
                    ? `\u0421\u0435\u0440\u0438\u044f: ${streaks.longest} \u0434\u043d.${curPart}`
                    : `Longest streak: ${streaks.longest} days.${curPart}`;
            }

            renderHeatmapYearNav(years, view);
        }

        async function loadHeatmap(year) {
            const url = year != null
                ? `/api/user/${encodeURIComponent(username)}/heatmap?year=${encodeURIComponent(year)}`
                : `/api/user/${encodeURIComponent(username)}/heatmap`;
            const data = await fetchJSON(url);
            renderHeatmap(data);
        }

        /* ── Header ── */

        function renderHeader(data) {
            const user = data.user;
            profileAuthor = {
                username: user.username,
                fullName: user.fullName || user.username,
                profilePicture: user.profilePicture || "/img/profile_images/Default_placeholder.svg",
            };
            const nameEl = document.getElementById("name-line");
            nameEl.classList.remove("skeleton");
            nameEl.textContent = user.fullName || user.username;
            if (user.isVerifiedUser) {
                const badge = document.createElement("span");
                badge.className = "verified-check";
                badge.title = "Verified";
                badge.innerHTML = '<svg viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="#1a1a2e"/><path d="M6 10.5l2.5 2.5L14 7.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
                nameEl.appendChild(badge);
            }

            document.getElementById("profile-avatar").src = user.profilePicture || "/img/profile_images/Default_placeholder.svg";
            document.getElementById("username-line").textContent = `@${user.username}`;

            // Institution + Country on one line
            const institution = document.getElementById("institution-line");
            const parts = [];
            if (user.institution) parts.push(user.institution);
            if (user.countryLocation) {
                const countryText = user.countryLocation + (user.countryFlag ? ` ${user.countryFlag}` : "");
                parts.push(countryText);
            }
            if (parts.length > 0) {
                institution.style.display = "block";
                institution.textContent = parts.join(" \u00b7 ");
            }

            // Bio with truncation
            const bioLine = document.getElementById("bio-line");
            const bioText = document.getElementById("bio-text");
            const bioToggle = document.getElementById("bio-toggle");
            if (user.bio) {
                bioLine.style.display = "block";
                bioText.textContent = user.bio;
                // Check if text is actually truncated (after render)
                requestAnimationFrame(() => {
                    if (bioText.scrollHeight > bioText.clientHeight) {
                        bioToggle.style.display = "inline";
                        bioToggle.addEventListener("click", () => {
                            const expanded = bioText.classList.toggle("bio-expanded");
                            bioToggle.textContent = expanded
                                ? (lang === "ru" ? "показать меньше" : "show less")
                                : (lang === "ru" ? "показать больше" : "show more");
                        });
                    }
                });
            }

            // Edit Profile or Follow/Message buttons
            if (data.isOwnProfile) {
                document.getElementById("edit-profile-link").style.display = "inline";
            } else if (sessionUsername) {
                const followBtn = document.getElementById("follow-btn");
                followBtn.style.display = "inline-block";
                setFollowState(followBtn, data.isFollowing);
                followBtn.addEventListener("click", () => toggleFollow(followBtn, user.id));
                document.getElementById("message-form").style.display = "inline-block";
            }

            const socialRow = document.getElementById("social-row");
            const links = [
                { url: user.github, icon: "bi-github", title: "GitHub" },
                { url: user.linkedin, icon: "bi-linkedin", title: "LinkedIn" },
                { url: user.website, icon: "bi-globe2", title: "Website" },
            ].filter((x) => x.url && String(x.url).trim() !== "");
            links.forEach((x) => {
                const a = document.createElement("a");
                a.className = "social-link";
                a.href = x.url;
                a.target = "_blank";
                a.rel = "noopener noreferrer";
                a.title = x.title;
                a.innerHTML = `<i class="bi ${x.icon}"></i>`;
                socialRow.appendChild(a);
            });

            document.getElementById("stat-solutions").textContent = Number(data.stats.solutions || 0).toLocaleString();
            document.getElementById("stat-edits").textContent = Number(data.stats.edits || 0).toLocaleString();
            document.getElementById("stat-translations").textContent = Number(data.stats.translations || 0).toLocaleString();
            document.getElementById("stat-likes").textContent = Number(data.stats.likesReceived || 0).toLocaleString();

            document.getElementById("member-since").textContent = lang === "ru"
                ? `Участник с ${fmtMonthYear(data.footer.memberSince)}`
                : `Member since ${fmtMonthYear(data.footer.memberSince)}`;
            document.getElementById("last-active").textContent = lang === "ru"
                ? `Последняя активность ${relTime(data.footer.lastActiveAt)}`
                : `Last active ${relTime(data.footer.lastActiveAt)}`;

            const collabRow = document.getElementById("collab-row");
            collabRow.innerHTML = "";
            (data.collaborators || []).forEach((c) => {
                const a = document.createElement("a");
                a.className = "collab-item";
                a.href = `/user/${encodeURIComponent(c.username)}`;
                a.title = c.fullName ? `${c.fullName} (@${c.username})` : `@${c.username}`;
                const uname = escapeHtml(c.username);
                const pic = escapeHtml(c.profilePicture || "/img/profile_images/Default_placeholder.svg");
                const count = Number(c.sharedProblems || 0).toLocaleString();
                a.innerHTML = `
                    <img class="collab-avatar" src="${pic}" alt="@${uname}">
                    <div class="collab-name">${uname}</div>
                    <div class="collab-count">${count}</div>
                `;
                collabRow.appendChild(a);
            });

            if (data.platformOverview) {
                const card = document.getElementById("platform-overview-card");
                const grid = document.getElementById("platform-overview-grid");
                card.style.display = "block";
                const items = lang === "ru" ? [
                    ["Всего решений на платформе", data.platformOverview.total_platform_solutions],
                    ["Зарегистрированных пользователей", data.platformOverview.total_registered_users],
                    ["Просмотров страниц", data.platformOverview.total_page_views],
                    ["Уникальных посетителей", data.platformOverview.unique_visitors],
                    ["Лично написанных решений", data.platformOverview.solutions_personally_authored],
                    ["Переведённых решений", data.platformOverview.solutions_translated],
                ] : [
                    ["Total platform solutions", data.platformOverview.total_platform_solutions],
                    ["Total registered users", data.platformOverview.total_registered_users],
                    ["Total page views", data.platformOverview.total_page_views],
                    ["Total unique visitors", data.platformOverview.unique_visitors],
                    ["Solutions personally authored", data.platformOverview.solutions_personally_authored],
                    ["Solutions translated", data.platformOverview.solutions_translated],
                ];
                grid.innerHTML = "";
                items.forEach(([label, value]) => {
                    const cell = document.createElement("article");
                    cell.className = "stat-tile";
                    cell.innerHTML = `
                        <div class="stat-value" style="font-size:24px;">${Number(value || 0).toLocaleString()}</div>
                        <div class="stat-label">${label}</div>
                    `;
                    grid.appendChild(cell);
                });
            }

            if (data.canShowSankey) {
                document.getElementById("sankey-card").style.display = "block";
                loadSankey();
            }

            // Hide empty sections for zero-contribution profiles
            const totalContribs = Number(data.stats.edits || 0);
            if (totalContribs === 0) {
                document.querySelector(".heatmap-card").style.display = "none";
                document.querySelector(".timeline-radar-card").style.display = "none";
                document.querySelector(".chapters-card").style.display = "none";
                document.querySelector(".collabs-card").style.display = "none";
            }
        }

        /* ── Follow ── */

        function setFollowState(btn, isFollowing) {
            if (isFollowing) {
                btn.textContent = lang === "ru" ? "Подписка" : "Following";
                btn.className = "follow-btn follow-btn--following";
            } else {
                btn.textContent = lang === "ru" ? "Подписаться" : "Follow";
                btn.className = "follow-btn follow-btn--follow";
            }
            btn.dataset.following = isFollowing ? "1" : "0";
        }

        async function toggleFollow(btn, userId) {
            btn.disabled = true;
            try {
                const res = await fetch(`/api/follow/${userId}`, { method: "POST" });
                if (!res.ok) throw new Error("Follow failed");
                const data = await res.json();
                setFollowState(btn, data.following);
            } catch (e) {
                console.error("Follow error:", e);
            } finally {
                btn.disabled = false;
            }
        }

        /* ── Timeline ── */

        async function renderTimeline() {
            const data = await fetchJSON(`/api/user/${username}/timeline`);
            const labels = data.months.map((x) => x.label);
            const values = data.months.map((x) => x.count);
            const ctx = document.getElementById("timeline-chart");
            if (timelineChart) timelineChart.destroy();
            timelineChart = new Chart(ctx, {
                type: "bar",
                data: {
                    labels,
                    datasets: [{
                        data: values,
                        backgroundColor: "#1a1a2e",
                        borderRadius: 2,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { ticks: { color: "#6c757d", maxRotation: 0, autoSkip: true } },
                        y: { ticks: { color: "#6c757d" }, beginAtZero: true },
                    },
                },
            });
            if (data.mostActive) {
                document.getElementById("timeline-summary").textContent = lang === "ru"
                    ? `Самый активный месяц: ${data.mostActive.label} (${data.mostActive.count} вкладов)`
                    : `Most active month: ${data.mostActive.label} (${data.mostActive.count} contributions)`;
            }
        }

        /* ── Radar + Chapter Breakdown ── */

        function renderBreakdownRows(rows) {
            const tbody = document.getElementById("chapter-body");
            tbody.innerHTML = "";
            rows.forEach((row) => {
                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td>${row.chapterName}</td>
                    <td>${row.solved}</td>
                    <td>${row.total}</td>
                    <td>
                        <div style="display:flex;align-items:center;gap:8px;">
                            <div class="progress-track"><div class="progress-fill" style="width:${Math.min(100, row.percentage)}%;"></div></div>
                            <span>${row.percentage.toFixed(1)}%</span>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        async function renderRadarAndBreakdown() {
            const data = await fetchJSON(`/api/user/${username}/radar`);

            // Hide radar if fewer than 5 contributions
            const totalSolved = data.radarAxes.reduce((s, x) => s + x.value, 0);
            if (totalSolved < 5) {
                document.getElementById("radar-card").innerHTML = lang === "ru"
                    ? '<h2 class="section-title">Охват физики</h2><p class="radar-empty">Недостаточно данных</p>'
                    : '<h2 class="section-title">Physics Coverage</h2><p class="radar-empty">Not enough data yet</p>';
            } else {
                const labels = data.radarAxes.map((x) => {
                    const text = x.label;
                    if (text.length <= 25) return text;
                    const parts = text.split('. ');
                    if (parts.length >= 2) {
                        const mid = Math.ceil(parts.length / 2);
                        return [parts.slice(0, mid).join('. '), parts.slice(mid).join('. ')];
                    }
                    const words = text.split(' ');
                    const midW = Math.ceil(words.length / 2);
                    return [words.slice(0, midW).join(' '), words.slice(midW).join(' ')];
                });
                const values = data.radarAxes.map((x) => x.value);
                const ctx = document.getElementById("radar-chart");
                if (radarChart) radarChart.destroy();
                const maxVal = Math.max(1, ...values);
                radarChart = new Chart(ctx, {
                    type: "radar",
                    data: {
                        labels,
                        datasets: [{
                            data: values,
                            backgroundColor: "rgba(26, 26, 46, 0.15)",
                            borderColor: "#1a1a2e",
                            borderWidth: 2,
                            pointBackgroundColor: "#1a1a2e",
                            pointRadius: 3,
                        }],
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            r: {
                                min: 0,
                                max: maxVal,
                                beginAtZero: true,
                                ticks: { display: false },
                                grid: { color: "#dee2e6" },
                                angleLines: { color: "#dee2e6" },
                                pointLabels: {
                                    font: { size: 10 },
                                    color: "#6c757d",
                                    padding: 4,
                                },
                            },
                        },
                    },
                });
            }

            renderBreakdownRows(data.breakdown);
        }

        /* ── Contributions List ── */

        function appendContributionRows(rows) {
            const list = document.getElementById("recent-list");
            const pa = profileAuthor;
            const authorUser = escapeHtml(pa.username);
            const avatarSrc = escapeHtml(pa.profilePicture);
            rows.forEach((row) => {
                const id = row.id;
                const diffHref = `/${row.language}/contributions/${id}`;
                const problemHref = `/${row.language}/${encodeURIComponent(row.problem_name)}`;
                const pn = escapeHtml(row.problem_name);
                const lng = escapeHtml(row.language);
                const dateStr = fmtCommitDate(row.edited_at);
                const isoAttr = escapeHtml(row.edited_at);
                const ariaContribution = lang === "ru"
                    ? `\u0412\u043a\u043b\u0430\u0434 ${id}, \u0437\u0430\u0434\u0430\u0447\u0430 ${row.problem_name}`
                    : `Contribution ${id}, problem ${row.problem_name}`;
                const wrap = document.createElement("div");
                wrap.className = "contrib-latest";
                wrap.setAttribute("role", "group");
                wrap.setAttribute("aria-label", ariaContribution);
                wrap.innerHTML = `
                    <div class="contrib-latest-inner">
                        <div class="contrib-latest-author">
                            <a href="/user/${authorUser}" class="contrib-avatar-wrap" aria-hidden="true" tabindex="-1">
                                <img class="contrib-avatar" src="${avatarSrc}" width="20" height="20" alt="">
                            </a>
                            <a class="contrib-author-link" href="/user/${authorUser}">${authorUser}</a>
                            <span class="contrib-title-wrap">
                                <a class="contrib-title-link" href="${diffHref}">#${id}</a>
                                <span class="contrib-sep" aria-hidden="true" style="color:#57606a;">\u00b7</span>
                                <a class="contrib-problem-link" href="${problemHref}">${pn}</a>
                                <span class="contrib-lang">${lng}</span>
                            </span>
                        </div>
                        <div class="contrib-meta-right">
                            <a class="contrib-hash" href="${diffHref}" title="${ariaContribution}">#${id}</a>
                            <span aria-hidden="true">\u00b7</span>
                            <time class="contrib-time" datetime="${isoAttr}" title="${relTime(row.edited_at)}">${dateStr}</time>
                        </div>
                    </div>
                `;
                list.appendChild(wrap);
            });
        }

        async function loadContributions() {
            const data = await fetchJSON(`/api/user/${username}/contributions?page=${contribPage}&limit=20`);
            appendContributionRows(data.rows || []);
            const link = document.getElementById("show-all-link");
            if (data.hasNext) {
                link.style.display = "inline";
            } else if (contribPage === 1 && (!data.rows || data.rows.length === 0)) {
                document.getElementById("recent-list").innerHTML = `<div class="contrib-time" style="padding:4px 0;">${lang === "ru" ? "\u041d\u0435\u0442 \u043d\u0435\u0434\u0430\u0432\u043d\u0438\u0445 \u0432\u043a\u043b\u0430\u0434\u043e\u0432." : "No recent contributions."}</div>`;
                link.style.display = "none";
            } else {
                link.style.display = "none";
            }
        }

        /* ── Sankey ── */

        async function renderSankey(chapter = null) {
            const query = chapter ? `?chapter=${chapter}` : "";
            const data = await fetchJSON(`/api/user/${username}/sankey${query}`);
            const select = document.getElementById("sankey-chapter");
            if (!select.dataset.bound) {
                select.innerHTML = data.chapters.map((c) => `<option value="${c.number}">${c.number}. ${c.name}</option>`).join("");
                select.dataset.bound = "1";
                select.addEventListener("change", () => {
                    renderSankey(select.value).catch(console.error);
                });
            }
            select.value = String(data.selectedChapter);

            const svg = d3.select("#sankey-svg");
            svg.selectAll("*").remove();
            const width = 900;
            const height = 360;
            const g = svg.append("g");
            const sankey = d3.sankey()
                .nodeWidth(14)
                .nodePadding(14)
                .extent([[1, 1], [width - 1, height - 6]]);

            const graph = sankey({
                nodes: data.nodes.map((d) => ({ ...d })),
                links: data.links.map((d) => ({ ...d })),
            });

            g.append("g")
                .selectAll("rect")
                .data(graph.nodes)
                .join("rect")
                .attr("x", (d) => d.x0)
                .attr("y", (d) => d.y0)
                .attr("height", (d) => Math.max(1, d.y1 - d.y0))
                .attr("width", (d) => d.x1 - d.x0)
                .attr("fill", (d) => (d.name === "Solved" ? "#1a1a2e" : (d.name === "Unsolved" ? "#dee2e6" : "#6d93b8")));

            g.append("g")
                .attr("fill", "none")
                .selectAll("g")
                .data(graph.links)
                .join("path")
                .attr("d", d3.sankeyLinkHorizontal())
                .attr("stroke", (d) => d.target.name === "Solved" ? "#1a1a2e" : "#b8c2cc")
                .attr("stroke-opacity", 0.45)
                .attr("stroke-width", (d) => Math.max(1, d.width));

            g.append("g")
                .style("font", "11px sans-serif")
                .attr("fill", "#2d2d2d")
                .selectAll("text")
                .data(graph.nodes)
                .join("text")
                .attr("x", (d) => d.x0 < width / 2 ? d.x1 + 4 : d.x0 - 4)
                .attr("y", (d) => (d.y1 + d.y0) / 2)
                .attr("dy", "0.35em")
                .attr("text-anchor", (d) => d.x0 < width / 2 ? "start" : "end")
                .text((d) => d.name);
        }

        async function loadSankey() {
            try {
                await renderSankey();
            } catch (_error) {
                document.getElementById("sankey-card").style.display = "none";
            }
        }

        /* ── Init ── */

        async function init() {
            const [stats, heatmap] = await Promise.all([
                fetchJSON(`/api/user/${username}/stats`),
                fetchJSON(`/api/user/${username}/heatmap`),
            ]);
            renderHeader(stats);
            renderHeatmap(heatmap);
            await Promise.all([renderTimeline(), renderRadarAndBreakdown(), loadContributions()]);
            document.getElementById("show-all-link").addEventListener("click", async (e) => {
                e.preventDefault();
                contribPage += 1;
                await loadContributions();
            });
        }

        init().catch((error) => {
            console.error("Profile page failed to load:", error);
        });
    </script>
</body>
</html>

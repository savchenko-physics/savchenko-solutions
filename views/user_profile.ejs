                        <span style="font-weight:600;color:#1a1a2e;"><%= c.score %>/100</span>
                        <% } %>
                    </div>
                    <% }); %>
                </div>
                <% } else { %>
                <p style="font-size:13px;color:#6c757d;margin:0;"><%= lang === 'ru' ? 'Нет участия в челленджах.' : 'No challenge submissions yet.' %></p>
                <% } %>
            </div>

            <!-- Quick Links -->
            <div style="display:flex;gap:12px;flex-wrap:wrap;padding-top:8px;border-top:1px solid #dee2e6;">
                <a href="/settings?tab=privacy" style="font-size:13px;color:#1a5276;text-decoration:none;"><%= lang === 'ru' ? 'Настройки уведомлений' : 'Notification Preferences' %></a>
                <a href="/notifications" style="font-size:13px;color:#1a5276;text-decoration:none;"><%= lang === 'ru' ? 'Все уведомления' : 'View All Notifications' %></a>
            </div>

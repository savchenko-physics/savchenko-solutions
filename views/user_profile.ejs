            <!-- Challenge Submissions -->
            <div style="margin-bottom:20px;">
                <h3 style="font-size:14px;font-weight:600;color:#1a1a2e;margin:0 0 8px;"><%= lang === 'ru' ? 'Участие в челленджах' : 'Challenge Submissions' %></h3>
                <% if (challengeHistory && challengeHistory.length > 0) { %>
                <div style="display:flex;flex-direction:column;gap:6px;">
                    <% challengeHistory.forEach(function(c) { %>

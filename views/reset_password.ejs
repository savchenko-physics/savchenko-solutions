<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta name="robots" content="noindex, nofollow" />
    <%- include(`default/head_${lang}.ejs`) %>
    <%- include('default/main_site_header_head') %>
    <link rel="stylesheet" href="/css/css-latex/login.css" />
    <title><%= lang === 'ru' ? 'Новый пароль' : 'Reset Password' %></title>
    <script src="/js/analytics.js"></script>
</head>
<body class="auth-page">
    <%- include('default/header.ejs') %>
    <div class="container1">
        <h2><%= lang === 'ru' ? 'Новый пароль' : 'Reset Password' %></h2>
        <% if (error) { %>
            <p class="error"><%= error %></p>
        <% } %>
        <% if (!error) { %>
        <form action="/reset-password" method="POST">
            <input type="hidden" name="token" value="<%= token %>">
            <input type="hidden" name="lang" value="<%= lang %>">
            <div class="form-group">
                <label for="password"><%= lang === 'ru' ? 'Новый пароль' : 'New Password' %></label>
                <input type="password" id="password" name="password" required minlength="8" />
            </div>
            <div class="form-group">
                <label for="confirmPassword"><%= lang === 'ru' ? 'Подтвердите пароль' : 'Confirm Password' %></label>
                <input type="password" id="confirmPassword" name="confirmPassword" required minlength="8" />
            </div>
            <button type="submit" class="submit-button"><%= lang === 'ru' ? 'Обновить пароль' : 'Update Password' %></button>
        </form>
        <% } %>
        <p style="margin-top: 16px;">
            <a href="/<%= lang %>/login"><%= lang === 'ru' ? 'Вернуться к входу' : 'Back to login' %></a>
        </p>
    </div>
    <%- include('default/modern_footer') %>
    <%- include('default/main_site_footer_scripts') %>
</body>
</html>

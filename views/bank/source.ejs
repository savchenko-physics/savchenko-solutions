<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= source.name %> — Physics Problem Bank | Savchenko Solutions</title>
    <meta name="description" content="<%= totalProblems %> <%= lang === 'ru' ? 'задач из' : 'problems from' %> <%= source.name %>. <%= source.description || '' %>" />
    <link rel="canonical" href="https://savchenkosolutions.com/bank/source/<%= source.slug %>" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/design-system.css" />
    <link rel="stylesheet" href="/css/main_page.css" />
    <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
    <link rel="icon" type="image/png" href="/img/logo.png" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        .bank-list-container { max-width: 900px; margin: 0 auto; padding: 2rem 1rem; }
        .bank-list-header { margin-bottom: 1.5rem; }
        .bank-list-header h1 {
            font-family: 'Inter', sans-serif;
            font-size: 28px; font-weight: 600; color: #2d2d2d; margin: 0 0 0.25rem 0;
        }
        .bank-list-breadcrumb {
            font-size: 13px; color: #6c757d; margin-bottom: 1rem;
        }
        .bank-list-breadcrumb a { color: #1a5276; text-decoration: none; }
        .bank-list-breadcrumb a:hover { text-decoration: underline; }
        .bank-list-desc { font-size: 14px; color: #6c757d; margin-bottom: 0.5rem; }
        .bank-list-meta { font-size: 13px; color: #6c757d; }

        /* Problem table */
        .problem-table { width: 100%; border-collapse: collapse; }
        .problem-table th {
            text-align: left; font-size: 12px; font-weight: 600; text-transform: uppercase;
            letter-spacing: 0.3px; color: #6c757d; padding: 0.75rem 0.5rem;
            border-bottom: 2px solid #dee2e6;
        }
        .problem-table td { padding: 0.75rem 0.5rem; border-bottom: 1px solid #f0f0f0; font-size: 14px; }
        .problem-table tr:hover td { background: #f8f9fa; }
        .problem-table a { color: #1a5276; text-decoration: none; font-weight: 500; }
        .problem-table a:hover { text-decoration: underline; }
        .diff-badge {
            display: inline-block; padding: 0.15rem 0.5rem; border-radius: 4px;
            font-size: 12px; font-weight: 600; color: #fff;
        }
        .diff-easy { background: #27ae60; }
        .diff-medium { background: #f39c12; }
        .diff-hard { background: #c0392b; }
        .topic-small {
            display: inline-block; padding: 0.1rem 0.45rem; border-radius: 3px;
            font-size: 11px; background: #f8f9fa; border: 1px solid #dee2e6; color: #6c757d;
            text-decoration: none; margin-right: 0.2rem;
        }
        .topic-small:hover { background: #1a1a2e; color: #fff; border-color: #1a1a2e; }

        /* Pagination */
        .bank-pagination { display: flex; justify-content: center; gap: 0.5rem; margin-top: 2rem; }
        .bank-page-link {
            display: inline-block; padding: 0.4rem 0.85rem; border: 1px solid #dee2e6;
            border-radius: 6px; font-size: 14px; text-decoration: none; color: #2d2d2d;
        }
        .bank-page-link:hover { background: #f8f9fa; }
        .bank-page-link.active { background: #1a1a2e; color: #fff; border-color: #1a1a2e; }

        .empty-state { text-align: center; padding: 3rem 1rem; color: #6c757d; }

        @media (max-width: 767px) {
            .problem-table .col-topics { display: none; }
        }
    </style>
    <script src="/js/analytics.js"></script>
</head>

<body>
    <%- include('../default/main_site_header') %>

    <main class="bank-list-container">
        <div class="bank-list-breadcrumb">
            <a href="/bank"><%= lang === 'ru' ? 'Банк задач' : 'Problem Bank' %></a>
            <span> / </span>
            <span><%= source.name %></span>
        </div>

        <div class="bank-list-header">
            <h1><%= source.name %></h1>
            <% if (source.description) { %>
            <p class="bank-list-desc"><%= source.description %></p>
            <% } %>
            <p class="bank-list-meta">
                <%= source.country %>
                · <%= totalProblems %> <%= lang === 'ru' ? 'задач' : 'problems' %>
                <% if (source.url) { %>
                    · <a href="<%= source.url %>" target="_blank" rel="noopener" style="color: #1a5276;"><%= lang === 'ru' ? 'Сайт' : 'Website' %></a>
                <% } %>
            </p>
        </div>

        <% if (problems.length === 0) { %>
        <div class="empty-state">
            <p><%= lang === 'ru' ? 'Задач пока нет.' : 'No problems yet.' %></p>
            <a href="/bank/submit" style="color: #1a5276;"><%= lang === 'ru' ? 'Добавить первую задачу' : 'Submit the first problem' %></a>
        </div>
        <% } else { %>
        <table class="problem-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th><%= lang === 'ru' ? 'Задача' : 'Problem' %></th>
                    <th><%= lang === 'ru' ? 'Год' : 'Year' %></th>
                    <th><%= lang === 'ru' ? 'Сложность' : 'Difficulty' %></th>
                    <th class="col-topics"><%= lang === 'ru' ? 'Темы' : 'Topics' %></th>
                </tr>
            </thead>
            <tbody>
                <% problems.forEach(function(p) { %>
                <tr>
                    <td><%= p.problem_number || p.id %></td>
                    <td><a href="/bank/problem/<%= p.id %>"><%= p.title || (source.name + ' #' + (p.problem_number || p.id)) %></a></td>
                    <td><%= p.year || '—' %></td>
                    <td>
                        <% if (p.difficulty) { %>
                            <span class="diff-badge <%= p.difficulty <= 3 ? 'diff-easy' : p.difficulty <= 6 ? 'diff-medium' : 'diff-hard' %>"><%= p.difficulty %></span>
                        <% } else { %>—<% } %>
                    </td>
                    <td class="col-topics">
                        <% if (p.topics && p.topics.length) { %>
                            <% p.topics.slice(0, 3).forEach(function(t) { %>
                                <a href="/bank/topic/<%= t %>" class="topic-small"><%= t %></a>
                            <% }); %>
                        <% } %>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>

        <% if (totalPages > 1) { %>
        <div class="bank-pagination">
            <% for (let pg = 1; pg <= totalPages; pg++) { %>
                <a href="/bank/source/<%= source.slug %>?page=<%= pg %>" class="bank-page-link <%= pg === page ? 'active' : '' %>"><%= pg %></a>
            <% } %>
        </div>
        <% } %>
        <% } %>
    </main>

    <%- include('../default/modern_footer') %>
</body>
</html>

<!DOCTYPE html>
<% const pageLang = typeof lang !== 'undefined' ? lang : 'en'; %>
<html lang="<%= pageLang %>">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
  <link rel="icon" type="image/png" href="/img/logo.png" />
  <link rel="apple-touch-icon" href="/img/logo.png" />
  <title><%= pageLang === 'ru' ? 'Ошибка сервера' : 'Server error' %> — Savchenko Solutions</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/design-system.css" />
</head>
<body class="d-flex flex-column min-vh-100">
  <!-- Minimal self-contained header so the error page never depends on request/session state -->
  <header style="border-bottom: 1px solid #dee2e6; padding: 16px 24px;">
    <a href="/<%= pageLang %>/" style="display: inline-flex; align-items: center; gap: 10px; text-decoration: none; color: #1a1a2e;">
      <img src="/img/logo.svg" alt="" style="height: 32px;" />
      <span style="font-weight: 600; font-size: 1.1rem;">Savchenko Solutions</span>
    </a>
  </header>

  <main class="flex-grow-1 d-flex align-items-center">
    <div style="max-width: 480px; margin: 80px auto; text-align: center; padding: 0 20px;">
      <h1 style="font-size: 72px; font-weight: 700; color: #1a1a2e; margin-bottom: 8px;">500</h1>
      <p style="font-size: 18px; color: #2d2d2d; margin-bottom: 24px;">
        <%= pageLang === 'ru'
            ? 'Что-то пошло не так на нашей стороне. Мы уже разбираемся.'
            : "Something went wrong on our end — we're looking into it." %>
      </p>
      <p style="font-size: 14px; color: #6c757d;">
        <a href="/<%= pageLang %>/" style="color: #1a5276;"><%= pageLang === 'ru' ? 'На главную' : 'Go to homepage' %></a>
      </p>
    </div>
  </main>

  <%- include('default/modern_footer', { lang: pageLang }) %>
</body>
</html>

<!DOCTYPE html>
<html lang="<%= lang %>">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="content-language" content="<%= lang %>" />
    <meta name="description" content="Search Savchenko Solutions" />
    <meta name="author" content="Aliaksandr Melnichenka" />
    <meta property="og:title" content="Global Search - Savchenko Solutions" />
    <meta property="og:image" content="https://savchenkosolutions.com/img/logo.png" />
    <meta property="og:description" content="Search Savchenko Solutions" />
    <%- include('default/main_site_header_head') %>
    <link rel="stylesheet" href="/css/css-latex/style.css" />
    <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
    <link rel="icon" type="image/png" href="/img/logo.png" />
    <link rel="apple-touch-icon" href="/img/logo.png" />
    <title><%= lang === 'ru' ? 'Поиск' : 'Search' %> - Savchenko Solutions</title>
    <style>
        .search-page-container {
            max-width: 780px;
            margin: 0 auto;
            padding: 32px 16px;
        }
        .search-page-form {
            display: flex;
            gap: 0;
            width: 100%;
            margin-bottom: 20px;
        }
        .search-page-form input[type="text"] {
            flex: 1;
            padding: 10px 14px;
            font-size: 1rem;
            border: 1px solid #dee2e6;
            border-right: none;
            border-radius: 6px 0 0 6px;
            outline: none;
            height: 40px;
            box-sizing: border-box;
        }
        .search-page-form input[type="text"]:focus {
            border-color: #1a5276;
        }
        .search-page-form button {
            padding: 0 20px;
            font-size: 0.875rem;
            font-weight: 600;
            background: #1a1a2e;
            color: #fff;
            border: 1px solid #1a1a2e;
            border-radius: 0 6px 6px 0;
            cursor: pointer;
            height: 40px;
            box-sizing: border-box;
        }
        .search-page-form button:hover {
            background: #2c2c4a;
        }
        .search-results-count {
            font-size: 14px;
            color: #6c757d;
            margin-bottom: 16px;
        }
        .search-filters {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 24px;
        }
        .search-filter-pill {
            display: inline-block;
            padding: 4px 12px;
            font-size: 13px;
            border: 1px solid #dee2e6;
            border-radius: 16px;
            background: #fff;
            color: #2d2d2d;
            cursor: pointer;
            text-decoration: none;
            transition: background-color 0.15s, border-color 0.15s;
        }
        .search-filter-pill:hover {
            background: #f8f9fa;
            border-color: #adb5bd;
            color: #2d2d2d;
            text-decoration: none;
        }
        .search-filter-pill.active {
            background: #1a1a2e;
            color: #fff;
            border-color: #1a1a2e;
        }
        .search-result-card {
            padding: 16px 0;
            border-bottom: 1px solid #dee2e6;
        }
        .search-result-card:last-child {
            border-bottom: none;
        }
        .search-result-name {
            font-size: 16px;
            font-weight: 600;
            margin: 0 0 4px 0;
        }
        .search-result-name a {
            color: #1a5276;
            text-decoration: none;
        }
        .search-result-name a:hover {
            color: #0d3b54;
            text-decoration: underline;
        }
        .search-result-context {
            font-size: 13px;
            color: #6c757d;
            margin: 0 0 6px 0;
        }
        .search-result-snippet {
            font-size: 14px;
            color: #2d2d2d;
            margin: 0;
            line-height: 1.5;
        }
        .search-lang-badge {
            display: inline-block;
            background: #e9ecef;
            border-radius: 3px;
            padding: 1px 6px;
            font-size: 11px;
            color: #6c757d;
            margin-left: 6px;
            vertical-align: middle;
        }
        .search-no-results {
            text-align: center;
            padding: 48px 16px;
            color: #6c757d;
        }
        .search-no-results p {
            font-size: 15px;
            margin-top: 12px;
        }
        .search-no-results a {
            color: #1a5276;
        }
    </style>
    <script src="/js/analytics.js"></script>
</head>

<body class="auth-page">
    <%- include('default/header.ejs') %>
    <div class="search-page-container">
        <h1 style="font-size: 22px; font-weight: 600; margin-bottom: 20px;"><%= lang === 'ru' ? 'Поиск' : 'Search' %></h1>

        <form class="search-page-form" action="/global-search" method="get">
            <input type="hidden" name="lang" value="<%= lang %>">
            <input type="text" name="search" id="search-query"
                placeholder="<%= __('menu.searchPlaceholder') %>"
                value="<%= searchTerm %>" autofocus>
            <button type="submit"><%= __('menu.searchButton') %></button>
        </form>

        <% if (searchTerm && results.length > 0) { %>
            <p class="search-results-count">
                <%= lang === 'ru' ? 'Найдено' : 'Found' %> <%= results.length %> <%= lang === 'ru' ? 'результатов для' : 'results for' %> "<%= searchTerm %>"
            </p>
        <% } %>

        <% if (searchTerm) { %>
        <div class="search-filters" id="search-filters">
            <span class="search-filter-pill active" data-filter="all"><%= lang === 'ru' ? 'Все' : 'All' %></span>
            <span class="search-filter-pill" data-filter="en">English</span>
            <span class="search-filter-pill" data-filter="ru"><%= lang === 'ru' ? 'Русский' : 'Russian' %></span>
            <% if (typeof chapters !== 'undefined' && chapters.length > 0) { %>
                <% chapters.forEach(function(ch) { %>
                    <span class="search-filter-pill" data-filter="ch-<%= ch.num %>">
                        <%= lang === 'ru' ? 'Глава' : 'Chapter' %> <%= ch.num %>
                    </span>
                <% }); %>
            <% } %>
        </div>
        <% } %>

        <div id="results">
            <% if (searchTerm && results.length === 0) { %>
                <div class="search-no-results">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6c757d" stroke-width="1.5">
                        <circle cx="11" cy="11" r="8"/>
                        <path d="M21 21l-4.35-4.35"/>
                    </svg>
                    <p>
                        <%= lang === 'ru'
                            ? 'Решения не найдены для "' + searchTerm + '". Попробуйте поискать по главам или загрузить решение.'
                            : 'No solutions found for "' + searchTerm + '". Try browsing by chapter or upload a solution.' %>
                    </p>
                    <a href="/<%= lang %>"><%= lang === 'ru' ? 'К главам' : 'Browse chapters' %></a>
                </div>
            <% } else if (!searchTerm) { %>
                <p style="color: #6c757d;"><%= __('menu.searchTypeToSeeResults') %></p>
            <% } else { %>
                <% results.forEach(function(result) { %>
                    <div class="search-result-card" data-lang="<%= result.lang %>" data-chapter="<%= result.chapterNum %>">
                        <p class="search-result-name">
                            <a href="<%= result.relativePath %>"><%= result.name %></a>
                            <span class="search-lang-badge"><%= result.lang %></span>
                        </p>
                        <% if (result.chapter || result.section) { %>
                            <p class="search-result-context">
                                <% if (result.chapter) { %><%= lang === 'ru' ? 'Глава' : 'Chapter' %> <%= result.chapterNum %>: <%= result.chapter %><% } %><% if (result.chapter && result.section) { %> &rsaquo; <% } %><%= result.section || '' %>
                            </p>
                        <% } %>
                        <p class="search-result-snippet"><%= result.snippet %></p>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </div>

    <%- include('default/main_site_footer_scripts') %>
    <%- include('default/footer_en.ejs') %>

    <script>
    (function() {
        const filters = document.getElementById('search-filters');
        if (!filters) return;

        const pills = filters.querySelectorAll('.search-filter-pill');
        const cards = document.querySelectorAll('.search-result-card');

        pills.forEach(function(pill) {
            pill.addEventListener('click', function() {
                pills.forEach(function(p) { p.classList.remove('active'); });
                pill.classList.add('active');

                const filter = pill.getAttribute('data-filter');

                cards.forEach(function(card) {
                    const cardLang = card.getAttribute('data-lang');
                    const cardChapter = card.getAttribute('data-chapter');

                    if (filter === 'all') {
                        card.style.display = '';
                    } else if (filter === 'en' || filter === 'ru') {
                        card.style.display = cardLang === filter ? '' : 'none';
                    } else if (filter.startsWith('ch-')) {
                        const chNum = filter.replace('ch-', '');
                        card.style.display = cardChapter === chNum ? '' : 'none';
                    }
                });

                // Update visible count
                const visible = document.querySelectorAll('.search-result-card:not([style*="display: none"])').length;
                const countEl = document.querySelector('.search-results-count');
                if (countEl) {
                    const term = '<%= searchTerm %>';
                    const lang = '<%= lang %>';
                    countEl.textContent = (lang === 'ru' ? 'Найдено ' : 'Found ') + visible + (lang === 'ru' ? ' результатов для "' : ' results for "') + term + '"';
                }
            });
        });
    })();

    (function() {
        const term = '<%= searchTerm.replace(/\'/g, "\\\\'") %>';
        if (!term) return;
        const terms = term.trim().split(/\s+/).filter(function(t) { return t.length > 1; });
        if (!terms.length) return;
        const pattern = new RegExp('(' + terms.map(function(t) { return t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }).join('|') + ')', 'gi');
        document.querySelectorAll('.search-result-snippet').forEach(function(el) {
            el.innerHTML = el.textContent.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(pattern, '<mark style="background:#fff3cd;padding:0 1px;border-radius:2px;">$1</mark>');
        });
    })();
    </script>
</body>

</html>

<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta http-equiv="content-language" content="<%= lang %>" />
  <meta name="keywords" content="<%= __('meta.keywords') %>" />
  <meta name="description" content="<%= __('meta.description') %>" />
  <meta name="author" content="<%= __('meta.author') %>" />
  <meta property="og:title" content="<%= __('title') %>" />
  <meta property="og:image" content="https://savchenkosolutions.com/img/logo.png" />
  <meta property="og:description" content="<%= __('meta.ogDescription') %>" />
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
  <link rel="icon" type="image/png" href="/img/logo.png" />
  <link rel="apple-touch-icon" href="/img/logo.png" />
  <title><%= __('unsolved.title') %></title>

  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
  />
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.9.1/font/bootstrap-icons.css"
  />
  <link rel="stylesheet" href="/css/design-system.css" />
  <link rel="stylesheet" href="/css/main_page.css" />

  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background-color: #ffffff;
    }

    .unsolved-page {
      max-width: 860px;
      margin: 0 auto;
      padding: 40px 20px 60px;
    }

    .unsolved-header {
      margin-bottom: 36px;
    }
    .unsolved-header h1 {
      font-size: 28px;
      font-weight: 600;
      color: #1a1a2e;
      margin: 0 0 4px;
      font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    .unsolved-header p {
      font-size: 15px;
      color: #6c757d;
      margin: 0;
    }

    /* Most Requested */
    .most-wanted {
      margin-bottom: 40px;
    }
    .most-wanted h2 {
      font-size: 18px;
      font-weight: 600;
      color: #1a1a2e;
      margin: 0 0 16px;
      font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    .most-wanted-list {
      list-style: none;
      padding: 0;
      margin: 0;
      border: 1px solid #dee2e6;
      border-radius: 8px;
      overflow: hidden;
    }
    .most-wanted-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 16px;
      border-bottom: 1px solid #f0f0f0;
      font-size: 14px;
    }
    .most-wanted-item:last-child {
      border-bottom: none;
    }
    .most-wanted-item a {
      color: #1a5276;
      text-decoration: none;
      font-weight: 600;
      white-space: nowrap;
    }
    .most-wanted-item a:hover {
      color: #0d3b54;
      text-decoration: underline;
    }
    .most-wanted-context {
      color: #6c757d;
      flex: 1;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .most-wanted-views {
      color: #6c757d;
      font-size: 13px;
      white-space: nowrap;
    }

    /* Accordion */
    .chapter-accordion {
      border: 1px solid #dee2e6;
      border-radius: 8px;
      overflow: hidden;
    }
    .chapter-row {
      border-bottom: 1px solid #f0f0f0;
    }
    .chapter-row:last-child {
      border-bottom: none;
    }
    .chapter-header {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      cursor: pointer;
      user-select: none;
      background: none;
      border: none;
      width: 100%;
      text-align: left;
      font-family: inherit;
      transition: background 100ms ease;
    }
    .chapter-header:hover {
      background: #f8f9fa;
    }
    .chapter-toggle {
      font-size: 12px;
      color: #6c757d;
      transition: transform 200ms ease;
      flex-shrink: 0;
    }
    .chapter-row.is-open .chapter-toggle {
      transform: rotate(90deg);
    }
    .chapter-name {
      font-size: 15px;
      font-weight: 600;
      color: #2d2d2d;
      flex: 1;
      min-width: 0;
    }
    .chapter-progress-bar {
      width: 120px;
      height: 6px;
      border-radius: 3px;
      background: #ebedf0;
      overflow: hidden;
      flex-shrink: 0;
    }
    .chapter-progress-fill {
      height: 100%;
      border-radius: 3px;
      background: #1a1a2e;
      transition: width 300ms ease;
    }
    .chapter-stats {
      font-size: 13px;
      color: #6c757d;
      white-space: nowrap;
      min-width: 60px;
      text-align: right;
    }

    .chapter-body {
      display: none;
      padding: 0 16px 16px;
    }
    .chapter-row.is-open .chapter-body {
      display: block;
    }

    .section-block {
      margin-top: 16px;
    }
    .section-block:first-child {
      margin-top: 8px;
    }
    .section-info {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }
    .section-name {
      font-size: 14px;
      font-weight: 500;
      color: #2d2d2d;
      flex: 1;
    }
    .section-stats {
      font-size: 13px;
      color: #6c757d;
      white-space: nowrap;
    }

    .problem-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .problem-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 4px 10px;
      font-size: 13px;
      font-weight: 500;
      color: #1a5276;
      background: #f8f9fa;
      border: 1px solid #dee2e6;
      border-radius: 4px;
      text-decoration: none;
      transition: border-color 150ms ease, background 150ms ease;
    }
    .problem-chip:hover {
      background: #eef3f7;
      border-color: #1a5276;
      color: #0d3b54;
    }

    @media (max-width: 576px) {
      .unsolved-page {
        padding: 24px 16px 40px;
      }
      .unsolved-header h1 {
        font-size: 24px;
      }
      .chapter-progress-bar {
        width: 80px;
      }
      .chapter-name {
        font-size: 14px;
      }
      .most-wanted-context {
        display: none;
      }
    }
  </style>
  <script src="/js/analytics.js"></script>
</head>
<body>
  <%- include('default/main_site_header', {
    langSwitchEnUrl: '/en/unsolved',
    langSwitchRuUrl: '/ru/unsolved'
  }) %>

  <div class="unsolved-page">
    <div class="unsolved-header">
      <h1><%= totalProblems - totalUniqueSolutions %> <%= lang === 'ru' ? 'Нерешённых задач' : 'Unsolved Problems' %></h1>
      <p><%= lang === 'ru' ? 'Помогите завершить самый полный сборник решений Савченко.' : 'Help complete the most comprehensive Savchenko solution set.' %></p>
    </div>

    <% if (mostWanted && mostWanted.length > 0) { %>
    <div class="most-wanted">
      <h2><%= lang === 'ru' ? 'Самые запрашиваемые' : 'Most Requested' %></h2>
      <ul class="most-wanted-list">
        <% mostWanted.forEach(function(mw) { %>
        <li class="most-wanted-item">
          <a href="/<%= lang %>/upload#<%= mw.problem %>"><%= mw.problem %></a>
          <span class="most-wanted-context"><%= mw.chapter %> &mdash; <%= mw.section %></span>
          <span class="most-wanted-views"><%= lang === 'ru' ? 'просмотров: ' + mw.views : 'viewed ' + mw.views + ' times' %></span>
        </li>
        <% }); %>
      </ul>
    </div>
    <% } %>

    <div class="chapter-accordion">
      <% chapterData.forEach(function(ch) { %>
      <div class="chapter-row">
        <button type="button" class="chapter-header" aria-expanded="false">
          <span class="chapter-toggle">&#9654;</span>
          <span class="chapter-name"><%= lang === 'ru' ? 'Глава' : 'Chapter' %> <%= ch.chapterNum %>. <%= ch.title %></span>
          <span class="chapter-progress-bar">
            <span class="chapter-progress-fill" style="width: <%= ch.total > 0 ? ((ch.solved / ch.total) * 100).toFixed(1) : 0 %>%;"></span>
          </span>
          <span class="chapter-stats"><%= ch.solved %> / <%= ch.total %></span>
        </button>
        <div class="chapter-body">
          <% ch.sections.forEach(function(sec) { %>
          <div class="section-block">
            <div class="section-info">
              <span class="section-name"><%= ch.chapterNum %>.<%= sec.sectionNum %>: <%= sec.title %></span>
              <span class="section-stats"><%= sec.solved %> / <%= sec.total %></span>
            </div>
            <div class="problem-grid">
              <% sec.unsolved.forEach(function(prob) { %>
              <a href="/<%= lang %>/upload#<%= prob.problem %>" class="problem-chip"><%= prob.problem %></a>
              <% }); %>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <% }); %>
    </div>
  </div>

  <%- include('default/modern_footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.querySelectorAll('.chapter-header').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const row = btn.closest('.chapter-row');
        const isOpen = row.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    });
  </script>
  <%- include('default/main_site_search_script') %>
</body>
</html>

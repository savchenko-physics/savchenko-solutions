                <button class="template-btn physics-btn" data-insert="\\vec{F} = m\\vec{a}" data-mode="replace" title="<%= lang === 'ru' ? 'Второй закон Ньютона' : 'Newton\'s second law' %>">\(\vec{F}\!=\!m\vec{a}\)</button>
                <button class="template-btn physics-btn" data-insert="\\frac{mv^{2}}{2}" data-mode="insert" title="<%= lang === 'ru' ? 'Кинетическая энергия' : 'Kinetic energy' %>">\(\frac{mv^2}{2}\)</button>
                <button class="template-btn physics-btn" data-insert="mgh" data-mode="insert" title="<%= lang === 'ru' ? 'Потенциальная энергия' : 'Gravitational potential energy' %>">\(mgh\)</button>
                <button class="template-btn physics-btn" data-insert="v = \\frac{l}{t}" data-mode="replace" title="<%= lang === 'ru' ? 'Скорость' : 'Velocity' %>">\(v=\frac{l}{t}\)</button>
                <button class="template-btn physics-btn" data-insert="F_{\\text{fr}} = \\mu N" data-mode="replace" title="<%= lang === 'ru' ? 'Сила трения' : 'Friction force' %>">\(F_{\text{fr}}\!=\!\mu N\)</button>
                <button class="template-btn physics-btn" data-insert="F = kx" data-mode="replace" title="<%= lang === 'ru' ? 'Закон Гука' : 'Hooke\'s law' %>">\(F\!=\!kx\)</button>
                <button class="template-btn physics-btn" data-insert="\\frac{kx^{2}}{2}" data-mode="insert" title="<%= lang === 'ru' ? 'Энергия упругой деформации' : 'Elastic potential energy' %>">\(\frac{kx^2}{2}\)</button>
                <button class="template-btn physics-btn" data-insert="\\frac{v^{2}}{R}" data-mode="insert" title="<%= lang === 'ru' ? 'Центростремительное ускорение' : 'Centripetal acceleration' %>">\(\frac{v^2}{R}\)</button>
                <button class="template-btn physics-btn" data-insert="h = \\frac{gt^{2}}{2}" data-mode="replace" title="<%= lang === 'ru' ? 'Путь свободного падения' : 'Free-fall distance' %>">\(h=\frac{gt^2}{2}\)</button>
                <button class="template-btn physics-btn" data-insert="s = v_{0}t + \\frac{at^{2}}{2}" data-mode="replace" title="<%= lang === 'ru' ? 'Кинематическое уравнение' : 'Kinematic equation' %>">\(s=v_0 t+\frac{at^2}{2}\)</button>
                <button class="template-btn physics-btn" data-insert="v = \\omega R" data-mode="replace" title="<%= lang === 'ru' ? 'Линейная скорость из угловой' : 'Linear from angular velocity' %>">\(v\!=\!\omega R\)</button>
            </div>
        </div>

        <!-- Row 3: Fields, Waves & Optics -->
        <div class="template-section">
            <div class="template-section-label"><%= lang === 'ru' ? 'Поля, волны и оптика' : 'Fields, Waves &amp; Optics' %></div>
            <div class="template-buttons" id="fieldsTemplates">
                <button class="template-btn physics-btn" data-insert="\\varepsilon = -\\frac{d\\Phi}{dt}" data-mode="replace" title="<%= lang === 'ru' ? 'Закон Фарадея' : 'Faraday\'s law' %>">\(\varepsilon\!=\!-\frac{d\Phi}{dt}\)</button>
                <button class="template-btn physics-btn" data-insert="E = h\\nu" data-mode="replace" title="<%= lang === 'ru' ? 'Энергия фотона' : 'Photon energy' %>">\(E\!=\!h\nu\)</button>
                <button class="template-btn physics-btn" data-insert="T = \\frac{2\\pi}{\\omega}" data-mode="replace" title="<%= lang === 'ru' ? 'Период' : 'Period' %>">\(T=\frac{2\pi}{\omega}\)</button>
                <button class="template-btn physics-btn" data-insert="\\frac{1}{F} = \\frac{1}{d_{1}} + \\frac{1}{d_{2}}" data-mode="replace" title="<%= lang === 'ru' ? 'Формула тонкой линзы' : 'Thin lens equation' %>">\(\frac{1}{F}=\frac{1}{d_1}+\frac{1}{d_2}\)</button>
                <button class="template-btn physics-btn" data-insert="\\Phi = BS\\cos\\alpha" data-mode="replace" title="<%= lang === 'ru' ? 'Магнитный поток' : 'Magnetic flux' %>">\(\Phi\!=\!BS\cos\alpha\)</button>
                <button class="template-btn physics-btn" data-insert="n_{1}\\sin\\alpha = n_{2}\\sin\\beta" data-mode="replace" title="<%= lang === 'ru' ? 'Закон Снеллиуса' : 'Snell\'s law' %>">\(n_1\sin\alpha\!=\!n_2\sin\beta\)</button>
                <button class="template-btn physics-btn" data-insert="T = 2\\pi\\sqrt{\\frac{l}{g}}" data-mode="replace" title="<%= lang === 'ru' ? 'Период маятника' : 'Pendulum period' %>">\(T=2\pi\sqrt{\frac{l}{g}}\)</button>
                <button class="template-btn physics-btn" data-insert="Q = I^{2}Rt" data-mode="replace" title="<%= lang === 'ru' ? 'Закон Джоуля-Ленца' : 'Joule heating' %>">\(Q\!=\!I^2Rt\)</button>
                <button class="template-btn physics-btn" data-insert="pV = \\nu RT" data-mode="replace" title="<%= lang === 'ru' ? 'Уравнение идеального газа' : 'Ideal gas law' %>">\(pV\!=\!\nu RT\)</button>
                <button class="template-btn physics-btn" data-insert="F = G\\frac{m_{1}m_{2}}{r^{2}}" data-mode="replace" title="<%= lang === 'ru' ? 'Закон всемирного тяготения' : 'Gravitational force' %>">\(F=G\frac{m_1 m_2}{r^2}\)</button>
                <button class="template-btn physics-btn" data-insert="B = \\frac{\\mu_{0}I}{2\\pi r}" data-mode="replace" title="<%= lang === 'ru' ? 'Магнитное поле провода' : 'Magnetic field of a wire' %>">\(B=\frac{\mu_0 I}{2\pi r}\)</button>
                <button class="template-btn physics-btn" data-insert="\\frac{1}{\\sqrt{1 - \\frac{v^{2}}{c^{2}}}}" data-mode="insert" title="<%= lang === 'ru' ? 'Фактор Лоренца' : 'Lorentz factor' %>">\(\frac{1}{\sqrt{1-\frac{v^2}{c^2}}}\)</button>
            </div>
        </div>

        <!-- Editor panels -->
        <div class="editor-panels">
            <div>
                <div class="panel-label"><%= lang === 'ru' ? 'Ввод LaTeX' : 'LaTeX Input' %></div>
                <textarea id="latexInput" placeholder="<%= lang === 'ru' ? 'Введите LaTeX, например E = mc^2' : 'Type LaTeX here, e.g. E = mc^2' %>"></textarea>
            </div>
            <div>
                <div class="panel-label"><%= lang === 'ru' ? 'Предпросмотр' : 'Preview' %></div>
                <div class="preview-panel" id="previewPanel">
                    <div id="previewContent">
                        <span class="preview-placeholder"><%= lang === 'ru' ? 'Ваше уравнение появится здесь...' : 'Your equation will appear here...' %></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action buttons -->
        <div class="action-buttons">
            <button class="action-btn" id="copyLatexBtn" title="<%= lang === 'ru' ? 'Копировать LaTeX в буфер обмена' : 'Copy LaTeX to clipboard' %>">
                <svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                <%= lang === 'ru' ? 'Копировать LaTeX' : 'Copy LaTeX' %>
            </button>
            <button class="action-btn" id="copyImageBtn" title="<%= lang === 'ru' ? 'Копировать уравнение как PNG' : 'Copy equation as PNG image' %>">
                <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                <%= lang === 'ru' ? 'Копировать изображение' : 'Copy as Image' %>
            </button>
            <span class="copy-feedback" id="copyFeedback"></span>
        </div>
    </div>

    <%- include('../default/modern_footer') %>
    <%- include('../default/main_site_search_script') %>

    <script>
    (function () {
        var pageLang = "<%= lang %>";

        const textarea = document.getElementById('latexInput');
        const previewContent = document.getElementById('previewContent');
        const previewPanel = document.getElementById('previewPanel');
        const copyLatexBtn = document.getElementById('copyLatexBtn');
        const copyImageBtn = document.getElementById('copyImageBtn');
        const copyFeedback = document.getElementById('copyFeedback');

        let debounceTimer = null;
        const DEBOUNCE_MS = 300;
        let isTypesetting = false;

        // --- Live preview with debounce ---
        function updatePreview() {
            const latex = textarea.value.trim();

            if (!latex) {
                previewContent.innerHTML = '<span class="preview-placeholder">' + (pageLang === "ru" ? "Ваше уравнение появится здесь..." : "Your equation will appear here...") + '</span>';
                return;
            }

            previewContent.innerHTML = '$$' + escapeHtml(latex) + '$$';

            if (!isTypesetting && typeof MathJax !== 'undefined' && MathJax.typesetPromise) {
                isTypesetting = true;
                MathJax.typesetPromise([previewContent]).then(function () {
                    isTypesetting = false;
                });
            }
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.appendChild(document.createTextNode(text));
            return div.innerHTML;
        }

        textarea.addEventListener('input', function () {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(updatePreview, DEBOUNCE_MS);
        });

        // --- Insert at cursor / replace ---
        function insertAtCursor(text) {
            const start = textarea.selectionStart;
            const end = textarea.selectionEnd;
            const before = textarea.value.substring(0, start);
            const after = textarea.value.substring(end);
            textarea.value = before + text + after;
            const cursorPos = start + text.length;
            textarea.setSelectionRange(cursorPos, cursorPos);
            textarea.focus();
            triggerPreview();
        }

        function replaceAll(text) {
            textarea.value = text;
            textarea.focus();
            triggerPreview();
        }

        function triggerPreview() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(updatePreview, 50);
        }

        // Decode HTML entities from data attributes (&#10; for newlines, &amp; for &)
        function decodeDataInsert(raw) {
            const el = document.createElement('textarea');
            el.innerHTML = raw;
            return el.value.replace(/\\\\/g, '\\');
        }

        // --- Symbols collapse toggle ---
        const symbolsSection = document.getElementById('symbolsSection');
        document.getElementById('symbolsCollapseBtn').addEventListener('click', function () {
            symbolsSection.classList.toggle('collapsed');
        });

        // --- Symbols tab switching ---
        document.querySelectorAll('.symbols-tab').forEach(function (tab) {
            tab.addEventListener('click', function () {
                document.querySelectorAll('.symbols-tab').forEach(function (t) { t.classList.remove('active'); });
                this.classList.add('active');
                const target = this.getAttribute('data-tab');
                symbolsSection.querySelectorAll('.symbols-grid').forEach(function (g) {
                    g.style.display = g.id === 'symbols-' + target ? 'grid' : 'none';
                });
                if (symbolsSection.classList.contains('collapsed')) {
                    symbolsSection.classList.remove('collapsed');
                }
            });
        });

        // --- Typeset MathJax in template buttons ---
        if (typeof MathJax !== 'undefined' && MathJax.typesetPromise) {
            MathJax.startup.promise.then(function () {
                var targets = ['mathTemplates', 'mechanicsTemplates', 'fieldsTemplates'].map(function (id) {
                    return document.getElementById(id);
                }).filter(Boolean);
                MathJax.typesetPromise(targets);
            });
        }

        // --- Template button handlers ---
        document.querySelectorAll('[data-insert]').forEach(function (btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                const raw = this.getAttribute('data-insert');
                const text = decodeDataInsert(raw);
                const mode = this.getAttribute('data-mode');

                if (mode === 'replace') {
                    replaceAll(text);
                } else {
                    insertAtCursor(text);
                }
            });
        });

        // --- Copy LaTeX ---
        function showFeedback(msg) {
            copyFeedback.textContent = msg;
            copyFeedback.classList.add('visible');
            setTimeout(function () {
                copyFeedback.classList.remove('visible');
            }, 2000);
        }

        copyLatexBtn.addEventListener('click', function () {
            const latex = textarea.value.trim();
            if (!latex) return;

            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(latex).then(function () {
                    showFeedback(pageLang === "ru" ? "Скопировано!" : "Copied!");
                }).catch(function () {
                    fallbackCopy(latex);
                });
            } else {
                fallbackCopy(latex);
            }
        });

        function fallbackCopy(text) {
            const temp = document.createElement('textarea');
            temp.value = text;
            temp.style.position = 'fixed';
            temp.style.opacity = '0';
            document.body.appendChild(temp);
            temp.select();
            try {
                document.execCommand('copy');
                showFeedback(pageLang === "ru" ? "Скопировано!" : "Copied!");
            } catch (e) {
                showFeedback(pageLang === "ru" ? "Ошибка копирования" : "Copy failed");
            }
            document.body.removeChild(temp);
        }

        // --- Copy as Image ---
        copyImageBtn.addEventListener('click', function () {
            const latex = textarea.value.trim();
            if (!latex) return;

            copyImageBtn.disabled = true;
            showFeedback(pageLang === "ru" ? "Рендеринг..." : "Rendering...");

            // Wait for MathJax to finish, then capture
            const doCapture = function () {
                html2canvas(previewPanel, {
                    backgroundColor: '#ffffff',
                    scale: 2,
                    logging: false
                }).then(function (canvas) {
                    canvas.toBlob(function (blob) {
                        if (navigator.clipboard && navigator.clipboard.write && typeof ClipboardItem !== 'undefined') {
                            const item = new ClipboardItem({ 'image/png': blob });
                            navigator.clipboard.write([item]).then(function () {
                                showFeedback(pageLang === "ru" ? "Скопировано как изображение!" : "Copied as image!");
                                copyImageBtn.disabled = false;
                            }).catch(function () {
                                downloadBlob(blob);
                                copyImageBtn.disabled = false;
                            });
                        } else {
                            downloadBlob(blob);
                            copyImageBtn.disabled = false;
                        }
                    }, 'image/png');
                }).catch(function () {
                    showFeedback(pageLang === "ru" ? "Ошибка рендеринга" : "Render failed");
                    copyImageBtn.disabled = false;
                });
            };
            if (typeof MathJax !== 'undefined' && MathJax.typesetPromise) {
                MathJax.typesetPromise([previewPanel]).then(doCapture);
            } else {
                doCapture();
            }
        });

        function downloadBlob(blob) {
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'equation.png';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            showFeedback(pageLang === "ru" ? "Скачано как PNG" : "Downloaded as PNG");
        }
    })();
    </script>
</body>
</html>

<script>
(function() {
    'use strict';

    var pageLang = "<%= lang %>";

    const searchInput = document.getElementById('formulaSearchInput');
    const searchCount = document.getElementById('searchCount');
    const noResults = document.getElementById('noResults');
    const chapterSelect = document.getElementById('chapterSelect');
    const allCards = document.querySelectorAll('.formula-card');
    const allSections = document.querySelectorAll('.chapter-section');
    const sidebarLinks = document.querySelectorAll('.chapter-sidebar a');

    /* ---- Search ---- */
    let debounceTimer = null;
    searchInput.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(filterFormulas, 150);
    });

    function filterFormulas() {
        const query = searchInput.value.trim().toLowerCase();

        if (!query) {
            allCards.forEach(function(card) { card.style.display = ''; });
            allSections.forEach(function(sec) { sec.style.display = ''; });
            searchCount.style.display = 'none';
            noResults.style.display = 'none';
            return;
        }

        const terms = query.split(/\s+/);
        let visible = 0;

        allCards.forEach(function(card) {
            const keywords = (card.getAttribute('data-keywords') || '').toLowerCase();
            const text = card.textContent.toLowerCase();
            const haystack = keywords + ' ' + text;

            const match = terms.every(function(term) {
                return haystack.indexOf(term) !== -1;
            });

            card.style.display = match ? '' : 'none';
            if (match) visible++;
        });

        /* Hide empty chapter sections */
        allSections.forEach(function(sec) {
            const cards = sec.querySelectorAll('.formula-card');
            let hasVisible = false;
            cards.forEach(function(card) {
                if (card.style.display !== 'none') hasVisible = true;
            });
            sec.style.display = hasVisible ? '' : 'none';
        });

        if (pageLang === 'ru') {
            var mod10 = visible % 10;
            var mod100 = visible % 100;
            var word;
            if (mod10 === 1 && mod100 !== 11) {
                word = 'формула найдена';
            } else if (mod10 >= 2 && mod10 <= 4 && (mod100 < 12 || mod100 > 14)) {
                word = 'формулы найдено';
            } else {
                word = 'формул найдено';
            }
            searchCount.textContent = visible + ' ' + word;
        } else {
            searchCount.textContent = visible + ' formula' + (visible === 1 ? '' : 's') + ' found';
        }
        searchCount.style.display = 'block';
        noResults.style.display = visible === 0 ? 'block' : 'none';
    }

    /* ---- Sidebar smooth scroll ---- */
    sidebarLinks.forEach(function(link) {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
            sidebarLinks.forEach(function(l) { l.classList.remove('active'); });
            this.classList.add('active');
        });
    });

    /* ---- Mobile chapter dropdown ---- */
    if (chapterSelect) {
        chapterSelect.addEventListener('change', function() {
            const id = this.value;
            if (!id) return;
            const target = document.getElementById(id);
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
            this.value = '';
        });
    }

    /* ---- Highlight sidebar on scroll ---- */
    function updateSidebarActive() {
        let current = '';
        allSections.forEach(function(sec) {
            const rect = sec.getBoundingClientRect();
            if (rect.top <= 120) {
                current = sec.id;
            }
        });
        sidebarLinks.forEach(function(link) {
            if (link.getAttribute('href') === '#' + current) {
                link.classList.add('active');
            } else {
                link.classList.remove('active');
            }
        });
    }
    window.addEventListener('scroll', updateSidebarActive, { passive: true });
    updateSidebarActive();
})();
</script>

</body>
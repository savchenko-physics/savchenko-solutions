    <link rel="canonical" href="https://savchenkosolutions.com/<%= lang %>/tools/formulas" />
    <meta property="og:title" content="<%= lang === 'ru' ? 'Формулы для МФО — Savchenko Solutions' : 'Formulas for IPhO — Savchenko Solutions' %>" />

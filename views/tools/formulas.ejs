        <!-- ============================================================
             IX — ELECTROMAGNETISM
        ============================================================ -->
        <section class="chapter-section" id="ch-9">
            <h2><%= lang === 'ru' ? 'IX. Электромагнетизм' : 'IX. Electromagnetism' %></h2>

            <div class="formula-card" data-keywords="coulomb law force potential energy charge electrostatic kepler кулон закон сила потенциальная энергия заряд электростатика кеплер">
                <h3><%= lang === 'ru' ? '1. Закон Кулона' : "1. Coulomb's Law" %></h3>
                <div class="formula-display">$$F = \frac{kq_1 q_2}{r^2}, \qquad \Pi = \frac{kq_1 q_2}{r}$$</div>
                <p class="formula-vars">\(k = 1/(4\pi\varepsilon_0)\). <%= lang === 'ru' ? 'Законы Кеплера применимы для силы' : "Kepler's laws are applicable for" %> \(1/r^2\)<%= lang === 'ru' ? '.' : ' force.' %></p>
            </div>

            <div class="formula-card" data-keywords="gauss law electric field flux enclosed charge magnetic field divergence gravity гаусс закон электрическое поле поток заряд магнитное поле дивергенция гравитация">
                <h3><%= lang === 'ru' ? '2. Теорема Гаусса' : "2. Gauss's Law" %></h3>
                <div class="formula-display">
                    $$\oint \vec{B}\cdot d\vec{S} = 0$$
                    $$\oint \varepsilon\varepsilon_0 \vec{E}\cdot d\vec{S} = Q$$
                    $$\oint \vec{g}\cdot d\vec{S} = -4\pi GM$$
                </div>
                <p class="formula-vars">\(Q\) — <%= lang === 'ru' ? 'заключённый заряд,' : 'enclosed charge,' %> \(M\) — <%= lang === 'ru' ? 'заключённая масса.' : 'enclosed mass.' %></p>
            </div>

            <div class="formula-card" data-keywords="circulation theorem ampere law faraday line integral electric magnetic field current теорема о циркуляции ампер фарадей криволинейный интеграл электрическое магнитное поле ток">
                <h3><%= lang === 'ru' ? '3. Теоремы о циркуляции' : '3. Circulation Theorems' %></h3>
                <div class="formula-display">
                    $$\oint \vec{E}\cdot d\vec{l} = 0 \;(= -\dot\Phi)$$
                    $$\oint \frac{\vec{B}\cdot d\vec{l}}{\mu\mu_0} = I$$
                    $$\oint \vec{g}\cdot d\vec{l} = 0$$
                </div>
                <p class="formula-vars"><%= lang === 'ru' ? 'Криволинейные интегралы по замкнутым контурам. Первое уравнение принимает вид' : 'Line integrals around closed loops. The first equation becomes' %> \(-\dot\Phi\) <%= lang === 'ru' ? 'при переменном магнитном потоке (закон Фарадея).' : 'for time-varying magnetic flux (Faraday\'s law).' %></p>
            </div>

            <div class="formula-card" data-keywords="biot savart law magnetic field current element wire center circular loop био савар закон магнитное поле ток элемент проводник центр круговой виток">
                <h3><%= lang === 'ru' ? '4. Закон Био — Савара' : '4. Biot-Savart Law' %></h3>
                <div class="formula-display">$$d\vec{B} = \frac{\mu\mu_0 I}{4\pi}\frac{d\vec{l}\times\vec{e}_r}{r^2}$$</div>
                <p class="formula-vars"><%= lang === 'ru' ? 'В центре кругового тока:' : 'At the center of a circular current:' %> \(B = \frac{\mu_0 I}{2r}\).</p>
            </div>

            <div class="formula-card" data-keywords="lorentz force charge velocity magnetic electric field wire current лоренц сила заряд скорость магнитное электрическое поле проводник ток">
                <h3><%= lang === 'ru' ? '5. Сила Лоренца' : '5. Lorentz Force' %></h3>
                <div class="formula-display">
                    $$\vec{F} = e(\vec{v}\times\vec{B} + \vec{E})$$
                    $$\vec{F} = I\vec{l}\times\vec{B}$$
                </div>
                <p class="formula-vars">\(e\) — <%= lang === 'ru' ? 'заряд,' : 'charge,' %> \(\vec{v}\) — <%= lang === 'ru' ? 'скорость,' : 'velocity,' %> \(I\) — <%= lang === 'ru' ? 'ток,' : 'current,' %> \(\vec{l}\) — <%= lang === 'ru' ? 'вектор длины проводника.' : 'wire length vector.' %></p>
            </div>

            <div class="formula-card" data-keywords="gauss law applications wire surface sphere cylinder charge density electric magnetic field применения теоремы гаусса провод поверхность сфера цилиндр плотность заряда электрическое магнитное поле">
                <h3><%= lang === 'ru' ? '6. Поля из теорем Гаусса и о циркуляции' : "6. Fields from Gauss's and Circulation Laws" %></h3>
                <div class="formula-display">
                    $$<%= lang === 'ru' ? '\\text{Провод:}' : '\\text{Wire:}' %>\; E = \frac{\sigma}{2\pi\varepsilon_0 r},\quad B = \frac{I\mu_0}{2\pi r}$$
                    $$<%= lang === 'ru' ? '\\text{Плоскость:}' : '\\text{Surface:}' %>\; E = \frac{\sigma}{2\varepsilon_0},\quad B = \frac{\mu_0 j}{2}$$
                </div>
                <p class="formula-vars"><%= lang === 'ru' ? 'Внутри однородно заряженных сферы/цилиндра/слоя с однородными' : 'Inside a uniformly charged sphere/cylinder/layer of homogeneous' %> \(\rho\) <%= lang === 'ru' ? 'или' : 'or' %> \(\vec{j}\): \(\vec{E} = \frac{\rho}{d\varepsilon_0}\vec{r}\), \(\vec{B} = \frac{1}{d}\mu_0\vec{j}\times\vec{r}\), <%= lang === 'ru' ? 'где' : 'where' %> \(d = 3\) (<%= lang === 'ru' ? 'шар' : 'ball' %>), \(d = 2\) (<%= lang === 'ru' ? 'цилиндр' : 'cylinder' %>), \(d = 1\) (<%= lang === 'ru' ? 'слой' : 'layer' %>).</p>
            </div>

            <div class="formula-card" data-keywords="solenoid magnetic field inductance flux turns volume solid angle соленоид магнитное поле индуктивность поток витки объём телесный угол">

<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= lang === 'ru' ? 'Блог' : 'Blog' %> — Savchenko Solutions</title>
    <meta name="description" content="<%= lang === 'ru' ? 'Блог Savchenko Solutions: руководства, разборы задач, новости платформы.' : 'Savchenko Solutions blog: study guides, problem deep dives, and platform updates.' %>" />
    <link rel="canonical" href="https://savchenkosolutions.com/blog<%= activeTag ? '/tag/' + activeTag : '' %>" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/design-system.css" />
    <link rel="stylesheet" href="/css/main_page.css" />
    <link rel="icon" type="image/svg+xml" href="/img/logo.svg" />
    <link rel="icon" type="image/png" href="/img/logo.png" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        .blog-container {
            max-width: 820px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }
        .blog-header {
            margin-bottom: 2rem;
        }
        .blog-header h1 {
            font-family: 'Inter', sans-serif;
            font-size: 28px;
            font-weight: 600;
            color: #2d2d2d;
            margin: 0;
        }
        .tag-filters {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 1rem;
        }
        .tag-pill {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
            text-decoration: none;
            border: 1px solid #dee2e6;
            color: #6c757d;
            background: #f8f9fa;
            transition: all 0.15s;
        }
        /* Need `a.tag-pill` (not bare `.tag-pill`) to outrank the global
           `a:hover:not(.btn)` rule in design-system.css. */
        a.tag-pill:hover,
        a.tag-pill:focus {
            background: #1a1a2e;
            color: #fff;
            border-color: #1a1a2e;
        }
        .tag-pill--active {
            background: #1a1a2e;
            color: #fff;
            border-color: #1a1a2e;
        }
        .tag-pill--active,
        .tag-pill--active:visited,
        .tag-pill--active:hover,
        .tag-pill--active:focus,
        .tag-pill--active:active {
            color: #fff !important;
            text-decoration: none;
        }
        .blog-post-card {
            padding: 1.5rem 0;
            border-bottom: 1px solid #dee2e6;
        }
        .blog-post-card:first-child {
            padding-top: 0;
        }
        .blog-post-card:last-child {
            border-bottom: none;
        }
        .blog-post-title {
            font-family: 'Inter', sans-serif;
            font-size: 20px;
            font-weight: 600;
            margin: 0 0 0.5rem 0;
        }
        .blog-post-title a {
            color: #2d2d2d;
            text-decoration: none;
        }
        .blog-post-title a:hover {
            color: #1a5276;
        }
        .blog-post-excerpt {
            color: #6c757d;
            font-size: 15px;
            line-height: 1.6;
            margin-bottom: 0.75rem;
        }
        .blog-post-meta {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.75rem;
            font-size: 13px;
            color: #6c757d;
        }
        .blog-post-meta a {
            color: #1a5276;
            text-decoration: none;
        }
        .blog-post-meta a:hover {
            text-decoration: underline;
        }
        .blog-post-tags {
            display: flex;
            gap: 0.35rem;
            flex-wrap: wrap;
            margin-top: 0.5rem;
        }
        .blog-post-tags .tag-pill {
            font-size: 12px;
            padding: 0.15rem 0.5rem;
        }
        .blog-view-count {
            color: #6c757d;
        }
        .blog-pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 0 0;
            border-top: 1px solid #dee2e6;
            margin-top: 1rem;
        }
        .blog-pagination a {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.5rem 1rem;
            border: 1px solid #dee2e6;
            border-radius: 6px;
            color: #2d2d2d;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.15s;
        }
        .blog-pagination a:hover {
            background: #f8f9fa;
        }
        .blog-pagination-disabled {
            visibility: hidden;
        }
        .blog-empty {
            text-align: center;
            padding: 3rem 1rem;
            color: #6c757d;
        }
        @media (max-width: 768px) {
            .blog-container { padding: 1rem 0.75rem; }
            .blog-header h1 { font-size: 24px; }
            .blog-post-title { font-size: 18px; }
        }
    </style>
</head>
<body>
    <%
    const tagTranslations = {
        'announcement': 'объявление',
        'beginners': 'для начинающих',
        'community': 'сообщество',
        'guide': 'руководство',
        'history': 'история',
        'meta': 'мета',
        'study-tips': 'советы',
        'physics': 'физика',
        'olympiad': 'олимпиада',
        'solutions': 'решения',
        'tutorial': 'туториал',
        'news': 'новости',
        'update': 'обновление',
        'education': 'образование',
        'mechanics': 'механика',
        'thermodynamics': 'термодинамика',
        'electrodynamics': 'электродинамика',
        'optics': 'оптика',
    };
    function tagLabel(tag) {
        if (lang === 'ru' && tagTranslations[tag]) return tagTranslations[tag];
        return tag;
    }
    %>
    <%- include('../default/main_site_header', { showViewsButton: false }) %>

    <div class="blog-container">
        <div class="blog-header" style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.75rem;">
            <h1><%= lang === 'ru' ? 'Блог' : 'Blog' %></h1>
            <% if (canPost) { %>
            <a href="/blog/new" style="display: inline-flex; align-items: center; gap: 0.4rem; background: #1a1a2e; color: #fff; border: none; border-radius: 6px; padding: 0.5rem 1.25rem; font-size: 14px; font-weight: 500; text-decoration: none; transition: background 0.15s;">
                <i class="fas fa-plus" style="font-size: 12px;"></i> <%= lang === 'ru' ? 'Новая запись' : 'New Post' %>
            </a>
            <% } %>
            <% if (allTags.length > 0) { %>
            <div class="tag-filters">
                <a href="/blog" class="tag-pill <%= !activeTag ? 'tag-pill--active' : '' %>"><%= lang === 'ru' ? 'Все' : 'All' %></a>
                <% allTags.forEach(tag => { %>
                    <a href="/blog/tag/<%= tag %>" class="tag-pill <%= activeTag === tag ? 'tag-pill--active' : '' %>"><%= tagLabel(tag) %></a>
                <% }); %>
            </div>
            <% } %>
        </div>

        <% if (posts.length === 0) { %>
        <div class="blog-empty">
            <p><%= lang === 'ru' ? 'Пока нет записей.' : 'No posts yet.' %></p>
        </div>
        <% } else { %>
        <div class="blog-post-list">
            <% posts.forEach(post => { %>
            <div class="blog-post-card">
                <h2 class="blog-post-title">
                    <a href="/blog/<%= post.slug %>"><%= post.title %></a>
                </h2>
                <p class="blog-post-excerpt"><%= post.excerpt %></p>
                <div class="blog-post-meta">
                    <span>
                        <a href="/user/<%= post.author_username %>"><%= post.author_username %></a>
                    </span>
                    <span><%= new Date(post.published_at).toLocaleDateString(lang === 'ru' ? 'ru-RU' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                    <span class="blog-view-count"><i class="fas fa-eye"></i> <%= post.view_count %></span>
                </div>
                <% if (post.tags && post.tags.length > 0) { %>
                <div class="blog-post-tags">
                    <% post.tags.forEach(tag => { %>
                        <a href="/blog/tag/<%= tag %>" class="tag-pill"><%= tagLabel(tag) %></a>
                    <% }); %>
                </div>
                <% } %>
            </div>
            <% }); %>
        </div>

        <% if (totalPages > 1) { %>
        <div class="blog-pagination">
            <% if (page > 1) { %>
                <a href="/blog<%= activeTag ? '/tag/' + activeTag : '' %>?page=<%= page - 1 %>">
                    &larr; <%= lang === 'ru' ? 'Назад' : 'Previous' %>
                </a>
            <% } else { %>
                <span class="blog-pagination-disabled"></span>
            <% } %>

            <span style="font-size: 14px; color: #6c757d;"><%= page %> / <%= totalPages %></span>

            <% if (page < totalPages) { %>
                <a href="/blog<%= activeTag ? '/tag/' + activeTag : '' %>?page=<%= page + 1 %>">
                    <%= lang === 'ru' ? 'Далее' : 'Next' %> &rarr;
                </a>
            <% } else { %>
                <span class="blog-pagination-disabled"></span>
            <% } %>
        </div>
        <% } %>
        <% } %>
    </div>

    <%- include('../default/modern_footer') %>
</body>
</html>
